<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User List - Go Rush</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.0.0-alpha1/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/dataTables.bootstrap5.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .container-bg {
            background: linear-gradient(135deg, #2078BE 0%, #BC1F2D 100%);
        }

        .card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
            overflow: hidden;
        }

        .card-header {
            background: linear-gradient(135deg, #2078BE 0%, #BC1F2D 100%);
            color: white;
            padding: 20px 30px;
            border: none;
        }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 600;
        }

        .card-body {
            padding: 30px;
        }

        .table {
            margin-bottom: 0;
        }

        .table thead th {
            background: #f8f9fa;
            color: #333;
            font-weight: 600;
            border-bottom: 2px solid #dee2e6;
        }

        /* Print button styles */
        .print-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn-print-main {
            background: #6c757d;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 5px;
            font-weight: 500;
        }

        .btn-print-main:hover {
            background: #5a6268;
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        .btn-confirm-print {
            background: #28a745;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 5px;
            font-weight: 500;
        }

        .btn-confirm-print:hover {
            background: #218838;
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        .btn-cancel-print {
            background: #dc3545;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 5px;
            font-weight: 500;
        }

        .btn-cancel-print:hover {
            background: #c82333;
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        .selection-badge {
            background: #2078BE;
            color: white;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
        }

        .btn-digital-id {
            background: #17a2b8;
            color: white;
            border: none;
            padding: 5px 15px;
            border-radius: 5px;
            margin-right: 5px;
        }

        .btn-qrcode {
            background: #28a745;
            color: white;
            border: none;
            padding: 5px 15px;
            border-radius: 5px;
            margin-right: 5px;
        }

        .btn-edit {
            background: #2078BE;
            color: white;
            border: none;
            padding: 5px 15px;
            border-radius: 5px;
            margin-right: 5px;
        }

        .btn-delete {
            background: #BC1F2D;
            color: white;
            border: none;
            padding: 5px 15px;
            border-radius: 5px;
        }

        .btn-digital-id:hover, .btn-qrcode:hover, .btn-edit:hover, .btn-delete:hover {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        .badge-active {
            background: #28a745;
            padding: 5px 10px;
            border-radius: 20px;
        }

        .badge-inactive {
            background: #dc3545;
            padding: 5px 10px;
            border-radius: 20px;
        }

        .badge-company {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .company-gorush {
            background: #2078BE;
            color: white;
        }

        .company-globex {
            background: #28a745;
            color: white;
        }

        .company-rbskyshop {
            background: #ffc107;
            color: #333;
        }

        .company-others {
            background: #6c757d;
            color: white;
        }

        .logo {
            height: 40px;
            width: auto;
            max-height: 40px;
        }

        /* Checkbox column */
        .checkbox-column {
            width: 40px;
            text-align: center;
        }

        .user-checkbox {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        /* Modal styles for QR code */
        .modal-qr {
            display: none;
            position: fixed;
            z-index: 9999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.8);
            justify-content: center;
            align-items: center;
        }

        .modal-qr-content {
            background-color: white;
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            max-width: 400px;
            width: 90%;
        }

        .modal-qr-content img {
            max-width: 100%;
            height: auto;
            margin: 20px 0;
        }

        .close-modal {
            background: #2078BE;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            cursor: pointer;
            margin-top: 10px;
        }

        .close-modal:hover {
            background: #BC1F2D;
        }

        @media (max-width: 768px) {
            .logo {
                height: 30px;
                max-height: 30px;
            }
        }
    </style>
    <link rel="icon" type="image/png" href="/images/smallgorushlogo.png">
</head>

<body>
    <div class="container-bg">
        <div class="container">
            <%- include('partials/navbar') %>
        </div>
    </div>

    <div class="container mt-4">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h2><i class="fas fa-users"></i> User List</h2>
                    <div class="print-actions">
                        <!-- Normal Print Button -->
                        <button id="printButton" class="btn-print-main" onclick="enableSelectionMode()">
                            <i class="fas fa-print"></i> Print
                        </button>
                        
                        <!-- Selection Mode Buttons (hidden by default) -->
                        <div id="selectionButtons" style="display: none;">
                            <button class="btn-confirm-print" onclick="confirmPrint()">
                                <i class="fas fa-check"></i> Confirm Print (<span id="selectedCount">0</span>)
                            </button>
                            <button class="btn-cancel-print" onclick="cancelSelection()">
                                <i class="fas fa-times"></i> Cancel
                            </button>
                        </div>
                        
                        <form action="/generate-user-ids" method="post" onsubmit="return confirm('Generate missing User IDs for all users? This will assign GRxxxxxx format IDs.');">
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-sync-alt"></i> Generate Missing User IDs
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <% if (typeof success_msg !== 'undefined' && success_msg && success_msg !== '') { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle"></i> <%= success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <% if (typeof error_msg !== 'undefined' && error_msg && error_msg !== '') { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-triangle"></i> <%= error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <div class="table-responsive">
                    <table id="userTable" class="table table-hover">
                        <thead>
                            <tr>
                                <th class="checkbox-column" style="display: none;" id="checkboxHeader"><input type="checkbox" id="selectAllCheckbox" onchange="toggleSelectAll()"></th>
                                <th>No.</th>
                                <th>Name</th>
                                <th>User ID</th>
                                <th>Job Position</th>
                                <th>Company</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(function(user, index) { %>
                                <tr data-user-id="<%= user.userId || user._id %>" data-user-name="<%= user.name %>">
                                    <td class="checkbox-column" style="display: none;"><input type="checkbox" class="user-checkbox" value="<%= user.userId || user._id %>"></td>
                                    <td><%= index + 1 %></td>
                                    <td><%= user.name %></td>
                                    <td><%= user.userId || '-' %></td>
                                    <td><%= user.jobPosition || '-' %></td>
                                    <td>
                                        <% if (user.company) { %>
                                            <span class="badge-company 
                                                <%= user.company === 'Gorush' ? 'company-gorush' : 
                                                   user.company === 'Globex' ? 'company-globex' : 
                                                   user.company === 'Rbskyshop' ? 'company-rbskyshop' : 
                                                   'company-others' %>">
                                                <%= user.company === 'Rbskyshop' ? 'RBSkyshop' : user.company %>
                                            </span>
                                        <% } else { %>
                                            <span class="badge-company company-others">Not Set</span>
                                        <% } %>
                                    </td>
                                    <td><span class="badge bg-info"><%= user.role.toUpperCase() %></span></td>
                                    <td>
                                        <span class="badge <%= user.status === 'Active' ? 'badge-active' : 'badge-inactive' %>">
                                            <%= user.status %>
                                        </span>
                                    </td>
                                    <td>
                                        <% if (user.userId) { %>
                                            <a href="/verify/<%= user.userId %>" target="_blank" class="btn-digital-id btn-sm">
                                                <i class="fas fa-id-card"></i> Digital ID
                                            </a>
                                            <% if (user.qrcodeVerify && user.qrcodeVerify !== '') { %>
                                                <button onclick="showQRCode('<%= user.qrcodeVerify %>', '<%= user.name %>')" class="btn-qrcode btn-sm">
                                                    <i class="fas fa-qrcode"></i> QR Code
                                                </button>
                                            <% } %>
                                        <% } %>
                                        <a href="/updateUser/<%= user.userId || user._id %>" class="btn-edit btn-sm">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>
                                        <button onclick="deleteUser('<%= user.userId || user._id %>')" class="btn-delete btn-sm">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- QR Code Modal -->
    <div id="qrModal" class="modal-qr">
        <div class="modal-qr-content">
            <h3 id="qrUserName"></h3>
            <img id="qrImage" src="" alt="QR Code">
            <button class="close-modal" onclick="closeQRModal()">Close</button>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/bootstrap@5.0.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        let dataTable;
        let selectionMode = false;

        $(document).ready(function() {
            dataTable = $('#userTable').DataTable({
                pageLength: 10,
                language: {
                    search: "Search:",
                    lengthMenu: "Show _MENU_ entries",
                    info: "Showing _START_ to _END_ of _TOTAL_ entries"
                }
            });
        });

        // Enable selection mode (show checkboxes)
        function enableSelectionMode() {
            selectionMode = true;
            
            // Show checkbox column
            $('#checkboxHeader').show();
            $('.checkbox-column').show();
            
            // Hide normal print button, show selection buttons
            $('#printButton').hide();
            $('#selectionButtons').show();
            
            // Update DataTable column visibility
            if (dataTable) {
                dataTable.columns.adjust().draw();
            }
        }

        // Cancel selection mode
        function cancelSelection() {
            selectionMode = false;
            
            // Uncheck all checkboxes
            $('.user-checkbox').prop('checked', false);
            $('#selectAllCheckbox').prop('checked', false);
            
            // Hide checkbox column
            $('#checkboxHeader').hide();
            $('.checkbox-column').hide();
            
            // Hide selection buttons, show normal print button
            $('#selectionButtons').hide();
            $('#printButton').show();
            
            // Update selected count
            updateSelectedCount();
            
            // Update DataTable column visibility
            if (dataTable) {
                dataTable.columns.adjust().draw();
            }
        }

        // Toggle select all checkboxes
        function toggleSelectAll() {
            const isChecked = $('#selectAllCheckbox').is(':checked');
            $('.user-checkbox').prop('checked', isChecked);
            updateSelectedCount();
        }

        // Update selected count display
        function updateSelectedCount() {
            const selectedCount = $('.user-checkbox:checked').length;
            $('#selectedCount').text(selectedCount);
        }

        // Listen for checkbox changes
        $(document).on('change', '.user-checkbox', function() {
            updateSelectedCount();
            
            // Update select all checkbox state
            const totalCheckboxes = $('.user-checkbox').length;
            const checkedCheckboxes = $('.user-checkbox:checked').length;
            $('#selectAllCheckbox').prop('checked', checkedCheckboxes === totalCheckboxes);
        });

        // Confirm print - get selected users and redirect to print page
        function confirmPrint() {
            const selectedUsers = [];
            $('.user-checkbox:checked').each(function() {
                selectedUsers.push($(this).val());
            });
            
            if (selectedUsers.length === 0) {
                alert('Please select at least one user to print.');
                return;
            }
            
            // Redirect to print page with selected user IDs as query parameter
            window.location.href = '/print-multiple?users=' + selectedUsers.join(',');
        }

        function deleteUser(identifier) {
            if (confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
                fetch(`/deleteUser/${identifier}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error deleting user: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error deleting user');
                });
            }
        }

        function showQRCode(qrCodeBase64, userName) {
            const modal = document.getElementById('qrModal');
            const qrImage = document.getElementById('qrImage');
            const qrUserName = document.getElementById('qrUserName');
            
            qrImage.src = qrCodeBase64;
            qrUserName.textContent = userName + "'s QR Code";
            modal.style.display = 'flex';
        }

        function closeQRModal() {
            const modal = document.getElementById('qrModal');
            modal.style.display = 'none';
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('qrModal');
            if (event.target === modal) {
                modal.style.display = 'none';
            }
        }
    </script>
</body>

</html>