<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update User - Go Rush</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.0.0-alpha1/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Cropper.js CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .container-bg {
            background: linear-gradient(135deg, #2078BE 0%, #BC1F2D 100%);
        }

        .card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .card-header {
            background: linear-gradient(135deg, #2078BE 0%, #BC1F2D 100%);
            color: white;
            padding: 20px 30px;
            border: none;
        }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 600;
        }

        .card-body {
            padding: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
            display: block;
        }

        .form-control, .form-select {
            border-radius: 10px;
            border: 2px solid #e0e0e0;
            padding: 10px 15px;
            transition: all 0.3s ease;
        }

        .form-control:focus, .form-select:focus {
            border-color: #2078BE;
            box-shadow: 0 0 0 0.2rem rgba(32, 120, 190, 0.25);
        }

        .btn-submit {
            background: linear-gradient(135deg, #2078BE 0%, #BC1F2D 100%);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: transform 0.3s ease;
            width: 100%;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }

        .profile-preview {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #2078BE;
            margin-top: 10px;
        }

        .qrcode-preview {
            width: 150px;
            height: 150px;
            object-fit: contain;
            border: 2px solid #2078BE;
            border-radius: 10px;
            margin-top: 10px;
        }

        .image-upload-area {
            border: 2px dashed #2078BE;
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .image-upload-area:hover {
            background: #f0f8ff;
        }

        .remove-image-btn {
            display: inline-block;
            margin-left: 10px;
            background: #BC1F2D;
            color: white;
            border: none;
            border-radius: 5px;
            padding: 5px 10px;
            cursor: pointer;
            font-size: 12px;
        }

        .remove-image-btn:hover {
            background: #ff4444;
        }

        .image-container {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
        }

        .logo {
            height: 40px;
            width: auto;
            max-height: 40px;
        }

        .user-id-box {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 10px;
            border-left: 4px solid #2078BE;
            margin-bottom: 20px;
        }

        /* Cropper Modal Styles */
        .cropper-modal {
            display: none;
            position: fixed;
            z-index: 9999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.9);
            justify-content: center;
            align-items: center;
        }

        .cropper-container-box {
            background: white;
            border-radius: 20px;
            padding: 20px;
            max-width: 90%;
            max-height: 90%;
            overflow: auto;
        }

        .cropper-image {
            max-width: 100%;
            max-height: 60vh;
        }

        .cropper-buttons {
            margin-top: 20px;
            text-align: center;
        }

        .cropper-buttons button {
            margin: 0 10px;
            padding: 10px 20px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
        }

        .btn-crop {
            background: #28a745;
            color: white;
        }

        .btn-cancel {
            background: #dc3545;
            color: white;
        }

        @media (max-width: 768px) {
            .logo {
                height: 30px;
                max-height: 30px;
            }
        }
    </style>
    <link rel="icon" type="image/png" href="/images/smallgorushlogo.png">
</head>

<body>
    <div class="container-bg">
        <div class="container">
            <%- include('partials/navbar') %>
        </div>
    </div>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h2><i class="fas fa-user-edit"></i> Update User</h2>
                    </div>
                    <div class="card-body">
                        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <strong><i class="fas fa-exclamation-triangle"></i> Errors:</strong>
                                <ul class="mb-0 mt-2">
                                    <% errors.forEach(function(error) { %>
                                        <li><%= error.msg %></li>
                                    <% }); %>
                                </ul>
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        <% } %>

                        <form action="/updateUser/<%= editUser.userId || editUser._id %>" method="post" id="userForm">
                            <div class="form-group">
                                <label class="form-label">Role <span class="text-danger">*</span></label>
                                <select name="role" id="role" class="form-select" required>
                                    <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                    <option value="manager" <%= editUser.role === 'manager' ? 'selected' : '' %>>Manager</option>
                                    <option value="cs" <%= editUser.role === 'cs' ? 'selected' : '' %>>CS</option>
                                    <option value="warehouse" <%= editUser.role === 'warehouse' ? 'selected' : '' %>>Warehouse</option>
                                    <option value="finance" <%= editUser.role === 'finance' ? 'selected' : '' %>>Finance</option>
                                    <option value="moh" <%= editUser.role === 'moh' ? 'selected' : '' %>>MOH</option>
                                    <option value="dispatcher" <%= editUser.role === 'dispatcher' ? 'selected' : '' %>>Dispatcher</option>
                                    <option value="freelancer" <%= editUser.role === 'freelancer' ? 'selected' : '' %>>Freelancer</option>
                                </select>
                            </div>

                            <div id="regularFields">
                                <div class="form-group">
                                    <label class="form-label">Full Name</label>
                                    <input type="text" name="fullName" class="form-control" value="<%= editUser.fullName || '' %>" placeholder="Enter full name">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Nickname <span class="text-danger">*</span></label>
                                    <input type="text" name="name" class="form-control" required value="<%= editUser.name %>" placeholder="Enter nickname">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Email <span class="text-danger" id="emailRequired">*</span></label>
                                    <input type="email" name="email" class="form-control" id="email" value="<%= editUser.email || '' %>" placeholder="Enter email address">
                                    <small class="text-muted" id="emailHint" style="display: none;">Email is optional for Freelancer/Dispatcher roles</small>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Password <span class="text-danger" id="passwordRequired">*</span></label>
                                    <input type="password" name="password" class="form-control" id="password" placeholder="Leave blank to keep current password">
                                    <small class="text-muted">Leave blank to keep current password (min 6 characters if changing)</small>
                                    <small class="text-muted" id="passwordHint" style="display: none;">Password is optional for Freelancer/Dispatcher roles</small>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">IC No</label>
                                    <input type="text" name="icNum" class="form-control" value="<%= editUser.icNum || '' %>" placeholder="Enter IC number">
                                </div>

                                <!-- NEW COMPANY FIELD -->
                                <div class="form-group">
                                    <label class="form-label">Company</label>
                                    <select name="company" class="form-select">
                                        <option value="Gorush" <%= editUser.company === 'Gorush' ? 'selected' : '' %>>Go Rush</option>
                                        <option value="Globex" <%= editUser.company === 'Globex' ? 'selected' : '' %>>Globex</option>
                                        <option value="Rbskyshop" <%= editUser.company === 'Rbskyshop' ? 'selected' : '' %>>RBSkyshop</option>
                                        <option value="Others" <%= editUser.company === 'Others' ? 'selected' : '' %>>Others</option>
                                    </select>
                                    <small class="text-muted">Select the company this user belongs to (optional)</small>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Job Position <span class="text-danger">*</span></label>
                                    <input type="text" name="jobPosition" class="form-control" required value="<%= editUser.jobPosition || '' %>" placeholder="Enter job position">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Status <span class="text-danger">*</span></label>
                                    <select name="status" class="form-select" required>
                                        <option value="Active" <%= editUser.status === 'Active' ? 'selected' : '' %>>Active</option>
                                        <option value="Inactive" <%= editUser.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">User ID (Unique Identifier)</label>
                                    <input type="text" name="userId" class="form-control" value="<%= editUser.userId || '' %>" placeholder="Enter User ID (e.g., GR000001 or FL000001)">
                                    <small class="text-muted">User ID must be unique. Format: GRxxxxxx or FLxxxxxx</small>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Profile Picture</label>
                                    <div class="image-upload-area" onclick="document.getElementById('profilePictureInput').click()">
                                        <i class="fas fa-cloud-upload-alt fa-2x" style="color: #2078BE;"></i>
                                        <p class="mt-2">Click to upload new profile picture</p>
                                        <small class="text-muted">Supported formats: JPG, PNG, GIF (Click to crop)</small>
                                    </div>
                                    <input type="file" id="profilePictureInput" accept="image/*" style="display: none;">
                                    <input type="hidden" name="profilePicture" id="profilePicture" value="<%= editUser.profilePicture || '' %>">
                                    <input type="hidden" name="removeProfilePicture" id="removeProfilePicture" value="0">
                                    
                                    <div id="profileImageContainer">
                                        <% if (editUser.profilePicture) { %>
                                            <div class="image-container">
                                                <img class="profile-preview" src="<%= editUser.profilePicture %>" alt="Profile Preview">
                                                <button type="button" class="remove-image-btn" id="removeProfileBtn">Remove</button>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">QR Code Image (for verification)</label>
                                    <div class="image-upload-area" onclick="document.getElementById('qrcodeInput').click()">
                                        <i class="fas fa-qrcode fa-2x" style="color: #2078BE;"></i>
                                        <p class="mt-2">Click to upload QR code image</p>
                                        <small class="text-muted">Supported formats: JPG, PNG, GIF</small>
                                    </div>
                                    <input type="file" id="qrcodeInput" accept="image/*" style="display: none;">
                                    <input type="hidden" name="qrcodeVerify" id="qrcodeVerify" value="<%= editUser.qrcodeVerify || '' %>">
                                    <input type="hidden" name="removeQrcode" id="removeQrcode" value="0">
                                    
                                    <div id="qrcodeImageContainer">
                                        <% if (editUser.qrcodeVerify) { %>
                                            <div class="image-container">
                                                <img class="qrcode-preview" src="<%= editUser.qrcodeVerify %>" alt="QR Code Preview">
                                                <button type="button" class="remove-image-btn" id="removeQrcodeBtn">Remove</button>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group mt-4">
                                <button type="submit" class="btn-submit">
                                    <i class="fas fa-save"></i> Update User
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cropper Modal -->
    <div id="cropperModal" class="cropper-modal">
        <div class="cropper-container-box">
            <img id="cropperImage" class="cropper-image" alt="Crop Image">
            <div class="cropper-buttons">
                <button class="btn-crop" onclick="cropImage()">Crop & Save</button>
                <button class="btn-cancel" onclick="closeCropper()">Cancel</button>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/bootstrap@5.0.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Cropper.js JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
    
    <script>
        let cropper = null;
        let currentFile = null;

        // Function to remove profile picture
        function removeProfilePicture() {
            document.getElementById('profilePicture').value = '';
            document.getElementById('removeProfilePicture').value = '1';
            const container = document.getElementById('profileImageContainer');
            if (container) {
                container.innerHTML = '';
            }
        }

        // Function to remove QR code
        function removeQrcode() {
            document.getElementById('qrcodeVerify').value = '';
            document.getElementById('removeQrcode').value = '1';
            const container = document.getElementById('qrcodeImageContainer');
            if (container) {
                container.innerHTML = '';
            }
        }

        // Open cropper modal
        function openCropper(file) {
            currentFile = file;
            const reader = new FileReader();
            reader.onload = function(e) {
                const image = document.getElementById('cropperImage');
                image.src = e.target.result;
                document.getElementById('cropperModal').style.display = 'flex';
                
                if (cropper) {
                    cropper.destroy();
                }
                
                cropper = new Cropper(image, {
                    aspectRatio: 1, // Square for profile picture
                    viewMode: 2,
                    dragMode: 'move',
                    cropBoxMovable: true,
                    cropBoxResizable: true,
                    zoomable: true,
                    zoomOnWheel: true,
                    zoomOnTouch: true,
                    scalable: true,
                    rotatable: true,
                    background: true,
                    guides: true,
                    center: true,
                    highlight: true,
                    autoCrop: true,
                    autoCropArea: 1,
                    responsive: true,
                    restore: true,
                    checkCrossOrigin: true,
                    checkOrientation: true,
                    modal: true
                });
            };
            reader.readAsDataURL(file);
        }

        // Crop and save image
        function cropImage() {
            if (cropper) {
                const canvas = cropper.getCroppedCanvas({
                    width: 200,
                    height: 200,
                    imageSmoothingEnabled: true,
                    imageSmoothingQuality: 'high'
                });
                
                const croppedImage = canvas.toDataURL('image/jpeg', 0.9);
                document.getElementById('profilePicture').value = croppedImage;
                document.getElementById('removeProfilePicture').value = '0';
                
                // Update preview
                const container = document.getElementById('profileImageContainer');
                container.innerHTML = '';
                
                const imageContainer = document.createElement('div');
                imageContainer.className = 'image-container';
                
                const preview = document.createElement('img');
                preview.className = 'profile-preview';
                preview.src = croppedImage;
                preview.alt = 'Profile Preview';
                
                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'remove-image-btn';
                removeBtn.textContent = 'Remove';
                removeBtn.onclick = function() { removeProfilePicture(); };
                
                imageContainer.appendChild(preview);
                imageContainer.appendChild(removeBtn);
                container.appendChild(imageContainer);
                
                closeCropper();
            }
        }

        // Close cropper modal
        function closeCropper() {
            document.getElementById('cropperModal').style.display = 'none';
            if (cropper) {
                cropper.destroy();
                cropper = null;
            }
        }

        // Attach event listeners when DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            // Attach remove profile picture button
            const removeProfileBtn = document.getElementById('removeProfileBtn');
            if (removeProfileBtn) {
                removeProfileBtn.addEventListener('click', removeProfilePicture);
            }
            
            // Attach remove QR code button
            const removeQrcodeBtn = document.getElementById('removeQrcodeBtn');
            if (removeQrcodeBtn) {
                removeQrcodeBtn.addEventListener('click', removeQrcode);
            }
        });

        // Get the current role
        const emailField = document.getElementById('email');
        const passwordField = document.getElementById('password');
        const emailRequired = document.getElementById('emailRequired');
        const passwordRequired = document.getElementById('passwordRequired');
        const emailHint = document.getElementById('emailHint');
        const passwordHint = document.getElementById('passwordHint');
        
        // Function to update field requirements based on role
        function updateFieldRequirements() {
            const role = document.getElementById('role').value;
            
            if (role === 'freelancer' || role === 'dispatcher') {
                emailField.removeAttribute('required');
                passwordField.removeAttribute('required');
                emailRequired.style.display = 'none';
                passwordRequired.style.display = 'none';
                if (emailHint) emailHint.style.display = 'block';
                if (passwordHint) passwordHint.style.display = 'block';
                emailField.placeholder = "Email (optional for Freelancer/Dispatcher)";
                passwordField.placeholder = "Password (optional for Freelancer/Dispatcher)";
            } else {
                emailField.setAttribute('required', 'required');
                emailRequired.style.display = 'inline';
                passwordRequired.style.display = 'inline';
                if (emailHint) emailHint.style.display = 'none';
                if (passwordHint) passwordHint.style.display = 'none';
                emailField.placeholder = "Enter email address";
                passwordField.placeholder = "Leave blank to keep current password";
            }
        }
        
        if (document.getElementById('role')) {
            updateFieldRequirements();
            document.getElementById('role').addEventListener('change', updateFieldRequirements);
        }

        // Profile Picture upload with cropper
        const profileInput = document.getElementById('profilePictureInput');
        if (profileInput) {
            profileInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    openCropper(file);
                    profileInput.value = ''; // Clear input
                }
            });
        }

        // QR Code upload and compression (no cropper needed for QR)
        const qrcodeInput = document.getElementById('qrcodeInput');
        if (qrcodeInput) {
            qrcodeInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const img = new Image();
                        img.onload = function() {
                            const canvas = document.createElement('canvas');
                            const ctx = canvas.getContext('2d');
                            
                            canvas.width = 300;
                            canvas.height = 300;
                            ctx.drawImage(img, 0, 0, 300, 300);
                            
                            const compressedBase64 = canvas.toDataURL('image/jpeg', 0.8);
                            document.getElementById('qrcodeVerify').value = compressedBase64;
                            document.getElementById('removeQrcode').value = '0';
                            
                            const container = document.getElementById('qrcodeImageContainer');
                            container.innerHTML = '';
                            
                            const imageContainer = document.createElement('div');
                            imageContainer.className = 'image-container';
                            
                            const preview = document.createElement('img');
                            preview.className = 'qrcode-preview';
                            preview.src = compressedBase64;
                            preview.alt = 'QR Code Preview';
                            
                            const removeBtn = document.createElement('button');
                            removeBtn.type = 'button';
                            removeBtn.className = 'remove-image-btn';
                            removeBtn.textContent = 'Remove';
                            removeBtn.addEventListener('click', removeQrcode);
                            
                            imageContainer.appendChild(preview);
                            imageContainer.appendChild(removeBtn);
                            container.appendChild(imageContainer);
                        };
                        img.src = event.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            });
        }
    </script>
</body>

</html>