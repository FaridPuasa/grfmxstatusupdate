            } else if (this.value === 'onebyone') {
                hideDeliveryBulkTextarea();
                hideDeliverySubmitButton();
                showDeliveryOneByOneScanner();
            } else {
                hideDeliveryBulkTextarea();
                hideDeliverySubmitButton();
