                if (isUp) {
                    currentValueLabel.textContent = 'Current Values:';
                    currentValueDiv.innerHTML = `
                <div>Current Payment Method: ${escapeHtml(result.paymentMethod !== '' && result.paymentMethod != null ? String(result.paymentMethod) : 'None')}</div>
                <div>Current Price: ${escapeHtml(result.totalPrice !== '' && result.totalPrice != null ? String(result.totalPrice) : 'None')}</div>
            `;
