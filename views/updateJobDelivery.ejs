                    const result = await res.json();

                    if (!res.ok || !result.exists) {
                        ucdrCheckStatusDiv.textContent = 'Tracking number not found.';
                        ucdrCheckStatusDiv.className = 'mt-2 text-danger';
                    } else {
                        ucdrCheckStatusDiv.textContent = '';
                        consignmentIDField.value = trackingNumber;

                        ucdrCurrentRemarksDiv.textContent = result.remarks ? result.remarks : 'No remarks available';
                        $("#dlvUcdrCurrentRemarksWrapper").fadeIn();

