            paymentMethodField.addEventListener('change', updatePriceWrapper);
            updateDeliveryFieldStatus();
            dispatchersField.addEventListener('change', updateFreelancerNameField);
            updateFreelancerNameField();
    

        // ==================================================
        // 🧩 MERGED PAGE GLUE (new code, not ported from either source page)
        //
        // Everything above this point is the job flow (verbatim from
