        // ==================================================
        // 🛡️ ESCAPE HTML FUNCTION (STANDALONE)
        // ==================================================

        function escapeHtml(text) {
            if (!text) return '';
            return String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;')
                .replace(/\n/g, '<br>');
        }

        // If every item shares the same value for a field, return that value so callers
        // can show it once above a table instead of repeating it in every row. Returns
        // null if the value varies (or the list is empty), meaning the column is still needed.
        function commonValue(items, getter) {
            if (!items || items.length === 0) return null;
            const first = getter(items[0]);
            return items.every(item => getter(item) === first) ? first : null;
        }

        // ==================================================
        // 📊 UPDATE BULK STYLE RESULTS (for one-by-one SBR)
        // ==================================================

        function updateBulkStyleResults() {
            // Update the summary cards if they exist in the DOM
            const updatedCountElem = document.getElementById('updatedCount');
            const failedCountElem = document.getElementById('failedCount');
            const totalCountElem = document.getElementById('totalCount');
            const duplicateCountElem = document.getElementById('duplicateCount');
            const delayedCountElem = document.getElementById('delayedCount');

            // Use global scanResults object
            if (typeof scanResults !== 'undefined') {
                if (updatedCountElem) {
                    updatedCountElem.textContent = scanResults.updatedCount || 0;
                }
                if (failedCountElem) {
                    failedCountElem.textContent = scanResults.notUpdatedCount || 0;
                }
                if (totalCountElem) {
                    const total = (scanResults.updatedCount || 0) + (scanResults.notUpdatedCount || 0) + (scanResults.duplicateCount || 0) + (scanResults.delayedCount || 0);
                    totalCountElem.textContent = total;
                }
                if (duplicateCountElem) {
                    duplicateCountElem.textContent = scanResults.duplicateCount || 0;
                }
                if (delayedCountElem) {
                    delayedCountElem.textContent = scanResults.delayedCount || 0;
                }
            }
        }

        // Groups IIW scan results by customer name + area, so parcels for the same
        // customer are easy to spot and sort together while scanning one by one.
        // Mirrors groupIIWResultsByCustomer() server-side (used for bulk IIW).
        function groupScanResultsByCustomer(items) {
            const grouped = {};

            items.forEach(item => {
                if (item.customerName && item.area) {
                    const key = `${item.customerName}|${item.area}`;

                    if (!grouped[key]) {
                        grouped[key] = {
                            customerName: item.customerName,
                            area: item.area,
                            trackingNumbers: [],
                            count: 0
                        };
                    }

                    grouped[key].trackingNumbers.push(item.trackingNumber);
                    grouped[key].count++;
                }
            });

            return Object.values(grouped).sort((a, b) => b.count - a.count);
        }

