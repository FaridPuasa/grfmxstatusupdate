        // delivery flow that the standalone updateDelivery.ejs never had.
        // ==================================================

        // ---- Delivery-flow scan accumulator (mirrors job's `scanResults`) ----
        let dlvScanResults = { successful: [], failed: [], updatedCount: 0, notUpdatedCount: 0 };

        const DLV_DANGER_ZONE_ACTIONS = {
            'CD': 'Cancel',
            'AJ': 'Reactivate (Cancelled -> Active)',
            '47': 'Dispose'
        };

        // Codes that must always go through the single-tracking-number
        // scanning loop instead of the bulk/one-by-one choice.
        const DLV_SINGLE_ONLY_CODES = ['UW', 'UP', 'UAR', 'UAS', 'UPN', 'URN', 'UJM', 'UPC', 'UAB', 'UGR'];

        function getDeliveryActionTitle() {
            const select = document.getElementById('actionCode');
            const opt = select.selectedOptions[0];
