        const processedTrackingNumbers = {
            bulk: new Map(),
            onebyone: new Map()
        };

        // Front-end version of trackDuplicate function
        function trackDuplicate(trackingNumber, updateCode, updateMethod = 'bulk') {
            const key = `${updateCode}_${trackingNumber}`;
            const tracker = updateMethod === 'onebyone' ? processedTrackingNumbers.onebyone : processedTrackingNumbers.bulk;

            const now = Date.now();
            const oneHour = 60 * 60 * 1000;

            if (tracker.has(key)) {
                const data = tracker.get(key);

                // Clean old entries
                if (now - data.lastSeen > oneHour) {
                    tracker.delete(key);
                    // Recreate as new entry
                    tracker.set(key, {
                        trackingNumber: trackingNumber,
                        updateCode: updateCode,
                        count: 1,
                        firstSeen: now,
                        lastSeen: now,
                        processed: false,
                        method: updateMethod
                    });
                    return { isDuplicate: false, count: 1 };
                }

                data.count = (data.count || 1) + 1;
                data.lastSeen = now;
                tracker.set(key, data);
                return { isDuplicate: true, count: data.count };
            } else {
                // First time seeing this tracking number
                tracker.set(key, {
                    trackingNumber: trackingNumber,
                    updateCode: updateCode,
                    count: 1,
                    firstSeen: now,
                    lastSeen: now,
                    processed: false,
                    method: updateMethod
                });
                return { isDuplicate: false, count: 1 };
            }
        }

        // Function to load only GDEX/GDEXT MAWBs for SBR
        async function loadGDEXMAWBs() {
            try {
                console.log('🔍 Fetching GDEX/GDEXT MAWBs for SBR...');

                const response = await fetch('/updateJob/gdexMAWBs');
                const data = await response.json();

                console.log('📊 GDEX MAWB response:', data);

                const mawbSelect = document.getElementById('mawbNum');
                const mawbStats = document.getElementById('mawbStats');
                const mawbStatsText = document.getElementById('mawbStatsText');

                // Clear existing options (keep first empty option)
                while (mawbSelect.options.length > 1) {
                    mawbSelect.remove(1);
                }

                if (data.success && data.mawbs && data.mawbs.length > 0) {
                    console.log(`✅ Found ${data.mawbs.length} GDEX/GDEXT MAWBs`);

                    data.mawbs.forEach(mawb => {
                        const option = document.createElement('option');
                        option.value = mawb.mawbNo;
                        option.textContent = `${mawb.mawbNo} (${mawb.totalJobs}) - ${mawb.product}`;
                        option.setAttribute('data-total', mawb.totalJobs);
                        option.setAttribute('data-product', mawb.product);
                        option.setAttribute('data-last-updated', mawb.lastUpdated);
                        mawbSelect.appendChild(option);
                    });

                    mawbStats.style.display = 'block';
                    mawbStatsText.textContent = `Showing ${data.mawbs.length} GDEX MAWBs from last 30 days with ${data.summary?.totalJobs || 0} total jobs`;

                    // Show the first option as selected hint
                    if (mawbSelect.options.length > 1) {
                        mawbSelect.selectedIndex = 0;
                    }

                } else {
                    console.log('⚠️ No GDEX/GDEXT MAWBs found');

                    const option = document.createElement('option');
                    option.value = '';
                    option.textContent = 'No GDEX/GDEXT MAWBs found';
                    option.disabled = true;
                    option.selected = true;
                    mawbSelect.appendChild(option);

                    mawbStats.style.display = 'block';
                    mawbStatsText.textContent = 'No GDEX/GDEXT MAWBs found in the system. Make sure there are orders with product "gdex" or "gdext" and MAWB numbers assigned.';
                }

            } catch (error) {
                console.error('❌ Error loading GDEX MAWBs:', error);

                const mawbSelect = document.getElementById('mawbNum');
                const mawbStats = document.getElementById('mawbStats');
                const mawbStatsText = document.getElementById('mawbStatsText');

                // Clear options
                while (mawbSelect.options.length > 1) {
                    mawbSelect.remove(1);
                }

                const option = document.createElement('option');
                option.value = '';
                option.textContent = 'Error loading MAWB numbers';
                option.disabled = true;
                option.selected = true;
                mawbSelect.appendChild(option);

                mawbStats.style.display = 'block';
                mawbStatsText.textContent = `Error: ${error.message}. Check console for details.`;
            }
        }

