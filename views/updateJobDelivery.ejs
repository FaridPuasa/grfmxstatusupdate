        // ---- Shared payload builder for both bulk submit and one-by-one scans ----
        // Reuses FormData over #deliveryForm so the exact same field names/values
        // that updateDelivery.ejs sends today (weight, price, area, warehouse,
        // dispatchers, ... whichever fields updateDeliveryFieldStatus() left
        // enabled for the current statusCode) are preserved unchanged; only
        // `statusCode` (now driven by the shared #actionCode select) is injected
        // manually since that select lives outside #deliveryForm.
        function buildDeliveryPayload(overrideConsignmentIDs) {
            const formData = new FormData(document.getElementById('deliveryForm'));
            const payload = Object.fromEntries(formData.entries());
            payload.statusCode = document.getElementById('actionCode').value;
            if (typeof overrideConsignmentIDs === 'string') {
                payload.consignmentIDs = overrideConsignmentIDs;
            }
            return payload;
        }

        // Polls /updateDelivery/status/:jobId (unchanged endpoint) until the job
        // completes or fails, updating the shared #loading progress bar the same
        // way updateDelivery.ejs's own pollJobStatus() used to.
        function pollDeliveryJobStatus(jobId) {
            return new Promise((resolve) => {
                const timer = setInterval(async () => {
                    try {
                        const res = await fetch(`/updateDelivery/status/${jobId}`);
                        if (!res.ok) throw new Error(`HTTP ${res.status}`);
                        const job = await res.json();

                        const total = job.total || 0;
                        const processed = job.processed || 0;
                        const pct = total > 0 ? Math.round((processed / total) * 100) : 0;
                        const progressBarEl = document.getElementById('progressBar');
                        const loadingMessageEl = document.getElementById('loadingMessage');
                        if (progressBarEl) {
                            progressBarEl.style.width = pct + '%';
                            progressBarEl.textContent = pct + '%';
                        }
                        if (loadingMessageEl) loadingMessageEl.textContent = `Processing ${processed} of ${total}...`;

                        if (job.status === 'completed' || job.status === 'failed') {
                            clearInterval(timer);
                            resolve(job);
                        }
                    } catch (error) {
                        console.error('Error polling delivery job status:', error);
                    }
                }, 2000);
            });
        }

        // The /updateDelivery status endpoint only ever returns a flat message
        // string per tracking number (processingResults[i].status), not a
        // structured success/failure code, so bucketing here is a front-end-only
        // heuristic as called out in the plan.
        function classifyDeliveryResult(status) {
            return /error|fail|not found|invalid/i.test(status || '') ? 'failed' : 'updated';
        }

        // Renders bulk (or FGA / UCDR-via-bulk) delivery results using the same
        // card+table visual language as job's displayBulkResults(), since
        // /updateDelivery has no delayed/duplicate categories to show.
        function displayDeliveryResults(processingResults) {
            const results = processingResults || [];
            const updated = results.filter(r => classifyDeliveryResult(r.status) === 'updated');
            const failed = results.filter(r => classifyDeliveryResult(r.status) === 'failed');

            const deliveryResultsEl = document.getElementById('deliveryResults');
            deliveryResultsEl.style.display = 'block';
            document.getElementById('dlvUpdatedCount').textContent = updated.length;
            document.getElementById('dlvFailedCount').textContent = failed.length;
            document.getElementById('dlvTotalCount').textContent = results.length;

            const container = document.getElementById('dlvResultsContainer');
            container.innerHTML = '';

            if (updated.length > 0) {
                const successTable = document.createElement('div');
                successTable.innerHTML = `
            <h4 class="text-success mt-4">Successfully Processed Jobs (${updated.length}) <span class="badge bg-success">Success</span></h4>
            <div class="table-responsive">
                <table class="table table-success table-striped">
                    <thead>
                        <tr>
                            <th>Tracking Number</th>
                            <th>Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${updated.map(r => `
                            <tr>
                                <td>${escapeHtml(r.consignmentID || 'N/A')}</td>
                                <td>${escapeHtml(r.status || 'Updated')}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            </div>
        `;
                container.appendChild(successTable);
                enhanceResultsTable(successTable.querySelector('table'));
            }

            if (failed.length > 0) {
                const failedTable = document.createElement('div');
                failedTable.innerHTML = `
            <h4 class="text-danger mt-4">Failed Jobs (${failed.length}) <span class="badge bg-danger">Failed</span></h4>
            <div class="table-responsive">
                <table class="table table-danger table-striped">
                    <thead>
                        <tr>
                            <th>Tracking Number</th>
                            <th>Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${failed.map(r => `
                            <tr>
                                <td>${escapeHtml(r.consignmentID || 'N/A')}</td>
                                <td>${escapeHtml(r.status || 'Failed')}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            </div>
        `;
                container.appendChild(failedTable);
                enhanceResultsTable(failedTable.querySelector('table'));
            }

            if (results.length === 0) {
                const noResults = document.createElement('div');
                noResults.className = 'alert alert-info';
                noResults.innerHTML = '<strong>No results to display.</strong>';
                container.appendChild(noResults);
            }

            setTimeout(() => {
                deliveryResultsEl.scrollIntoView({ behavior: 'smooth' });
            }, 100);
        }

        // Renders the accumulating delivery one-by-one scan results, mirroring
        // job's updateScanResultsDisplay()/#scanResults pattern, self-contained
        // inside #dlvScanResults.
        function updateDeliveryScanResultsDisplay() {
            const scanResultsDiv = document.getElementById('dlvScanResults');
            if (!scanResultsDiv) return;

            let html = `
        <h3>Scanning Results</h3>
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card text-white bg-success">
                    <div class="card-body text-center">
                        <h5 class="card-title">Updated</h5>
                        <p class="card-text display-4">${dlvScanResults.updatedCount}</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-danger">
                    <div class="card-body text-center">
                        <h5 class="card-title">Failed</h5>
                        <p class="card-text display-4">${dlvScanResults.notUpdatedCount}</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-secondary">
                    <div class="card-body text-center">
                        <h5 class="card-title">Total</h5>
                        <p class="card-text display-4">${dlvScanResults.updatedCount + dlvScanResults.notUpdatedCount}</p>
                    </div>
                </div>
            </div>
        </div>
    `;

            const allResults = [...dlvScanResults.successful, ...dlvScanResults.failed];
            const latest = allResults[allResults.length - 1];
            if (latest) {
                const isSuccess = dlvScanResults.successful.includes(latest);
                html += `
            <div class="alert ${isSuccess ? 'alert-success' : 'alert-danger'} alert-dismissible fade show">
                <strong>${isSuccess ? '✅ Success' : '❌ Failed'}:</strong>
                ${escapeHtml(latest.consignmentID || 'N/A')} - ${escapeHtml(latest.status || 'No result message')}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        `;
            }

            if (dlvScanResults.successful.length > 0) {
                const recent = dlvScanResults.successful.slice(-10).reverse();
                html += `
            <h4 class="text-success">Recently Updated <span class="badge bg-success">Success</span></h4>
            <div class="table-responsive mb-3">
                <table class="table table-success table-striped table-sm">
                    <thead>
                        <tr>
                            <th>Tracking Number</th>
                            <th>Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${recent.map(r => `
                            <tr>
                                <td><small>${escapeHtml(r.consignmentID || 'N/A')}</small></td>
                                <td><small>${escapeHtml(r.status || 'Updated')}</small></td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            </div>
        `;
            }

            if (dlvScanResults.failed.length > 0) {
                const recent = dlvScanResults.failed.slice(-10).reverse();
                html += `
            <h4 class="text-danger">Recent Failures <span class="badge bg-danger">Failed</span></h4>
            <div class="table-responsive">
                <table class="table table-danger table-striped table-sm">
                    <thead>
                        <tr>
                            <th>Tracking Number</th>
                            <th>Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${recent.map(r => `
                            <tr>
                                <td><small>${escapeHtml(r.consignmentID || 'N/A')}</small></td>
                                <td><small>${escapeHtml(r.status || 'Failed')}</small></td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            </div>
        `;
            }

            scanResultsDiv.innerHTML = html;
            scanResultsDiv.style.display = 'block';
        }

        // Mirrors job's switchToActiveUpdateMode(), but for the delivery flow's
        // own results/scan containers.
        function switchToDeliveryActiveMode(method) {
            document.getElementById('initialSection').style.display = 'none';
            document.getElementById('activeUpdateSection').style.display = 'block';
            document.getElementById('activeUpdateTitle').textContent = getDeliveryActionTitle();

            document.getElementById('delayedJobsInfo').style.display = 'none';
            document.getElementById('bulkResults').style.display = 'none';
            document.getElementById('oneByOneInterface').style.display = 'none';
            document.getElementById('deliveryResults').style.display = 'none';
            document.getElementById('dlvOneByOneInterface').style.display = 'none';
            document.getElementById('loading').style.display = 'none';

            if (method === 'onebyone') {
                document.getElementById('dlvOneByOneInterface').style.display = 'block';
                setTimeout(() => {
                    document.getElementById('dlvTrackingNumSingle').focus();
                }, 300);
            }
        }

        // ---- Bulk submit (also used by FGA and by UCDR's Submit button) ----
        document.getElementById('deliveryForm').addEventListener('submit', async function (event) {
            event.preventDefault();

            const statusCode = document.getElementById('actionCode').value;
            const dangerAction = DLV_DANGER_ZONE_ACTIONS[statusCode];
            if (dangerAction) {
                const trackingNumbers = document.getElementById('dlvConsignmentID').value
                    .split('\n')
                    .map(v => v.trim())
                    .filter(Boolean);
                const preview = trackingNumbers.slice(0, 15).join(', ') +
                    (trackingNumbers.length > 15 ? `, ... (+${trackingNumbers.length - 15} more)` : '');
                const confirmed = await showConfirm(
                    `You are about to ${dangerAction} ${trackingNumbers.length} job(s):\n\n${preview}\n\n` +
                    `This action cannot be undone. Continue?`,
                    { title: 'Please Confirm', okText: 'Continue', okClass: 'btn-danger' }
                );
                if (!confirmed) return;
            }

            switchToDeliveryActiveMode('bulk');

            document.getElementById('loading').innerHTML = `
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2" id="loadingMessage">Starting processing...</p>
        <div class="progress mt-3" style="height: 25px;">
            <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated"
                 role="progressbar" style="width: 0%; font-weight: bold;">0%</div>
        </div>
    `;
            document.getElementById('loading').style.display = 'block';

            try {
                const payload = buildDeliveryPayload();

                const res = await fetch('/updateDelivery', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!res.ok) {
                    const errBody = await res.json().catch(() => ({}));
                    throw new Error(errBody.error || `HTTP ${res.status}`);
                }

                const result = await res.json();
                if (!result.jobId) throw new Error('No job ID received from server');

                const loadingMessageEl = document.getElementById('loadingMessage');
                if (loadingMessageEl) loadingMessageEl.textContent = `Processing 0 of ${result.total}...`;

                const job = await pollDeliveryJobStatus(result.jobId);

                document.getElementById('loading').style.display = 'none';
                displayDeliveryResults(job.processingResults);

                if (job.status === 'failed') {
                    showToast('Update job failed: ' + (job.error || 'Unknown error'), 'error');
                }
            } catch (error) {
                console.error('Error submitting delivery update:', error);
                document.getElementById('loading').style.display = 'none';
                showToast('Error starting update job: ' + error.message, 'error');
            }
        });

        // ---- One-by-one scanning (new capability for the delivery flow) ----
        document.getElementById('dlvReadyToScan').addEventListener('click', function () {
            const form = document.getElementById('deliveryForm');
            if (!form.reportValidity()) return;
            switchToDeliveryActiveMode('onebyone');
        });

        document.getElementById('dlvTrackingNumSingle').addEventListener('change', async function () {
            const trackingNumber = this.value.trim();
            if (!trackingNumber) return;
            this.value = '';

            const statusCode = document.getElementById('actionCode').value;

            const dangerAction = DLV_DANGER_ZONE_ACTIONS[statusCode];
            if (dangerAction) {
                const confirmed = await showConfirm(
                    `You are about to ${dangerAction} job ${trackingNumber}.\n\nThis action cannot be undone. Continue?`,
                    { title: 'Please Confirm', okText: 'Continue', okClass: 'btn-danger' }
                );
                if (!confirmed) {
                    this.focus();
                    return;
                }
            }

            this.disabled = true;
            const loadingDiv = document.getElementById('loading');
            loadingDiv.style.display = 'block';
            loadingDiv.innerHTML = `
        <div class="spinner-border spinner-border-sm text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <span class="ms-2">Updating...</span>
    `;

            try {
                const payload = buildDeliveryPayload(trackingNumber);

                const res = await fetch('/updateDelivery', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!res.ok) {
                    const errBody = await res.json().catch(() => ({}));
                    throw new Error(errBody.error || `HTTP ${res.status}`);
                }

                const result = await res.json();
                if (!result.jobId) throw new Error('No job ID received from server');

                const job = await pollDeliveryJobStatus(result.jobId);
                const r = (job.processingResults && job.processingResults[0]) ||
                    { consignmentID: trackingNumber, status: job.error || 'No result returned' };

                if (classifyDeliveryResult(r.status) === 'failed') {
                    dlvScanResults.failed.push(r);
                    dlvScanResults.notUpdatedCount++;
                    flashError(this);
                } else {
                    dlvScanResults.successful.push(r);
                    dlvScanResults.updatedCount++;
                    flashSuccess(this);
                }
                updateDeliveryScanResultsDisplay();

            } catch (error) {
                console.error('Error:', error);
                dlvScanResults.failed.push({ consignmentID: trackingNumber, status: 'Error: ' + error.message });
                dlvScanResults.notUpdatedCount++;
                updateDeliveryScanResultsDisplay();
                flashError(this);
            } finally {
                loadingDiv.style.display = 'none';
                this.disabled = false;
                this.focus();
            }
        });

        // ---- Reset the job-side form/fields when a delivery (or blank) option is picked ----
        function resetJobFieldsForNonJobFlow() {
            document.getElementById('mawbFields').style.display = 'none';
            document.getElementById('updateMethod').closest('.mb-3').style.display = 'none';
            document.getElementById('warehouse').required = false;
            hideAllSections();
            hideExcelUploadButton();
            const iiwHoldWarning = document.getElementById('iiwHoldWarning');
            if (iiwHoldWarning) iiwHoldWarning.style.display = 'none';
        }

        // ---- Reset the delivery-side form/fields when a job (or blank) option is picked ----
        function resetDeliveryFieldsForNonDeliveryFlow() {
            document.getElementById('deliveryForm').style.display = 'none';
            hideAllDeliverySections();
        }

        // ---- "On Hold (GDEX)" and "Fail (MGLOBAL)" are consolidated into one
        //      dropdown entry each (to save space) that reveals a secondary
        //      Reason select. Picking a reason sets #actionCode's own value to
        //      the real underlying code (a hidden <option> already exists for
        //      each reason inside #actionCode), so every other place in this
        //      file that reads #actionCode's value - job submit handler,
        //      buildDeliveryPayload(), danger-zone lookups, etc. - keeps
        //      working unchanged and always sees the true code being submitted.
        const REASON_GROUPS = {
            gdexHold: {
                reasons: [
                    { value: 'H9', label: 'Reject By Airport' },
                    { value: 'H18', label: 'DG Shipment' },
                    { value: 'H19', label: 'Prohibited Shipment' },
                    { value: 'H27', label: 'Pending Custom Declaration' },
                    { value: 'H31', label: 'Shipment rejected/confiscated by customs' }
                ]
            },
            mglobalFail: {
                reasons: [
                    { value: 'FCC', label: 'Customer not available / cannot be contacted' },
                    { value: 'FIA', label: 'Incorrect Address' },
                    { value: 'FSC', label: 'Reschedule to self collect requested by customer' }
                ]
            }
        };

        function showReasonSelector(groupKey) {
            const group = REASON_GROUPS[groupKey];
            if (!group) return;
            const select = document.getElementById('reasonCode');
            select.innerHTML = '<option value="" selected>Please select a reason</option>' +
                group.reasons.map(r => `<option value="${r.value}">${r.label}</option>`).join('');
            document.getElementById('reasonCodeWrapper').style.display = 'block';
        }

        function hideReasonSelector() {
            document.getElementById('reasonCodeWrapper').style.display = 'none';
            document.getElementById('reasonCode').innerHTML = '<option value="" selected>Please select a reason</option>';
        }

        // ---- The single dispatcher that replaces both files' own
        //      #updateCode / #statusCode change listeners ----
        async function dispatchAction() {
            const actionSelect = document.getElementById('actionCode');
            const selectedOption = actionSelect.selectedOptions[0];
            const reasonTarget = selectedOption ? selectedOption.dataset.reasonTarget : '';

            if (reasonTarget) {
                // A reason group header was picked - wait for an actual reason
                // before doing anything else (no concrete code chosen yet).
                showReasonSelector(reasonTarget);
                resetJobFieldsForNonJobFlow();
                resetDeliveryFieldsForNonDeliveryFlow();
                return;
            }
            hideReasonSelector();

            const flow = selectedOption ? selectedOption.dataset.flow : '';
            const mode = selectedOption ? selectedOption.dataset.mode : '';

            if (flow !== 'job') {
                resetJobFieldsForNonJobFlow();
            }
            if (flow !== 'delivery') {
                resetDeliveryFieldsForNonDeliveryFlow();
            }

            if (flow === 'job') {
                await handleJobActionChange(actionSelect.value);
            } else if (flow === 'delivery') {
                document.getElementById('deliveryForm').style.display = 'block';
                updateDeliveryFieldStatus();
                applyDeliveryModeUI(actionSelect.value, mode);
            }
        }

        document.getElementById('actionCode').addEventListener('change', dispatchAction);

        document.getElementById('reasonCode').addEventListener('change', async function () {
            if (!this.value) return;
            // The chosen reason IS one of #actionCode's own (hidden) options.
            document.getElementById('actionCode').value = this.value;
            await dispatchAction();
        });

    </script>
    <script>
        let inputElement1 = document.getElementById('dlvPhoneNum');
        var patternMask = IMask(inputElement1, {
            mask: '{673}0000000',
        });

        let inputElement2 = document.getElementById('dlvPostalCode');
        var patternMask = IMask(inputElement2, {
            mask: '{aa}0000',
            prepare: function (value, masked) {
                if (value.length <= 2) {
                    return value.toUpperCase();
                }
                return value;
            },
        });

        let inputElement3 = document.getElementById('dlvAwbNum');
        var patternMask = IMask(inputElement3, {
            mask: '000{-}00000000',
        });
    </script>
</body>

</html>
