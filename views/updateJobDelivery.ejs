        document.getElementById('trackingNumSingle').addEventListener('change', async function () {
            const trackingNumber = this.value.trim();
            if (!trackingNumber) return;

            this.value = '';

            const updateCode = document.getElementById('actionCode').value;

            if (updateCode === 'SBR') {
                const mawbSelect = document.getElementById('mawbNum');
                const mawbNum = mawbSelect ? mawbSelect.value.trim() : '';

                if (!mawbNum) {
                    showToast('Please select a MAWB Number first', 'warning');
                    this.focus();
                    return;
                }

                // Check for duplicate
                const duplicateCheck = trackDuplicate(trackingNumber, updateCode, 'onebyone');
                if (duplicateCheck.isDuplicate && duplicateCheck.count > 1) {
                    showScanAlert(`⚠️ Duplicate manifest seal: ${trackingNumber} (skipped)`, 'info');
                    // Update duplicate count in the summary cards
                    scanResults.duplicateCount = (scanResults.duplicateCount || 0) + 1;
                    updateBulkStyleResults(); // NEW: Update the summary cards
                    this.focus();
                    return;
                }

                showSingleLoading(true);

                try {
                    const response = await fetch('/updateJob/scanManifestSeal', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            mawbNum: mawbNum,
                            manifestSeals: [trackingNumber],
                            updateMethod: 'onebyone'
                        })
                    });

                    const result = await response.json();

                    if (result.successful && result.successful.length > 0) {
                        scanResults.successful.push({
                            trackingNumber: trackingNumber,
                            result: result.successful[0].message || `Manifest seal scanned successfully for MAWB ${mawbNum}`
                        });
                        scanResults.updatedCount++;
                        flashSuccess(this);
                    } else if (result.duplicate && result.duplicate.length > 0) {
                        scanResults.duplicateCount = (scanResults.duplicateCount || 0) + 1;
                        showScanAlert(`⚠️ Duplicate manifest seal: ${trackingNumber} (already scanned)`, 'info');
                        flashWarning(this);
                    } else {
                        const failMessage = (result.failed && result.failed[0] && result.failed[0].message) || result.message || 'Failed to scan manifest seal';
                        scanResults.failed.push({
                            trackingNumber: trackingNumber,
                            result: failMessage
                        });
                        scanResults.notUpdatedCount++;
                        flashError(this);
                    }

                    // NEW: Update the bulk-style summary cards
                    updateBulkStyleResults();
                    updateScanResultsDisplay();

                } catch (error) {
                    console.error('Error:', error);
                    scanResults.failed.push({
                        trackingNumber: trackingNumber,
                        result: 'Error: ' + error.message
                    });
                    scanResults.notUpdatedCount++;
                    updateBulkStyleResults();
                    updateScanResultsDisplay();
                    flashError(this);
                } finally {
                    showSingleLoading(false);
                    this.focus();
                }

                return;
            }

            const warehouse = document.getElementById('warehouse') ? document.getElementById('warehouse').value : '';

            // GET MAWB VALUE FROM PRESERVED STORAGE
            let mawbNum = '';
            const hiddenMAWB = document.getElementById('hiddenMAWB');
            if (hiddenMAWB && hiddenMAWB.value) {
                mawbNum = hiddenMAWB.value.trim();
            } else {
                // Fallback to the select element
                const mawbSelect = document.getElementById('mawbNum');
                mawbNum = mawbSelect ? mawbSelect.value.trim() : '';
            }

            console.log('🔍 Using MAWB value:', mawbNum);

            // Clear the input field
            this.value = '';

            // Check for duplicate
            const duplicateCheck = trackDuplicate(trackingNumber, updateCode, 'onebyone');
            if (duplicateCheck.isDuplicate && duplicateCheck.count > 1) {
                console.log(`⏭️ Duplicate one-by-one: ${trackingNumber}`);
                scanResults.duplicateCount = (scanResults.duplicateCount || 0) + 1;
                updateScanResultsDisplayWithDuplicate(trackingNumber, duplicateCheck.count);

                this.focus();
                return;
            }

            // NOTE: IIW MAWB/already-scanned validation used to be a separate
            // /updateJob/checkTrackingForMAWB round trip before the /updateJob call below.
            // /updateJob already runs the same checks server-side (MAWB_MISMATCH,
            // ALREADY_SCANNED codes), so the stats update now happens after that single
            // call instead (see below) to avoid doing the check twice per scan.

            // Validation for different update codes
            if (updateCode === 'UAN' && !mawbNum) {
                showToast('Please enter MAWB Number', 'warning');
                this.focus();
                return;
            }

            if (updateCode === 'IIW' && !warehouse) {
                showToast('Please select a warehouse location', 'warning');
                this.focus();
                return;
            }

            // FOQJ validation - only need warehouse
            if (updateCode === 'FOQJ' && !warehouse) {
                showToast('Please select a warehouse location', 'warning');
                this.focus();
                return;
            }

            showSingleLoading(true);

            try {
                console.log('Sending one-by-one update request...');
                console.log('📤 Sending with MAWB:', mawbNum);

                const requestBody = {
                    updateCode: updateCode,
                    trackingNumbers: [trackingNumber],
                    updateMethod: 'onebyone'
                };

                // Add MAWB number for UAN updates
                if (updateCode === 'UAN' && mawbNum) {
                    requestBody.mawbNum = mawbNum;
                }

                // Add warehouse for IIW updates
                if (updateCode === 'IIW' && warehouse) {
                    requestBody.warehouse = warehouse;
                    // Also add mawbNum for IIW if provided
                    if (mawbNum !== '') {
                        requestBody.mawbNum = mawbNum;
                    }
                }

                console.log('📤 Request body:', JSON.stringify(requestBody, null, 2));

                const response = await fetch('/updateJob', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(requestBody)
                });

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const result = await response.json();
                console.log('One-by-one result:', result);

                // FIX: Check if result is defined before accessing properties
                if (!result) {
                    throw new Error('No result returned from server');
                }

                // Update MAWB scanning stats/alerts for IIW based on the update result
                // (previously derived from the separate checkTrackingForMAWB pre-check)
                if (updateCode === 'IIW' && window.mawbScanningStats) {
                    if (result.successful && result.successful.length > 0) {
                        window.mawbScanningStats.newlyScanned++;
                    } else {
                        const failCode = result.failed && result.failed[0] ? result.failed[0].code : null;
                        if (failCode === 'MAWB_MISMATCH' || failCode === 'INVALID_MAWB') {
                            window.mawbScanningStats.invalid++;
                            showScanAlert(`❌ ${trackingNumber} is not part of MAWB ${mawbNum} group`, 'danger');
                        } else if (failCode === 'ALREADY_SCANNED') {
                            window.mawbScanningStats.skipped++;
                            showScanAlert(`⚠️ ${trackingNumber} already scanned`, 'warning');
                        }
                    }
                    updateMAWBOneByOneStatsDisplay();
                }

                // Handle the result properly with safe checks
                if (result.successful && result.successful.length > 0) {
                    scanResults.successful.push(...result.successful);
                    scanResults.updatedCount += result.updatedCount || 0;
                    flashSuccess(this);
                }
                if (result.failed && result.failed.length > 0) {
                    scanResults.failed.push(...result.failed);
                    scanResults.notUpdatedCount += result.failedCount || result.failed.length || 0;
                }
                if (result.delayed && result.delayed.length > 0) {
                    scanResults.delayed.push(...result.delayed);
                    scanResults.delayedCount += result.delayedCount || result.delayed.length || 0;
                }
                if (result.duplicate && result.duplicate.length > 0) {
                    scanResults.duplicateCount = (scanResults.duplicateCount || 0) + (result.duplicateCount || 0);
                }

                updateScanResultsDisplay();

            } catch (error) {
                console.error('Error:', error);
                // Add to failed results
                scanResults.failed.push({
                    trackingNumber: trackingNumber,
                    result: 'Error: ' + error.message
                });
                scanResults.notUpdatedCount++;
                updateScanResultsDisplay();
            } finally {
                showSingleLoading(false);
                this.focus();
                return;
            }
        });

