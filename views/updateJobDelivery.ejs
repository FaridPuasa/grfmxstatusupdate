        // Job Price (UP) isn't in this map - its Current Payment Method/Price
        // + new-payment-method-then-conditionally-priced flow is special-cased
        // below since it drives two existing fields, not one.
        const SINGLE_CHECK_CONFIGS = {
            UGR: { field: 'grRemark', targetInput: 'dlvGrRemark', targetWrapper: 'dlvGrRemarkWrapper', currentLabel: 'Current Go Rush Remark', editable: true },
            UAS: { field: 'receiverAddress', targetInput: 'dlvAddress', targetWrapper: 'dlvAddressWrapper', currentLabel: 'Current Address', editable: true },
            UPN: { field: 'receiverPhoneNumber', targetInput: 'dlvPhoneNum', targetWrapper: 'dlvPhoneNumWrapper', currentLabel: 'Current Phone Number', editable: true },
            URN: { field: 'receiverName', targetInput: 'dlvName', targetWrapper: 'dlvNameWrapper', currentLabel: 'Current Name', editable: true },
            UPC: { field: 'receiverPostalCode', targetInput: 'dlvPostalCode', targetWrapper: 'dlvPostalCodeWrapper', currentLabel: 'Current Postal Code', editable: true },
            UW: { field: 'parcelWeight', targetInput: 'dlvWeight', targetWrapper: 'dlvWeightWrapper', currentLabel: 'Current Weight', editable: true },
            UJM: { field: 'jobMethod', targetInput: 'dlvJobMethod', targetWrapper: 'dlvJobMethodWrapper', currentLabel: 'Current Job Method', editable: false },
            UAR: { field: 'area', targetInput: 'dlvArea', targetWrapper: 'dlvAreaWrapper', currentLabel: 'Current Area', editable: false }
        };

        // Re-hides whichever target field(s) belong to the active check-single
        // action - called both when first entering that mode and whenever the
        // tracking number is edited (invalidating a previous check).
        function hideCheckSingleTargetFields(statusCode) {
            if (statusCode === 'UP') {
                $('#dlvPaymentMethodWrapper').hide();
                $('#dlvPriceWrapper').hide();
                const paymentMethodField = document.getElementById('dlvPaymentMethod');
                const priceField = document.getElementById('dlvPrice');
