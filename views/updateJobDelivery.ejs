                } catch (error) {
                    console.error('Error checking tracking number:', error);
                    ucdrCheckStatusDiv.textContent = 'Error checking tracking number. Please try again.';
                    ucdrCheckStatusDiv.className = 'mt-2 text-danger';
                } finally {
                    ucdrCheckButton.disabled = false;
