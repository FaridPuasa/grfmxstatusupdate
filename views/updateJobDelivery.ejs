        // ---- "Check current value first" - bulk-table style (Swap
        //      Dispatchers / Warehouse Location). Check is informational only:
        //      Submit still posts every tracking number in the textarea
        //      exactly as buildDeliveryPayload() always has, regardless of
        //      which rows the check table found. ----
        const BULK_CHECK_CONFIGS = {
            SD: { field: 'assignedTo', label: 'Current Dispatcher/Freelancer', newValueInput: 'dlvDispatchers', newValueLabel: 'New Dispatcher/Freelancer' },
            UWL: { field: 'latestLocation', label: 'Current Warehouse Location', newValueInput: 'dlvWarehouse', newValueLabel: 'New Warehouse Location' },
