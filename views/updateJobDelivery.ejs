            }
            const config = SINGLE_CHECK_CONFIGS[statusCode];
            if (!config) return;
            $('#' + config.targetWrapper).hide();
            const targetField = document.getElementById(config.targetInput);
            targetField.value = '';
            targetField.disabled = true;
            targetField.required = false;
