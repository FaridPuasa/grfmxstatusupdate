                const selectedOption = newValueField.selectedOptions[0];
                return (selectedOption && selectedOption.value) ? selectedOption.textContent : '—';
            }
            return newValueField.value.trim() || '—';
        }

        // Keeps the check table's "New Value" column in sync with whatever is
