<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Status &amp; Details</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <script src="https://unpkg.com/imask"></script>
    <style>
        .loading {
            display: none;
            text-align: center;
            padding: 20px;
        }

        .spinner-border {
            width: 3rem;
            height: 3rem;
        }

        .result-section {
            display: none;
            margin-top: 20px;
        }

        .table-responsive {
            margin-bottom: 30px;
        }

        .scan-section {
            display: none;
        }

        .scan-active {
            background-color: #e8f5e8;
            border: 2px solid #28a745;
            border-radius: 5px;
            padding: 15px;
        }

        #trackingNumSingle:focus {
            border-color: #28a745;
            box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.25);
        }

        .scan-success-flash {
            background-color: #d4edda !important;
            transition: background-color 0.1s ease;
        }
    </style>
</head>

<body>
    <%- include('partials/navbar') %>
    <div class="container mt-4">
        <!-- Initial Header and Form Section -->
        <div id="initialSection">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Update Status &amp; Details</h5>
                </div>
            </div>

                <%
                    // Small helper so each group/option below can be gated by role
                    // and/or specific email in one line, matching the pattern
                    // already used elsewhere in partials/navbar.ejs.
                    function canAccess(roles, emails) {
                        emails = emails || [];
                        return roles.includes(user.role) || emails.includes(user.email);
                    }
                %>
                <div class="mb-3">
                    <label for="actionCode" class="form-label">Action to Update:</label>
                    <select id="actionCode" name="actionCode" class="form-select" required>
                        <option value="" selected>Please select an action</option>

                        <% if (canAccess(['admin'], ['operation2@globex.com.bn', 'operation3@globex.com.bn', 'warehouse@globex.com.bn'])) { %>
                        <optgroup label="🛃 Customs Clearing (EWE/MGLOBAL/PDU/GDEX)">
                            <% if (canAccess(['admin'], ['operation2@globex.com.bn', 'operation3@globex.com.bn'])) { %>
                            <option value="UAN" data-flow="job">MAWB No. / Postal Code / Weight</option>
                            <% } %>
                            <% if (canAccess(['admin'], ['operation2@globex.com.bn', 'operation3@globex.com.bn', 'warehouse@globex.com.bn'])) { %>
                            <option value="CCH" data-flow="job">On Hold (EWE/MGLOBAL/PDU)</option>
                            <option value="__GDEX_HOLD__" data-flow="job" data-reason-target="gdexHold">On Hold (GDEX)</option>
                            <% } %>
                        </optgroup>
                        <% } %>

                        <% if (canAccess(['admin', 'cs', 'warehouse'], ['operation2@globex.com.bn', 'warehouse@globex.com.bn'])) { %>
                        <optgroup label="📥 Item In">
                            <% if (canAccess(['admin', 'warehouse'], ['operation2@globex.com.bn', 'warehouse@globex.com.bn'])) { %>
                            <option value="SBR" data-flow="job">Scan Manifest Seal Tag (GDEX)</option>
                            <% } %>
                            <option value="IIW" data-flow="job">Scan In Warehouse</option>
                        </optgroup>
                        <% } %>

                        <% if (canAccess(['admin', 'cs', 'warehouse'], ['operation2@globex.com.bn', 'warehouse@globex.com.bn'])) { %>
                        <optgroup label="📤 Item Out">
                            <option value="35" data-flow="delivery">Out for Delivery</option>
                            <option value="CSSC" data-flow="delivery">Self Collect</option>
                        </optgroup>
                        <% } %>

                        <% if (canAccess(['admin', 'cs', 'warehouse'], ['operation2@globex.com.bn', 'warehouse@globex.com.bn'])) { %>
                        <optgroup label="✅ Failed/Completed">
                            <% if (canAccess(['admin', 'cs'], ['operation2@globex.com.bn'])) { %>
                            <option value="__MGLOBAL_FAIL__" data-flow="delivery" data-reason-target="mglobalFail">Fail (MGLOBAL)</option>
                            <% } %>
                            <option value="SFJ" data-flow="delivery">Clear Job</option>
                        </optgroup>
                        <% } %>

                        <% if (canAccess(['admin', 'cs', 'warehouse'], ['operation2@globex.com.bn', 'operation3@globex.com.bn', 'warehouse@globex.com.bn'])) { %>
                        <optgroup label="✏️ Update Details">
                            <option value="SD" data-flow="delivery" data-mode="check-bulk">Swap Dispatchers</option>
                            <option value="UWL" data-flow="delivery" data-mode="check-bulk">Warehouse Location</option>
                            <option value="UCDR" data-flow="delivery">Customer/Instructions Remark</option>
                            <option value="UGR" data-flow="delivery" data-mode="check-single">Go Rush Remark</option>
                            <% if (canAccess(['admin', 'cs'], ['operation2@globex.com.bn', 'operation3@globex.com.bn', 'warehouse@globex.com.bn'])) { %>
                            <option value="UJM" data-flow="delivery" data-mode="check-single">Job Method</option>
                            <option value="UP" data-flow="delivery" data-mode="check-single">Job Price</option>
                            <option value="UAS" data-flow="delivery" data-mode="check-single">Customer Address</option>
                            <option value="UAR" data-flow="delivery" data-mode="check-single">Customer Address Area</option>
                            <option value="UPN" data-flow="delivery" data-mode="check-single">Customer Phone Number</option>
                            <option value="URN" data-flow="delivery" data-mode="check-single">Customer Name</option>
                            <option value="UPC" data-flow="delivery" data-mode="check-single">Customer Postal Code</option>
                            <% } %>
                            <% if (canAccess(['admin', 'cs'], ['operation2@globex.com.bn', 'operation3@globex.com.bn'])) { %>
                            <option value="UW" data-flow="delivery" data-mode="check-single">Weight (CBSL)</option>
                            <option value="UWP" data-flow="job">Weight/Postal Code (EWE/MGLOBAL/PDU/GDEX)</option>
                            <option value="UAB" data-flow="delivery" data-mode="check-bulk">MAWB No.</option>
                            <% } %>
                        </optgroup>
                        <% } %>

                        <% if (canAccess(['admin'], ['operation2@globex.com.bn'])) { %>
                        <optgroup label="↩️ Return">
                            <option value="RSAL2" data-flow="delivery">Return to Shipper (GDEX)</option>
                        </optgroup>
                        <% } %>

                        <% if (canAccess(['admin', 'cs'], ['operation2@globex.com.bn', 'operation3@globex.com.bn', 'warehouse@globex.com.bn'])) { %>
                        <optgroup label="⚠️ Danger Zone">
                            <option value="CD" data-flow="delivery">Cancel Job</option>
                            <option value="AJ" data-flow="delivery">Reactivate Cancelled Job</option>
                            <option value="47" data-flow="delivery">Dispose Job</option>
                        </optgroup>
                        <% } %>

                        <% if (canAccess(['admin'], ['operation2@globex.com.bn'])) { %>
                        <optgroup label="🛠️ Fix">
                            <% if (['admin'].includes(user.role)) { %>
                            <option value="FOQJ" data-flow="job">Queued / Delayed Jobs After Scan In Warehouse (EWE/MGLOBAL/PDU)</option>
                            <% } %>
                            <option value="FSJ" data-flow="delivery">Stuck Failed &amp; Completed Jobs / Hidden Jobs on Agent App</option>
                            <option value="RGP" data-flow="delivery">Resend POD (GDEX) - make sure job is Completed on Detrack first</option>
                            <% if (['admin'].includes(user.role)) { %>
                            <option value="FGA" data-flow="delivery" data-mode="bulk-only">Job Flow Reupdate (GDEX)</option>
                            <% } %>
                        </optgroup>
                        <% } %>

                        <!-- Hidden reason options - never shown directly; picked via the
                             Reason selector below when "On Hold (GDEX)" / "Fail (MGLOBAL)"
                             is chosen above. Kept as real <option>s of #actionCode so that
                             every existing piece of logic reading #actionCode's value
                             (job submit handler, buildDeliveryPayload(), etc.) still works
                             unchanged once a reason is picked. -->
                        <optgroup label="(reasons)" style="display: none;">
                            <option value="H9" data-flow="job">On Hold (GDEX) - Reject By Airport</option>
                            <option value="H18" data-flow="job">On Hold (GDEX) - DG Shipment</option>
                            <option value="H19" data-flow="job">On Hold (GDEX) - Prohibited Shipment</option>
                            <option value="H27" data-flow="job">On Hold (GDEX) - Pending Custom Declaration</option>
                            <option value="H31" data-flow="job">On Hold (GDEX) - Shipment rejected/confiscated by customs</option>
                            <option value="FCC" data-flow="delivery">Fail (MGLOBAL) - Customer not available / cannot be contacted</option>
                            <option value="FIA" data-flow="delivery">Fail (MGLOBAL) - Incorrect Address</option>
                            <option value="FSC" data-flow="delivery">Fail (MGLOBAL) - Reschedule to self collect requested by customer</option>
                        </optgroup>
                    </select>
                </div>

                <div class="mb-3" id="reasonCodeWrapper" style="display: none;">
                    <label for="reasonCode" class="form-label">Reason:</label>
                    <select id="reasonCode" class="form-select">
                        <option value="" selected>Please select a reason</option>
                    </select>
                </div>

                <div class="alert alert-warning" id="iiwHoldWarning" style="display: none;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Items that are actually on hold should be updated via <strong>Customs Clearing (EWE/MGLOBAL/PDU/GDEX)</strong> first.
                    Once released, come back here to scan them in warehouse.
                </div>

            <form id="updateJobForm">
<div id="mawbFields" style="display: none;">
                    <!-- MAWB Number Field -->
                    <div id="mawbNumContainer">
                        <div class="mb-3">
                            <label for="mawbNum" class="form-label">MAWB No:
                                <span id="mawbRequired" class="text-danger">*</span>
                                <span id="mawbOptional" class="text-muted" style="display:none;"> (Optional)</span>
                            </label>
                            <select id="mawbNum" name="mawbNum" class="form-select" style="display: none;">
                                <option value="" selected>Please select MAWB Number (optional)</option>
                                <!-- Options will be populated dynamically -->
                            </select>
                            <input type="text" id="mawbNumInput" name="mawbNumInput" class="form-control"
                                style="display: none;">
                            <div class="form-text" id="mawbHelp">Select MAWB number for bulk scanning or leave empty for
                                individual updates</div>
                            <div id="mawbStats" class="mt-2" style="display: none;">
                                <small class="text-muted" id="mawbStatsText"></small>
                            </div>
                        </div>
                    </div>

                    <!-- Warehouse Field -->
                    <div id="warehouseFields" style="display: none;">
                        <div class="mb-3">
                            <label for="warehouse" class="form-label">Warehouse:</label>
                            <select id="warehouse" name="warehouse" class="form-select" required>
                                <option value="" selected>Please select warehouse location</option>
                                <option value="Warehouse K1">Warehouse K1</option>
                                <option value="Warehouse K2">Warehouse K2</option>
                            </select>
                            <div class="warehouse-notes">
                                <small>K1 &gt; Go Rush Kiulap</small><br>
                                <small>K2 &gt; Jangsak Warehouse</small><br>
                                <strong><small>*If no failed job, pick K1</small></strong>
                            </div>
                        </div>
                    </div>

                    <!-- Update Method -->
                    <div class="mb-3">
                        <label for="updateMethod" class="form-label">Update Method:</label>
                        <select id="updateMethod" name="updateMethod" class="form-select" required>
                            <option value="" selected>Please select method</option>
                            <option value="bulk">1. Bulk</option>
                            <option value="onebyone">2. One by one</option>
                        </select>
                    </div>

                    <!-- Bulk Section -->
                    <div id="bulkSection" class="update-section" style="display: none;">
                        <div class="mb-3">
                            <label for="trackingNumBulk" id="trackingNumBulkLabel" class="form-label">Tracking Number(s):</label>
                            <textarea id="trackingNumBulk" name="trackingNumBulk" class="form-control" rows="2"
                                placeholder="Enter one tracking number per line"></textarea>
                        </div>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                            <button type="submit" id="submitButton" class="btn btn-primary me-md-2">Submit</button>
                        </div>
                    </div>

                    <!-- One by One Section -->
                    <div id="oneByOneSection" class="update-section scan-section" style="display: none;">
                        <div class="mb-3 text-center">
                            <button type="button" id="readyToScan" class="btn btn-success btn-lg">Ready to Scan</button>
                        </div>
                    </div>
                </div>
            </form>

<form id="deliveryForm" style="display: none;">

            <!-- "Check current value first" UI for the 9 one-by-one Update Details
                 actions (Go Rush Remark, Job Method, Job Price, Customer Address/
                 Area/Phone/Name/Postal Code, Weight (CBSL)). Mirrors UCDR's own
                 Check -> preview -> edit -> Submit flow, generalized over
                 SINGLE_CHECK_CONFIGS for whichever action is active. Placed right
                 above the field-wrapper cluster below so whichever target field
                 becomes visible after Check always sits directly beneath its
                 Current Value box, not down near the Submit button. -->
            <div class="mb-3" id="dlvCheckSingleWrapper" style="display: none;">
                <label for="dlvCheckSingleTrackingNumber" class="form-label">Tracking Number:</label>
                <div class="input-group">
                    <input type="text" id="dlvCheckSingleTrackingNumber" class="form-control">
                    <button type="button" id="dlvCheckSingleButton" class="btn btn-outline-secondary">Check</button>
                </div>
                <div id="dlvCheckSingleStatus" class="mt-2"></div>
            </div>
            <div class="mb-3" id="dlvCheckSingleCurrentValueWrapper" style="display: none;">
                <label class="form-label" id="dlvCheckSingleCurrentValueLabel">Current Value:</label>
                <div id="dlvCheckSingleCurrentValue" class="form-control" style="background-color:#e9ecef; height:auto;"></div>
            </div>

            <div class="mb-3">
                <div class="field-wrapper" id="dlvFgaStartDateTimeWrapper">
                    <label for="dlvFgaStartDateTime" class="form-label">Start Date/Time (Brunei Time):</label>
                    <input type="datetime-local" id="dlvFgaStartDateTime" name="fgaStartDateTime" class="form-control"
                        disabled>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvFgaEndDateTimeWrapper">
                    <label for="dlvFgaEndDateTime" class="form-label">End Date/Time (Brunei Time):</label>
                    <input type="datetime-local" id="dlvFgaEndDateTime" name="fgaEndDateTime" class="form-control"
                        disabled>
                    <strong><small>*Only Detrack status changes within this range (Brunei time) will be pushed to
                            GDEX.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvAssignDateWrapper">
                    <label for="dlvAssignDate" class="form-label">Assign Date:</label>
                    <input type="date" id="dlvAssignDate" name="assignDate" class="form-control" disabled>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvDispatchersWrapper">
                    <label for="dlvDispatchers" class="form-label">Dispatchers:</label>
                    <select id="dlvDispatchers" name="dispatchers" class="form-select" disabled>
                        <option value="" selected>Please select dispatcher</option>
                        <optgroup label="Dispatchers">
                            <option value="Edey">Edey</option>
                            <option value="Hamidin">Hamidin</option>
                            <option value="Leo">Leo</option>
                            <option value="Sowdeq">Sowdeq</option>
                            <option value="Hjazam">Hjazam</option>
                        </optgroup>
                        <optgroup label="Freelancers">
                            <option value="Ermi">Ermi</option>
                            <option value="Feeza">Feeza</option>
                            <option value="Ikha">Ikha</option>
                            <option value="Jon">Jon</option>
                            <option value="Qui">Qui</option>
                        </optgroup>
                        <optgroup label="Others">
                            <option value="Zura">Zura</option>
                            <!-- <option value="Wafi">Wafi</option> -->
                            <option value="Adiwardi">Adiwardi</option>
                            <!-- <option value="Syahmi">Syahmi</option> -->
                        </optgroup>
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvFreelancerNameWrapper">
                    <label for="dlvFreelancerName" class="form-label">Freelancer Name:</label>
                    <input type="text" id="dlvFreelancerName" name="freelancerName" class="form-control" disabled>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvAdditionalReasonWrapper">
                    <label for="dlvAdditionalReason" class="form-label">Additional Reason / Rescheduled Date:</label>
                    <input type="text" id="dlvAdditionalReason" name="additionalReason" class="form-control" disabled>
                    <strong><small>*For Detained by Customs or Cancelled Delivery, fill in the
                            reason.</small></strong><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvWarehouseWrapper">
                    <label for="dlvWarehouse" class="form-label">Warehouse:</label>
                    <select id="dlvWarehouse" name="warehouse" class="form-select" disabled>
                        <option value="" selected>Please select warehouse location</option>
                        <option value="Warehouse K1">Warehouse K1</option>
                        <option value="Warehouse K2">Warehouse K2</option>
                    </select>
                    <small>K1 > Go Rush Kiulap</small><br>
                    <small>K2 > Jangsak Warehouse</small><br>
                    <strong><small>*If no failed job, pick K1</small></strong><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvK2roomWrapper">
                    <label for="dlvK2room" class="form-label">Room:</label>
                    <select id="dlvK2room" name="k2room" class="form-select" disabled>
                        <option value="Open Space" selected>Open Space</option>
                        <option value="Medicine Room">Medicine Room</option>
                        <option value="Room 1">Room 1</option>
                    </select>
                    <small>Open space > All parcels except medicine</small><br>
                    <small>Medicine Room > Strictly for medicine</small><br>
                    <small>Room 1 > Failed deliveries</small><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvFridgeWrapper">
                    <label for="dlvFridge" class="form-label">Fridge Item?:</label>
                    <select id="dlvFridge" name="fridge" class="form-select" disabled>
                        <option value="" selected>Please select</option>
                        <option value="Yes">Yes</option>
                        <option value="No">No</option>
                    </select>
                    <strong><small>*Strictly applicable for medicines only.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvK2rowWrapper">
                    <label for="dlvK2row" class="form-label">Rack row number:</label>
                    <select id="dlvK2row" name="k2row" class="form-select" disabled>
                        <option value="N/A" selected>N/A</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                        <option value="6">6</option>
                        <option value="7">7</option>
                        <option value="8">8</option>
                        <option value="9">9</option>
                        <option value="10">10</option>
                    </select>
                    <small>Rack row number from 1-5 > Single Rack</small><br>
                    <small>Rack row number from 1-10 > Dual Rack</small><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvUcdrTrackingWrapper">
                    <label for="dlvUcdrTrackingNumber" class="form-label">Tracking Number:</label>
                    <div class="input-group">
                        <input type="text" id="dlvUcdrTrackingNumber" class="form-control" disabled>
                        <button type="button" id="dlvUcdrCheckButton" class="btn btn-outline-secondary"
                            disabled>Check</button>
                    </div>
                    <div id="dlvUcdrCheckStatus" class="mt-2"></div>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvUcdrCurrentRemarksWrapper">
                    <label class="form-label">Current Remarks:</label>
                    <div id="dlvUcdrCurrentRemarks" class="form-control" style="background-color:#e9ecef;"></div>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvCdRemarkWrapper">
                    <label for="dlvCdRemark" class="form-label">Updated Customer/Instructions Remark:</label>
                    <input type="text" id="dlvCdRemark" name="cdRemark" class="form-control" disabled>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvGrRemarkWrapper">
                    <label for="dlvGrRemark" class="form-label">New Go Rush Remark:</label>
                    <input type="text" id="dlvGrRemark" name="grRemark" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            remark.</small></strong><br>
                    <strong><small>**Check if there is existing customer remark on Detrack before
                            updating.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvWeightWrapper">
                    <label for="dlvWeight" class="form-label">New Weight:</label>
                    <input type="text" id="dlvWeight" name="weight" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with same
                            weight.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvPaymentMethodWrapper">
                    <label for="dlvPaymentMethod" class="form-label">Payment Method:</label>
                    <select id="dlvPaymentMethod" name="paymentMethod" class="form-select" disabled>
                        <option value="" selected>Please select payment method</option>
                        <optgroup label="NON COD">
                            <option value="NON COD">NON COD</option>
                        </optgroup>
                        <optgroup label="COD">
                            <option value="Cash">Cash</option>
                            <option value="Bill Payment (BIBD)">Bill Payment (BIBD)</option>
                            <option value="Bank Transfer (BIBD)">Bank Transfer (BIBD)</option>
                            <option value="Bank Transfer (Baiduri)">Bank Transfer (Baiduri)</option>
                        </optgroup>
                    </select>
                </div>
                <div class="field-wrapper" id="dlvPriceWrapper">
                    <br>
                    <label for="dlvPrice" class="form-label">New Price:</label>
                    <input type="text" id="dlvPrice" name="price" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with same
                            price and payment method.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvAreaWrapper">
                    <label for="dlvArea" class="form-label">New Area:</label>
                    <select id="dlvArea" name="area" class="form-select" disabled>
                        <option value="" selected>Please select area</option>
                        <option value="B">B</option>
                        <option value="G">G</option>
                        <option value="JT">JT</option>
                        <option value="KB">KB</option>
                        <option value="TUTONG">TUTONG</option>
                        <option value="TEMBURONG">TEMBURONG</option>
                    </select>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            area.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvAddressWrapper">
                    <label for="dlvAddress" class="form-label">New Address:</label>
                    <input type="text" id="dlvAddress" name="address" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            address.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvPhoneNumWrapper">
                    <label for="dlvPhoneNum" class="form-label">New Phone Number:</label>
                    <input type="text" id="dlvPhoneNum" name="phoneNum" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            phone number.</small></strong><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dlvNameWrapper">
                    <label for="dlvName" class="form-label">New Name:</label>
                    <input type="text" id="dlvName" name="name" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            name.</small></strong>
                </div>
            </div>
