        // Layers the new bulk/one-by-one/single-only/check-first UX on top of
        // the (verbatim, unmodified) per-field show/hide logic in
        // updateDeliveryFieldStatus(). Called right after it on every
        // #actionCode change for a delivery-flow option.
        function applyDeliveryModeUI(statusCode, mode) {
            hideAllDeliverySections();

            if (!statusCode) return;

            if (statusCode === 'UCDR') {
                // Dedicated Check-button -> preview-remark -> Submit flow;
                // updateDeliveryFieldStatus() already hid the bulk textarea and
                // showed the UCDR-specific fields. Nothing else to layer in.
                return;
            }

            if (statusCode === 'FGA') {
                // Bulk-only date-range sweep - textarea + submit button stay as
                // updateDeliveryFieldStatus() already set them; just make sure no
                // method selector / one-by-one UI leaks in.
                return;
            }

            if (mode === 'check-single') {
                // One tracking number at a time - Check first, then the
                // (verbatim) target field enables/pre-fills, then Submit.
                hideDeliveryBulkTextarea();
                hideDeliverySubmitButton();
                showCheckSingleUI(statusCode);
                return;
            }

            if (mode === 'check-bulk') {
                // Bulk-only - reuse the existing textarea, but Submit stays
                // hidden until Check has run against its current contents.
                showDeliveryBulkTextarea();
                hideDeliverySubmitButton();
                showCheckBulkUI();
                return;
            }

            if (mode === 'single') {
                hideDeliveryBulkTextarea();
                hideDeliverySubmitButton();
                showDeliveryOneByOneScanner();
                return;
            }

            // Both bulk and one-by-one are available - make the user pick a
            // method first, matching updateJob.ejs's #updateMethod pattern.
            showDeliveryMethodSelector();
            hideDeliveryBulkTextarea();
            hideDeliverySubmitButton();
            hideDeliveryOneByOneScanner();
