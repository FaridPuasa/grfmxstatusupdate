<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Check Success</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/mobile-center.css">

    <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/smallgorushlogo.png">
  <link rel="icon" href="/images/smallgorushlogo.png" type="image/x-icon">
<link rel="icon" href="/images/smallgorushlogo.png" type="image/png">
<link rel="apple-touch-icon" href="/images/favicon.png">
</head>

<body>
    <%- include('partials/navbar') %>
    <main class="container mt-4">
        <div class="card my-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Check Result</h5>
                <span class="badge bg-light text-dark"><%= totalCount %> address<%= totalCount === 1 ? '' : 'es' %> checked</span>
            </div>
            <div class="card-body">
                <% if (totalCount === 0) { %>
                    <p class="text-center text-muted">No addresses were submitted.</p>
                <% } else { %>
                    <div class="d-flex justify-content-end mb-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="copyAllBtn">
                            <i class="bi bi-clipboard"></i> Copy All Areas
                        </button>
                    </div>
                    <%- include('partials/addressAreaGroupCards', { groupedByArea }) %>
                <% } %>

                <div class="mt-3">
                    <button class="btn btn-primary" onclick="window.location.href = '/addressAreaCheck'"><i class="bi bi-arrow-left"></i> Back to Address Area
                        Checker</button>
                </div>
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const groupedByArea = <%- JSON.stringify(groupedByArea).replace(/</g, '\\u003c') %>;

        async function copyToClipboard(text, successMessage) {
            try {
                await navigator.clipboard.writeText(text);
                showToast(successMessage, 'success');
            } catch (err) {
                console.error('Clipboard copy failed:', err);
                showToast('Failed to copy to clipboard.', 'error');
            }
        }

        document.querySelectorAll('.area-copy-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const area = btn.getAttribute('data-area');
                const addresses = groupedByArea[area] || [];
                copyToClipboard(addresses.join('\n'), `Copied ${addresses.length} address(es) for ${area}.`);
            });
        });

        const copyAllBtn = document.getElementById('copyAllBtn');
        if (copyAllBtn) {
            copyAllBtn.addEventListener('click', () => {
                const lines = [];
                Object.keys(groupedByArea).forEach(area => {
                    groupedByArea[area].forEach(addr => lines.push(`${addr}\t${area}`));
                });
                copyToClipboard(lines.join('\n'), 'Copied all addresses (with area) to clipboard.');
            });
        }
    </script>
</body>

</html>
