<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Delivery</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.0.0-alpha1/css/bootstrap.min.css">
    <script src="https://unpkg.com/imask"></script>
    <style>
        /* Custom CSS for your page */
        .navbar-nav.flex-row {
            flex-direction: row !important;
        }

        /* Make the navbar background transparent */
        .navbar {
            background-color: transparent;
        }

        /* Add background color to the container */
        .container-bg {
            background-color: #333;
            /* You can use your desired background color here */
        }

        /* Add margin to the navigation links */
        .navbar-nav.flex-row .nav-item {
            margin-right: 10px;
        }

        /* Add margin to the submit button */
        .btn-submit {
            margin-top: 10px;
            /* Adjust the margin-top as needed */
        }

        /* Increase the margin-bottom for the h1 element */
        h1 {
            margin-bottom: 20px;
            /* Adjust the value as needed */
        }

        /* Custom CSS for reducing line height */
        .delivery-flow-box p {
            margin: 5px 0;
            /* Adjust the margin to control line spacing */
        }

        .logo {
            height: 40px;
            width: auto;
            max-height: 40px;
        }

        @media (max-width: 768px) {
            .logo {
                height: 30px;
                max-height: 30px;
            }
        }

        @media (max-width: 480px) {
            .logo {
                height: 25px;
                max-height: 25px;
            }
        }
    </style>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/smallgorushlogo.png">
    <link rel="icon" href="/images/smallgorushlogo.png" type="image/x-icon">
    <link rel="icon" href="/images/smallgorushlogo.png" type="image/png">
    <link rel="apple-touch-icon" href="/images/favicon.png">
</head>

<body>
    <div class="container-bg">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <%- include('partials/navbar') %>
                </div>
            </div>
        </div>
    </div>
    <main class="container mt-4 mb-4">
        <h1 class="text-center mt-4">Update Delivery</h1>
        <form action="/updateDelivery" method="post">
            <div class="mb-3">
                <div class="field-wrapper" id="consignmentIDWrapper">
                    <label for="consignmentID" class="form-label">Tracking Number(s):</label>
                    <textarea id="consignmentID" name="consignmentIDs" class="form-control" rows="2"
                        required></textarea>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="statusCodeWrapper">
                    <label for="statusCode" class="form-label">Status Code:</label>
                    <select id="statusCode" name="statusCode" class="form-select" required>
                        <option value="" selected>Please select status</option>
                        <optgroup label="Standard Flow">
                            <!-- <option value="12">1. Item In Warehouse</option> -->
                            <option value="35">1.1. Out for Delivery</option>
                            <option value="CSSC">1.2. Self Collect</option>
                        </optgroup>
                        <optgroup label="MGLOBAL Flow">
                            <option value="FCC">1.1. Fail due to Customer not available / cannot be contacted</option>
                            <option value="FIA">1.2. Fail due to Incorrect Address</option>
                            <option value="FSC">1.3.1. Fail due to Reschedule to self collect requested by customer
                            </option>
                            <option value="CSSC">1.3.2. Self Collect</option>
                        </optgroup>
                        <optgroup label="GDEX On Hold Warehouse Flow">
                            <option value="H3">Oversized Shipment</option>
                            <option value="H9">Reject By Airport</option>
                            <option value="H10">Consignee Office Closed</option>
                            <option value="H17">Damage Shipment</option>
                            <option value="H18">DG Shipment</option>
                            <option value="H19">Prohibited Shipment</option>
                            <option value="H27">Pending Custom Declaration</option>
                            <option value="H31">Shipment rejected/confiscated by customs</option>
                            <option value="H32">AWB not clear</option>
                        </optgroup>
                        <optgroup label="GDEX Return">
                            <option value="RSAL2">Return to Shipper</option>
                        </optgroup>
                        <optgroup label="Stuck Jobs Hidden from Agent App">
                            <option value="FSJ">Fix Stuck Jobs</option>
                        </optgroup>
                        <optgroup label="After Success/Fail updated on Agent App">
                            <option value="SFJ">Clear Job</option>
                        </optgroup>
                        <optgroup label="Change Details">
                            <option value="SD">Swap Dispatchers</option>
                            <option value="UWL">Update Warehouse</option>
                            <option value="UGR">Update Go Rush Remark</option>
                            <option value="UD">Update Job Date</option>
                            <option value="UJM">Update Job Method</option>
                            <option value="UP">Update Price</option>
                            <option value="UW">Update Weight</option>
                            <option value="UAS">Update Address</option>
                            <option value="UAR">Update Area</option>
                            <option value="UPN">Update Phone Number</option>
                            <option value="URN">Update Customer Name</option>
                            <option value="UPC">Update Postal Code</option>
                            <option value="UAB">Update MAWB No.</option>
                        </optgroup>
                        <optgroup label="Danger Zone!!!">
                            <option value="CD">1. Cancelled Job</option>
                            <option value="AJ">2. Cancelled -> Reactivate Job</option>
                            <option value="47">3. Dispose Job</option>
                            <!-- <option value="FA">|All| Fix Job</option> -->
                            <!-- <option value="SFJA">|All| Complete Job</option> -->
                        </optgroup>
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="assignDateWrapper">
                    <label for="assignDate" class="form-label">Assign Date:</label>
                    <input type="date" id="assignDate" name="assignDate" class="form-control" disabled>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="dispatchersWrapper">
                    <label for="dispatchers" class="form-label">Dispatchers:</label>
                    <select id="dispatchers" name="dispatchers" class="form-select" disabled>
                        <option value="" selected>Please select dispatcher</option>
                        <optgroup label="Dispatchers">
                            <!-- <option value="Edey">Edey</option> -->
                            <option value="Ghafar">Ghafar</option>
                            <option value="Hairol">Hairol</option>
                            <option value="Hamidin">Hamidin</option>
                            <option value="Leo">Leo</option>
                            <option value="Sowdeq">Sowdeq</option>
                            <option value="Wafi">Wafi</option>
                            <option value="Zura">Zura</option>
                        </optgroup>
                        <optgroup label="Freelancers">
                            <option value="Azreena">Azreena</option>
                            <option value="Bob">Bob</option>
                            <option value="Ermi">Ermi</option>
                            <option value="Feeza">Feeza</option>
                            <!-- <option value="Hjjul">Hjjul</option> -->
                             <option value="Khairul">Khairul</option>
                            <option value="Jon">Jon</option>
                            <option value="Mikael">Mikael</option>
                            <option value="Qui">Qui</option>
                            <option value="Tommy">Tommy</option>
                            <!-- <option value="Zuran">Zuran</option> -->
                            <!-- <option value="Yui">Yui</option> -->
                            <!-- <option value="Faruk">Faruk</option> -->
                            <!-- <option value="Fesal">Fesal</option> -->
                        </optgroup>
                        <optgroup label="Belts">
                            <option value="Adiwardi">Adiwardi</option>
                            <!-- <option value="Aiedil">Aiedil</option> -->
                            <!-- <option value="Hardy">Hardy</option> -->
                            <!-- <option value="Hazif">Hazif</option> -->
                            <!-- <option value="Rizal">Rizal</option> -->
                            <!-- <option value="Zainul">Zainul</option> -->
                            <!-- <option value="Zakwan">Zakwan</option> -->
                        </optgroup>
                        <!-- <optgroup label="Others">
            <option value="Syahmi">Syahmi</option>
          </optgroup> -->
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="freelancerNameWrapper">
                    <label for="freelancerName" class="form-label">Freelancer Name:</label>
                    <input type="text" id="freelancerName" name="freelancerName" class="form-control" disabled>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="additionalReasonWrapper">
                    <label for="additionalReason" class="form-label">Additional Reason / Rescheduled Date:</label>
                    <input type="text" id="additionalReason" name="additionalReason" class="form-control" disabled>
                    <strong><small>*For Detained by Customs or Cancelled Delivery, fill in the
                            reason.</small></strong><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="warehouseWrapper">
                    <label for="warehouse" class="form-label">Warehouse:</label>
                    <select id="warehouse" name="warehouse" class="form-select" disabled>
                        <option value="" selected>Please select warehouse location</option>
                        <option value="Warehouse K1">Warehouse K1</option>
                        <option value="Warehouse K2">Warehouse K2</option>
                    </select>
                    <small>K1 > Go Rush Kiulap</small><br>
                    <small>K2 > Simpang 14-9</small><br>
                    <strong><small>*If no failed job, pick K1</small></strong><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="k2roomWrapper">
                    <label for="k2room" class="form-label">Room:</label>
                    <select id="k2room" name="k2room" class="form-select" disabled>
                        <option value="Open Space" selected>Open Space</option>
                        <option value="Medicine Room">Medicine Room</option>
                        <option value="Room 1">Room 1</option>
                    </select>
                    <small>Open space > All parcels except medicine</small><br>
                    <small>Medicine Room > Strictly for medicine</small><br>
                    <small>Room 1 > Failed deliveries</small><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="fridgeWrapper">
                    <label for="fridge" class="form-label">Fridge Item?:</label>
                    <select id="fridge" name="fridge" class="form-select" disabled>
                        <option value="" selected>Please select</option>
                        <option value="Yes">Yes</option>
                        <option value="No">No</option>
                    </select>
                    <strong><small>*Strictly applicable for medicines only.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="k2rowWrapper">
                    <label for="k2row" class="form-label">Rack row number:</label>
                    <select id="k2row" name="k2row" class="form-select" disabled>
                        <option value="N/A" selected>N/A</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                        <option value="6">6</option>
                        <option value="7">7</option>
                        <option value="8">8</option>
                        <option value="9">9</option>
                        <option value="10">10</option>
                    </select>
                    <small>Rack row number from 1-5 > Single Rack</small><br>
                    <small>Rack row number from 1-10 > Dual Rack</small><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="grRemarkWrapper">
                    <label for="grRemark" class="form-label">New Go Rush Remark:</label>
                    <input type="text" id="grRemark" name="grRemark" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            remark.</small></strong><br>
                    <strong><small>**Check if there is existing customer remark on Detrack before
                            updating.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="weightWrapper">
                    <label for="weight" class="form-label">New Weight:</label>
                    <input type="text" id="weight" name="weight" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with same
                            weight.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="paymentMethodWrapper">
                    <label for="paymentMethod" class="form-label">Payment Method:</label>
                    <select id="paymentMethod" name="paymentMethod" class="form-select" disabled>
                        <option value="" selected>Please select payment method</option>
                        <optgroup label="NON COD">
                            <option value="NON COD">NON COD</option>
                        </optgroup>
                        <optgroup label="COD">
                            <option value="Cash">Cash</option>
                            <option value="Bill Payment (BIBD)">Bill Payment (BIBD)</option>
                            <option value="Bank Transfer (BIBD)">Bank Transfer (BIBD)</option>
                            <option value="Bank Transfer (Baiduri)">Bank Transfer (Baiduri)</option>
                        </optgroup>
                    </select>
                </div>
                <div class="field-wrapper" id="priceWrapper">
                    <br>
                    <label for="price" class="form-label">New Price:</label>
                    <input type="text" id="price" name="price" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with same
                            price and payment method.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="areaWrapper">
                    <label for="area" class="form-label">New Area:</label>
                    <select id="area" name="area" class="form-select" disabled>
                        <option value="" selected>Please select area</option>
                        <option value="B">B</option>
                        <option value="G">G</option>
                        <option value="JT">JT</option>
                        <option value="KB">KB</option>
                        <option value="TUTONG">TUTONG</option>
                        <option value="TEMBURONG">TEMBURONG</option>
                    </select>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            area.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="addressWrapper">
                    <label for="address" class="form-label">New Address:</label>
                    <input type="text" id="address" name="address" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            address.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="phoneNumWrapper">
                    <label for="phoneNum" class="form-label">New Phone Number:</label>
                    <input type="text" id="phoneNum" name="phoneNum" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            phone number.</small></strong><br>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="nameWrapper">
                    <label for="name" class="form-label">New Name:</label>
                    <input type="text" id="name" name="name" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            name.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="jobMethodWrapper">
                    <label for="jobMethod" class="form-label">New Job Method:</label>
                    <select id="jobMethod" name="jobMethod" class="form-select" disabled>
                        <option value="" selected>Please select Job Method</option>
                        <option value="Standard">Standard</option>
                        <option value="Express">Express</option>
                        <option value="Immediate">Immediate</option>
                        <option value="Drop Off">Drop Off</option>
                        <option value="Self Collect">Self Collect / Pick Up</option>
                    </select>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            job method.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="postalCodeWrapper">
                    <label for="postalCode" class="form-label">New Postal Code:</label>
                    <input type="text" id="postalCode" name="postalCode" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            postal code.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="awbNumWrapper">
                    <label for="awbNum" class="form-label">New MAWB No:</label>
                    <input type="text" id="awbNum" name="awbNum" class="form-control" disabled>
                    <strong><small>*1 tracking number per update recommended unless multiple tracking number with
                            same
                            AWB number.</small></strong>
                </div>
            </div>
            <div class="mb-3">
                <div class="field-wrapper" id="paymentStatusWrapper">
                    <label for="paymentStatus" class="form-label">BT paid?:</label>
                    <select id="paymentStatus" name="paymentStatus" class="form-select" disabled>
                        <option value="" selected>Please select status</option>
                        <option value="Yes">Yes</option>
                        <option value="No">No</option>
                    </select>
                </div>
            </div>
            <button type="submit" id="submitButton" class="btn btn-primary">Submit</button>
        </form>

        <div id="loading" class="text-center" style="display: none;">
            <div class="spinner-border" role="status">
                <span class="sr-only">Loading...</span>
            </div>
            <p>Loading...</p>
        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/bootstrap@5.0.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // --- NEW LOGIC: Set Assign Date to Today's Date and make it read-only/auto-populated ---
            const assignDateField = document.getElementById('assignDate');
            const today = new Date();
            const yyyy = today.getFullYear();
            const mm = String(today.getMonth() + 1).padStart(2, '0');
            const dd = String(today.getDate()).padStart(2, '0');
            const todayFormatted = `${yyyy}-${mm}-${dd}`;

            // Set the value of the assignDate field to today's date
            assignDateField.value = todayFormatted;

            // The field is already disabled by default, but we ensure it remains disabled
            // and the user cannot change it manually. However, we want it to be submitted with the form.
            // Disabled inputs are not submitted, so we need to make it readonly but still enabled? 
            // Actually, disabled fields are NOT sent to server. But original code had it disabled and expected to be enabled for certain status codes.
            // To maintain functionality while auto-populating today's date when the field becomes required/enabled,
            // we will override the updateFieldStatus logic to ensure whenever the field is enabled (required),
            // it always gets today's date and remains non-editable by user (readonly but not disabled to allow submission).
            // However, note: disabled fields are not submitted; but original design used disabled + required? That's contradictory.
            // Better approach: make the field readonly when shown, not disabled, to allow submission AND user cannot change.
            // We'll adjust dynamically in updateFieldStatus to set readonly attribute instead of disabled, but preserve original required logic.

            // Store original functions and override behaviour for assignDate.
            // But to keep it simple and robust: we'll patch the updateFieldStatus logic to ensure assignDate is always today and readonly when active.
            // However we must respect original requirements for assignDate: it should be required for certain status codes.
            // So we will preserve the required flag, but instead of setting disabled=false, we set readonly=true and remove disabled.
            // This ensures the value is submitted and user cannot change it.

            // Let's keep references and modify updateFieldStatus function after its definition.

            $("#assignDateWrapper").hide();
            $("#dispatchersWrapper").hide();
            $("#freelancerNameWrapper").hide();
            $("#additionalReasonWrapper").hide();
            $("#warehouseWrapper").hide();
            $("#weightWrapper").hide();
            $("#paymentMethodWrapper").hide();
            $("#priceWrapper").hide();
            $("#areaWrapper").hide();
            $("#addressWrapper").hide();
            $("#phoneNumWrapper").hide();
            $("#nameWrapper").hide();
            $("#jobMethodWrapper").hide();
            $("#postalCodeWrapper").hide();
            $("#awbNumWrapper").hide();
            $("#paymentStatusWrapper").hide();
            $("#k2roomWrapper").hide();
            $("#k2rowWrapper").hide();
            $("#fridgeWrapper").hide();
            $("#grRemarkWrapper").hide();

            // Get references to the fields
            const dispatchersField = document.getElementById('dispatchers');
            const freelancerNameField = document.getElementById('freelancerName');
            const additionalReasonField = document.getElementById('additionalReason');
            const warehouseField = document.getElementById('warehouse');
            const weightField = document.getElementById('weight');
            const paymentMethodField = document.getElementById('paymentMethod');
            const priceField = document.getElementById('price');
            const areaField = document.getElementById('area');
            const addressField = document.getElementById('address');
            const phoneNumField = document.getElementById('phoneNum');
            const nameField = document.getElementById('name');
            const jobMethodField = document.getElementById('jobMethod');
            const postalCodeField = document.getElementById('postalCode');
            const awbNumField = document.getElementById('awbNum');
            const paymentStatusField = document.getElementById('paymentStatus');
            const k2roomField = document.getElementById('k2room');
            const k2rowField = document.getElementById('k2row');
            const fridgeField = document.getElementById('fridge');
            const grRemarkField = document.getElementById('grRemark');

            const statusCodeSelect = document.getElementById('statusCode');
            const submitButton = document.getElementById('submitButton');

            function disableSubmitButton(event) {
                submitButton.disabled = true;
                document.getElementById('loading').style.display = 'block';
            }
            document.querySelector('form').addEventListener('submit', disableSubmitButton);

            function updateFreelancerNameField() {
                const selectedDispatcher = dispatchersField.value;
                if ((selectedDispatcher === 'FL1') || (selectedDispatcher === 'FL2')) {
                    $("#freelancerNameWrapper").fadeIn();
                    freelancerNameField.disabled = false;
                    freelancerNameField.required = true;
                } else {
                    $("#freelancerNameWrapper").hide();
                    freelancerNameField.disabled = true;
                    freelancerNameField.required = false;
                    freelancerNameField.value = '';
                }
            }

            document.getElementById('weight').addEventListener('input', function (e) {
                const value = e.target.value;
                const validNumber = /^\d*\.?\d{0,3}$/;
                if (!validNumber.test(value)) {
                    e.target.value = value.slice(0, -1);
                }
            });

            priceField.addEventListener('input', function (e) {
                const value = e.target.value;
                const validNumber = /^\d*\.?\d{0,2}$/;
                if (!validNumber.test(value)) {
                    e.target.value = value.slice(0, -1);
                }
            });

            function updatePriceWrapper() {
                const selectedPaymentMethod = paymentMethodField.value;
                if (selectedPaymentMethod === 'NON COD') {
                    $("#priceWrapper").hide();
                    priceField.disabled = true;
                    priceField.required = false;
                    priceField.value = '';
                } else {
                    $("#priceWrapper").fadeIn();
                    priceField.disabled = false;
                    priceField.required = true;
                }
            }

            $('#warehouse').change(function () {
                if ($(this).val().length == 0) {
                    $("#k2roomWrapper").hide();
                    $("#k2rowWrapper").hide();
                    k2roomField.disabled = true;
                    k2roomField.required = false;
                    k2rowField.disabled = true;
                    k2rowField.required = false;
                }
                if ($(this).val() == "Warehouse K1") {
                    $("#k2roomWrapper").hide();
                    $("#k2rowWrapper").hide();
                    k2roomField.disabled = true;
                    k2roomField.required = false;
                    k2rowField.disabled = true;
                    k2rowField.required = false;
                }
                if ($(this).val() == "Warehouse K2") {
                    $('#k2room').val("Open Space");
                    $('#k2row').val("N/A");
                    $("#k2roomWrapper").fadeIn();
                    $("#k2rowWrapper").fadeIn();
                    k2roomField.disabled = false;
                    k2roomField.required = true;
                    k2rowField.disabled = false;
                    k2rowField.required = false;
                }
            })

            // Helper to set assign date to today, readonly and ensure value is always today
            function setAssignDateTodayAndReadonly(makeRequired) {
                // Always set the value to today's date
                assignDateField.value = todayFormatted;
                // Make it readonly so user can't edit but still submits
                assignDateField.readOnly = true;
                // Remove disabled attribute so it's submitted with form
                assignDateField.disabled = false;
                if (makeRequired) {
                    assignDateField.required = true;
                } else {
                    assignDateField.required = false;
                }
            }

            // Modified updateFieldStatus with assign date always today and readonly when visible
            function updateFieldStatus() {
                const selectedStatusCode = statusCodeSelect.value;

                assignDateField.value = '';
                dispatchersField.value = '';
                additionalReasonField.value = '';
                freelancerNameField.value = '';
                warehouseField.value = '';
                weightField.value = '';
                paymentMethodField.value = '';
                priceField.value = '';
                areaField.value = '';
                addressField.value = '';
                phoneNumField.value = '';
                nameField.value = '';
                jobMethodField.value = '';
                postalCodeField.value = '';
                awbNumField.value = '';
                paymentStatusField.value = '';
                k2roomField.value = '';
                k2rowField.value = '';
                fridgeField.value = '';
                grRemarkField.value = '';

                $("#assignDateWrapper").hide();
                $("#dispatchersWrapper").hide();
                $("#additionalReasonWrapper").hide();
                $("#freelancerNameWrapper").hide();
                $("#warehouseWrapper").hide();
                $("#weightWrapper").hide();
                $("#paymentMethodWrapper").hide();
                $("#priceWrapper").hide();
                $("#areaWrapper").hide();
                $("#addressWrapper").hide();
                $("#phoneNumWrapper").hide();
                $("#nameWrapper").hide();
                $("#jobMethodWrapper").hide();
                $("#postalCodeWrapper").hide();
                $("#awbNumWrapper").hide();
                $("#paymentStatusWrapper").hide();
                $("#k2roomWrapper").hide();
                $("#k2rowWrapper").hide();
                $("#grRemarkWrapper").hide();
                $("#fridgeWrapper").hide();

                if ((selectedStatusCode === '35') || (selectedStatusCode === 'SD')) {
                    assignDateField.disabled = false;
                    dispatchersField.disabled = false;
                    additionalReasonField.disabled = true;
                    warehouseField.disabled = true;

                    $("#assignDateWrapper").fadeIn();
                    $("#dispatchersWrapper").fadeIn();

                    setAssignDateTodayAndReadonly(true);

                    dispatchersField.required = true;
                    additionalReasonField.required = false;
                    warehouseField.required = false;

                    weightField.disabled = true; weightField.required = false;
                    paymentMethodField.disabled = true; paymentMethodField.required = false;
                    priceField.disabled = true; priceField.required = false;
                    areaField.disabled = true; areaField.required = false;
                    addressField.disabled = true; addressField.required = false;
                    phoneNumField.disabled = true; phoneNumField.required = false;
                    nameField.disabled = true; nameField.required = false;
                    jobMethodField.disabled = true; jobMethodField.required = false;
                    postalCodeField.disabled = true; postalCodeField.required = false;
                    awbNumField.disabled = true; awbNumField.required = false;
                    paymentStatusField.disabled = true; paymentStatusField.required = false;
                    k2roomField.disabled = true; k2roomField.required = false;
                    k2rowField.disabled = true; k2rowField.required = false;
                    fridgeField.disabled = true; fridgeField.required = false;
                    grRemarkField.disabled = true; grRemarkField.required = false;
                }
                else if ((selectedStatusCode === 'CSSC') || (selectedStatusCode === 'UD')) {
                    assignDateField.disabled = false;
                    dispatchersField.disabled = true;
                    additionalReasonField.disabled = true;
                    warehouseField.disabled = true;
                    $("#assignDateWrapper").fadeIn();
                    setAssignDateTodayAndReadonly(true);
                    dispatchersField.required = false;
                    additionalReasonField.required = false;
                    warehouseField.required = false;
                    // reset others disabled
                    weightField.disabled = true; paymentMethodField.disabled = true; priceField.disabled = true;
                    areaField.disabled = true; addressField.disabled = true; phoneNumField.disabled = true;
                    nameField.disabled = true; jobMethodField.disabled = true; postalCodeField.disabled = true;
                    awbNumField.disabled = true; paymentStatusField.disabled = true; k2roomField.disabled = true;
                    k2rowField.disabled = true; fridgeField.disabled = true; grRemarkField.disabled = true;
                }
                else if (selectedStatusCode === 'UP') {
                    assignDateField.disabled = true;
                    $("#paymentMethodWrapper").fadeIn();
                    paymentMethodField.disabled = false;
                    paymentMethodField.required = true;
                    // assign date not shown, ensure it's not required and disabled
                    assignDateField.required = false;
                    assignDateField.disabled = true;
                }
                else if ((selectedStatusCode === '12') || (selectedStatusCode === 'SFJ') || (selectedStatusCode === 'UWL')) {
                    $("#warehouseWrapper").fadeIn();
                    warehouseField.disabled = false;
                    warehouseField.required = true;
                    assignDateField.disabled = true;
                }
                else if ((selectedStatusCode === 'CD') || (selectedStatusCode === 'DC')) {
                    additionalReasonField.disabled = false;
                    additionalReasonField.required = true;
                    $("#additionalReasonWrapper").fadeIn();
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'UW') {
                    $("#weightWrapper").fadeIn();
                    weightField.disabled = false;
                    weightField.required = true;
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'UFM') {
                    $("#fridgeWrapper").fadeIn();
                    fridgeField.disabled = false;
                    fridgeField.required = true;
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'UAR') {
                    $("#areaWrapper").fadeIn();
                    areaField.disabled = false;
                    areaField.required = true;
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'UAS') {
                    $("#addressWrapper").fadeIn();
                    addressField.disabled = false;
                    addressField.required = true;
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'UPN') {
                    $("#phoneNumWrapper").fadeIn();
                    phoneNumField.disabled = false;
                    phoneNumField.required = true;
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'URN') {
                    $("#nameWrapper").fadeIn();
                    nameField.disabled = false;
                    nameField.required = true;
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'UJM') {
                    $("#jobMethodWrapper").fadeIn();
                    jobMethodField.disabled = false;
                    jobMethodField.required = true;
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'UPC') {
                    $("#postalCodeWrapper").fadeIn();
                    postalCodeField.disabled = false;
                    postalCodeField.required = true;
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'UAB') {
                    $("#awbNumWrapper").fadeIn();
                    awbNumField.disabled = false;
                    awbNumField.required = true;
                    assignDateField.disabled = true;
                }
                else if (selectedStatusCode === 'UGR') {
                    $("#grRemarkWrapper").fadeIn();
                    grRemarkField.disabled = false;
                    grRemarkField.required = true;
                    assignDateField.disabled = true;
                }
                else {
                    assignDateField.disabled = true;
                    dispatchersField.disabled = true;
                    additionalReasonField.disabled = true;
                    warehouseField.disabled = true;
                    weightField.disabled = true;
                    paymentMethodField.disabled = true;
                    priceField.disabled = true;
                    areaField.disabled = true;
                    addressField.disabled = true;
                    phoneNumField.disabled = true;
                    nameField.disabled = true;
                    jobMethodField.disabled = true;
                    postalCodeField.disabled = true;
                    awbNumField.disabled = true;
                    paymentStatusField.disabled = true;
                    k2roomField.disabled = true;
                    k2rowField.disabled = true;
                    fridgeField.disabled = true;
                    grRemarkField.disabled = true;

                    assignDateField.required = false;
                    dispatchersField.required = false;
                    additionalReasonField.required = false;
                    warehouseField.required = false;
                    weightField.required = false;
                    paymentMethodField.required = false;
                    priceField.required = false;
                    areaField.required = false;
                    addressField.required = false;
                    phoneNumField.required = false;
                    nameField.required = false;
                    jobMethodField.required = false;
                    postalCodeField.required = false;
                    awbNumField.required = false;
                    paymentStatusField.required = false;
                    k2roomField.required = false;
                    k2rowField.required = false;
                    fridgeField.required = false;
                    grRemarkField.required = false;
                }
                // Additional case for 'SD' or '35' already handled but ensure assign date readOnly and today
                if ((selectedStatusCode === '35') || (selectedStatusCode === 'SD') || (selectedStatusCode === 'CSSC') || (selectedStatusCode === 'UD')) {
                    setAssignDateTodayAndReadonly(true);
                } else {
                    // if not showing assignDate, we might disable but also reset readonly attribute
                    assignDateField.readOnly = false;
                    assignDateField.disabled = true;
                    assignDateField.required = false;
                }
            }

            statusCodeSelect.addEventListener('change', updateFieldStatus);
            paymentMethodField.addEventListener('change', updatePriceWrapper);
            updateFieldStatus();
            dispatchersField.addEventListener('change', updateFreelancerNameField);
            updateFreelancerNameField();
        });
    </script>
    <script>
        let inputElement1 = document.getElementById('phoneNum');
        var patternMask = IMask(inputElement1, {
            mask: '{673}0000000',
        });

        let inputElement2 = document.getElementById('postalCode');
        var patternMask = IMask(inputElement2, {
            mask: '{aa}0000',
            prepare: function (value, masked) {
                if (value.length <= 2) {
                    return value.toUpperCase();
                }
                return value;
            },
        });

        let inputElement3 = document.getElementById('awbNum');
        var patternMask = IMask(inputElement3, {
            mask: '000{-}00000000',
        });
    </script>
