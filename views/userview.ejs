<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Digital ID - <%= user.name %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
        }

        .digital-id-card {
            max-width: 400px;
            width: 100%;
            background: white;
            border-radius: 30px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3);
            overflow: hidden;
            animation: slideUp 0.5s ease;
        }

        @keyframes slideUp {
            from {
                transform: translateY(50px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .card-header {
            background: white;
            padding: 30px 30px 20px 30px;
            text-align: center;
        }

        .company-logo {
            max-width: 200px;
            height: auto;
            margin: 0 auto;
            display: block;
        }

        .logo-spacer {
            height: 0px;
        }

        .card-body {
            padding: 0px 30px 30px 30px;
            text-align: center;
        }

        .profile-circle-wrapper {
            border-radius: 50%;
            display: inline-block;
            margin: 0 auto 10px auto;
        }

        .profile-circle {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            display: block;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }

        .profile-spacer {
            height: 0px;
        }

        .name {
            font-size: 24px;
            font-weight: 700;
            color: #333;
            margin-bottom: 5px;
        }

        .name-only {
            font-size: 24px;
            font-weight: 700;
            color: #333;
            margin-bottom: 25px;
        }

        .nickname {
            font-size: 18px;
            color: #666;
            margin-bottom: 20px;
        }

        .info-row {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 12px;
            text-align: center;
        }

        .info-label {
            font-size: 12px;
            color: #000;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
            text-align: center;
            font-weight: 600;
        }

        .info-value {
            font-size: 16px;
            font-weight: 600;
            color: #333;
            text-align: center;
        }

        .timer {
            font-family: monospace;
            font-size: 20px;
            font-weight: 700;
        }

        .status-badge {
            display: inline-block;
            padding: 8px 20px;
            border-radius: 50px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .status-authorized {
            background: #28a745;
            color: white;
        }

        .status-expired {
            background: #ffc107;
            color: #333;
        }

        .status-unauthorized {
            background: #dc3545;
            color: white;
        }

        .assurance-text {
            font-size: 14px;
            color: #000;
            margin-bottom: 15px;
            font-weight: 600;
            text-align: center;
        }

        .contact-info {
            margin-top: 10px;
            margin-bottom: 20px;
            text-align: center;
        }

        .contact-link {
            display: inline-block;
            margin: 5px;
            padding: 10px 20px;
            color: white;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .contact-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            filter: brightness(0.9);
        }

        .qr-code {
            margin-top: 0px;
            padding: 0px;
            background: white;
            border-radius: 15px;
            display: inline-block;
        }

        .qr-code img {
            max-width: 150px;
            height: auto;
            border-radius: 10px;
        }

        @media (max-width: 480px) {
            .digital-id-card {
                margin: 10px;
            }
            
            .name {
                font-size: 20px;
            }
            
            .name-only {
                font-size: 20px;
                margin-bottom: 20px;
            }
            
            .nickname {
                font-size: 16px;
            }
            
            .profile-circle {
                width: 120px;
                height: 120px;
            }
            
            .profile-circle-wrapper {
                margin: 0 auto 6px auto;
            }
        }
    </style>
    <link rel="icon" type="image/png" href="/images/smallgorushlogo.png">
</head>

<body>
    <div class="digital-id-card" id="digitalIdCard">
        <div class="card-header">
            <% 
                let logoFile = 'logo.png';
                let companyColor = '#3176BE';
                let infoBgColor = '#FFEAED';
                let profileBorderColor = '#3176BE';
                let buttonColor = '#3176BE';
                let companyName = 'Go Rush';
                let contactPerson = 'Go Rush Manager';
                let phoneNumber = '6738334988';
                let formattedPhone = '+673 833 4988';
                
                if (user.company === 'Globex') {
                    logoFile = 'globexlogo.png';
                    companyColor = '#3176BE';
                    infoBgColor = '#E5F2FF';
                    buttonColor = '#EE8100';
                    companyName = 'Globex';
                    contactPerson = 'Globex HR';
                    phoneNumber = '6738740189';
                    formattedPhone = '+673 874 0189';
                } else if (user.company === 'Gorush') {
                    logoFile = 'logo.png';
                    companyColor = '#3176BE';
                    infoBgColor = '#FFEAED';
                    buttonColor = '#3176BE';
                    companyName = 'Go Rush';
                    contactPerson = 'Go Rush Manager';
                    phoneNumber = '6738334988';
                    formattedPhone = '+673 833 4988';
                } else if (user.company === 'Rbskyshop') {
                    logoFile = 'rbskyshoplogo.png';
                    companyColor = '#372F2D';
                    infoBgColor = '#FFFAD7';
                    buttonColor = '#372F2D';
                    companyName = 'RBSkyshop';
                    contactPerson = 'RBSkyshop Manager';
                    phoneNumber = '6738794949';
                    formattedPhone = '+673 879 4949';
                } else if (user.company === 'Others' || !user.company) {
                    logoFile = 'globexlogo.png';
                    companyColor = '#555555';
                    infoBgColor = '#E0E0E0';
                    buttonColor = '#555555';
                    companyName = 'Globex';
                    contactPerson = 'Globex HR';
                    phoneNumber = '6738740189';
                    formattedPhone = '+673 874 0189';
                }
            %>
            <img src="/images/<%= logoFile %>" alt="Company Logo" class="company-logo">
        </div>
        
        <div class="logo-spacer"></div>
        
        <div class="card-body">
            <% if (user.profilePicture) { %>
                <div class="profile-circle-wrapper">
                    <img src="<%= user.profilePicture %>" alt="Profile" class="profile-circle">
                </div>
            <% } else { %>
                <div class="profile-circle" style="background-color: #f0f0f0; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px auto; width: 150px; height: 150px; border-radius: 50%;">
                    <i class="fas fa-user fa-4x" style="color: #999;"></i>
                </div>
            <% } %>
            
            <div class="profile-spacer"></div>
            
            <% if (user.fullName && user.fullName !== user.name) { %>
                <div class="name"><%= user.fullName %></div>
                <div class="nickname">(<%= user.name %>)</div>
            <% } else { %>
                <div class="name-only"><%= user.name %></div>
            <% } %>
            
            <div class="status-badge status-<%= statusType %>">
                <i class="fas <%= statusIcon %>"></i> <%= statusText %>
            </div>
            
            <% if (user.icNum && user.icNum.length >= 4) { 
                let lastFourDigits = user.icNum.slice(-4);
                let censoredIc = `**-**-${lastFourDigits}`;
            %>
                <div class="info-row" style="background-color: <%= infoBgColor %>;">
                    <div class="info-label">
                        <i class="fas fa-id-card"></i> IC Number
                    </div>
                    <div class="info-value">
                        <%= censoredIc %>
                    </div>
                </div>
            <% } %>
            
            <div class="info-row" style="background-color: <%= infoBgColor %>;">
                <div class="info-label">
                    <i class="fas fa-briefcase"></i> Position
                </div>
                <div class="info-value">
                    <% if (positionHtml) { %>
                        <%- positionHtml %>
                    <% } else { %>
                        <%= position %>
                    <% } %>
                </div>
            </div>
            
            <div class="assurance-text">
                <%= assuranceText %>
            </div>
            
            <div class="contact-info">
                <% if (contactHtml) { %>
                    <%- contactHtml %>
                <% } %>
            </div>
        </div>
    </div>
    
    <style>
        .digital-id-card {
            border: 3px solid <%= companyColor %>;
        }
        
        .timer {
            color: <%= companyColor %>;
        }
        
        .contact-link {
            background: <%= buttonColor %>;
        }
        
        .info-label i {
            color: #000;
        }
    </style>
    
    <% if (needTimer) { %>
    <script>
        function updateTimer() {
            const now = new Date();
            const bruneiTime = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Brunei' }));
            const tomorrow8am = new Date(bruneiTime);
            tomorrow8am.setDate(tomorrow8am.getDate() + 1);
            tomorrow8am.setHours(8, 0, 0, 0);
            
            const diff = tomorrow8am - bruneiTime;
            
            if (diff <= 0) {
                document.getElementById('timer').innerHTML = 'Expired';
                return;
            }
            
            const hours = Math.floor(diff / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (3600000)) / (1000 * 60));
            const seconds = Math.floor((diff % (60000)) / 1000);
            
            document.getElementById('timer').innerHTML = `${hours}h ${minutes}m ${seconds}s`;
        }
        
        updateTimer();
        setInterval(updateTimer, 1000);
    </script>
    <% } %>
</body>

</html>