<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Address Area Checker</title>
    <!-- Copy the styles from the first page here -->
    <style>
        /* Custom CSS for your page */
        .navbar-nav.flex-row {
            flex-direction: row !important;
        }

        /* Make the navbar background transparent */
        .navbar {
            background-color: transparent;
        }

        /* Add background color to the container */
        .container-bg {
            background-color: #333;
            /* You can use your desired background color here */
        }

        /* Add margin to the navigation links */
        .navbar-nav.flex-row .nav-item {
            margin-right: 10px;
        }

        /* Add margin to the submit button */
        .btn-submit {
            margin-top: 10px;
            /* Adjust the margin-top as needed */
        }

        /* Increase the margin-bottom for the h1 element */
        h1 {
            margin-bottom: 20px;
            /* Adjust the value as needed */
        }

        .logo {
  height: 40px;
  width: auto;
  max-height: 40px;
}

@media (max-width: 768px) {
  .logo {
    height: 30px;
    max-height: 30px;
  }
}

@media (max-width: 480px) {
  .logo {
    height: 25px;
    max-height: 25px;
  }
}
    </style>
    <!-- Include Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/smallgorushlogo.png">
  <link rel="icon" href="/images/smallgorushlogo.png" type="image/x-icon">
<link rel="icon" href="/images/smallgorushlogo.png" type="image/png">
<link rel="apple-touch-icon" href="/images/favicon.png">
  </head>

<body>
    <div class="container-bg">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <%- include('partials/navbar') %>
                </div>
            </div>
        </div>
    </div>
    <main class="container mt-4">
        <div class="card my-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Address Area Checker</h5>
            </div>
            <div class="card-body">
                <form action="/addressAreaCheck" method="post" id="addressAreaForm">
                    <div class="mb-3">
                        <label for="customerAddresses" class="form-label">Customer Address(es) — one per line</label>
                        <textarea name="customerAddresses" id="customerAddresses" rows="10" class="form-control"
                            placeholder="Enter one customer address per line"></textarea>
                    </div>
                    <button type="submit" id="submitButton" class="btn btn-primary"><i class="bi bi-search"></i> Submit</button>
                </form>

                <!-- Loading animation and message -->
                <div id="loading" class="text-center mt-3" style="display: none;">
                    <div class="spinner-border" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                    <p>Loading...</p>
                </div>
            </div>
        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Get references to the form, submit button, and loading element
        const addressAreaForm = document.getElementById('addressAreaForm');
        const submitButton = document.getElementById('submitButton');
        const loading = document.getElementById('loading');

        // Disable the submit button and show the loading animation while the
        // (synchronous, server-side) area lookup runs - the native form submit
        // below proceeds immediately, no artificial delay needed.
        function disableSubmitButton(event) {
            submitButton.disabled = true;
            loading.style.display = 'block';
        }

        // Attach the disableSubmitButton function to the "submit" event of the form
        addressAreaForm.addEventListener('submit', disableSubmitButton);
    </script>

</body>

</html>