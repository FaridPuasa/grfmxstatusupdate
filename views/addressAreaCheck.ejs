<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Address Area Checker</title>
    <style>
        /* Increase the margin-bottom for the h1 element */
        h1 {
            margin-bottom: 20px;
        }
    </style>
    <!-- Include Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/mobile-center.css">

<!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/smallgorushlogo.png">
  <link rel="icon" href="/images/smallgorushlogo.png" type="image/x-icon">
<link rel="icon" href="/images/smallgorushlogo.png" type="image/png">
<link rel="apple-touch-icon" href="/images/favicon.png">
  </head>

<body>
    <%- include('partials/navbar') %>
    <main class="container mt-4">
        <div class="card my-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Address Area Checker</h5>
            </div>
            <div class="card-body">
                <form action="/addressAreaCheck" method="post" id="addressAreaForm">
                    <div class="mb-3">
                        <label for="customerAddresses" class="form-label">Customer Address(es) — one per line</label>
                        <textarea name="customerAddresses" id="customerAddresses" rows="10" class="form-control"
                            placeholder="Enter one customer address per line" required><%= (typeof result !== 'undefined' && result) ? result.map(entry => entry.customerAddress).join('\n') : '' %></textarea>
                        <small class="text-muted" id="addressCountHint">0 addresses entered</small>
                    </div>
                    <button type="submit" id="submitButton" class="btn btn-primary"><i class="bi bi-search"></i> Submit</button>
                </form>

                <!-- Loading animation and message -->
                <div id="loading" class="text-center mt-3" style="display: none;">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p>Loading...</p>
                </div>
            </div>
        </div>

        <% if (typeof result !== 'undefined' && result) { %>
            <div class="card my-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Check Result</h5>
                    <span class="badge bg-light text-dark"><%= totalCount %> address<%= totalCount === 1 ? '' : 'es' %> checked</span>
                </div>
                <div class="card-body">
                    <% if (totalCount === 0) { %>
                        <p class="text-center text-muted">No addresses were submitted.</p>
                    <% } else { %>
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="copyAreasBtn">
                                <i class="bi bi-clipboard"></i> Copy Areas
                            </button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 3rem;">#</th>
                                        <th>Address</th>
                                        <th style="width: 8rem;">Area</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% result.forEach((entry, i) => { %>
                                        <tr class="<%= entry.area === 'N/A' ? 'table-danger' : '' %>">
                                            <td><%= i + 1 %></td>
                                            <td><%= entry.customerAddress %></td>
                                            <td><%= entry.area %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>
    </main>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Get references to the form, submit button, and loading element
        const addressAreaForm = document.getElementById('addressAreaForm');
        const submitButton = document.getElementById('submitButton');
        const loading = document.getElementById('loading');
        const customerAddresses = document.getElementById('customerAddresses');
        const addressCountHint = document.getElementById('addressCountHint');

        function nonBlankLines(text) {
            return text.split('\n').map(line => line.trim()).filter(line => line.length > 0);
        }

        function updateAddressCount() {
            const count = nonBlankLines(customerAddresses.value).length;
            addressCountHint.textContent = `${count} address${count === 1 ? '' : 'es'} entered`;
        }
        customerAddresses.addEventListener('input', updateAddressCount);
        updateAddressCount();

        // Disable the submit button and show the loading animation while the
        // (synchronous, server-side) area lookup runs - the native form submit
        // below proceeds immediately, no artificial delay needed.
        function disableSubmitButton(event) {
            if (nonBlankLines(customerAddresses.value).length === 0) {
                event.preventDefault();
                showToast('Enter at least one customer address before submitting.', 'warning');
                return;
            }
            submitButton.disabled = true;
            loading.style.display = 'block';
        }

        // Attach the disableSubmitButton function to the "submit" event of the form
        addressAreaForm.addEventListener('submit', disableSubmitButton);

        <% if (typeof result !== 'undefined' && result) { %>
        const checkedResult = <%- JSON.stringify(result).replace(/</g, '\\u003c') %>;

        async function copyToClipboard(text, successMessage) {
            try {
                await navigator.clipboard.writeText(text);
                showToast(successMessage, 'success');
            } catch (err) {
                console.error('Clipboard copy failed:', err);
                showToast('Failed to copy to clipboard.', 'error');
            }
        }

        const copyAreasBtn = document.getElementById('copyAreasBtn');
        if (copyAreasBtn) {
            copyAreasBtn.addEventListener('click', () => {
                // Areas only, one per line, in the same order the addresses
                // were pasted in - so they can be pasted straight back next
                // to the address column in Excel.
                const areas = checkedResult.map(entry => entry.area);
                copyToClipboard(areas.join('\n'), `Copied ${areas.length} area(s) to clipboard.`);
            });
        }
        <% } %>
    </script>

</body>

</html>