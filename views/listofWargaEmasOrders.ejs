<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Warga Emas Orders</title>
    <!-- Include necessary CSS and JavaScript libraries (similar to listofpharmacyPod.ejs) -->
    <!-- Make sure to include Bootstrap, jQuery, and DataTables -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/mobile-center.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.2.2/css/buttons.dataTables.min.css">
    <style>
        th {
            background-color: #f2f2f2;
            font-size: 15px;
            text-align: center;
            /* Center-align table headers horizontally */
        }

        td {
            font-size: 15px;
            text-align: center;
            /* Center-align table data cells horizontally */
        }

        table {
            width: 80%;
            /* Set the desired width for the table */
            margin: 0 auto;
            /* Center the table horizontally */
            vertical-align: middle;
            /* Center-align table contents vertically */
        }

    </style>

    <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/smallgorushlogo.png">
  <link rel="icon" href="/images/smallgorushlogo.png" type="image/x-icon">
<link rel="icon" href="/images/smallgorushlogo.png" type="image/png">
<link rel="apple-touch-icon" href="/images/favicon.png">
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <main class="container mt-4">
        <div class="card my-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-person-heart"></i> All Warga Emas Orders (<%= totalRecords %>)</h5>
            </div>
            <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped" id="orderTable">
                <thead class="table-primary">
                    <tr>
                        <th class="header">Date Time Submission</th>
                        <th class="header">Phone Number</th>
                        <th class="header">IC Picture Front</th>
                        <th class="header">IC Picture Back</th>
                    </tr>
                </thead>

                <tbody>
                    <!-- Iterate through the orders and display the data -->
                    <% waorders.forEach(function(waorder, index) { %>
                        <tr>
                            <td>
                                <%= waorder.dateTimeSubmission %>
                            </td>
                            <td>
                                <%= waorder.receiverPhoneNumber %>
                            </td>
                            <td>
                                <button class="btn btn-primary show-btn" type="button"
                                    data-bs-toggle="modal" data-bs-target="#modalFront<%= index %>"><i class="bi bi-image"></i> Show</button>
                            </td>
                            <td>
                                <button class="btn btn-primary show-btn" type="button"
                                    data-bs-toggle="modal" data-bs-target="#modalBack<%= index %>"><i class="bi bi-image"></i> Show</button>
                            </td>
                        </tr>

                        <!-- Modal for IC Picture Front -->
                        <div class="modal fade" id="modalFront<%= index %>" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">IC Picture (Front)</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body text-center">
                                        <img src="<%= waorder.icPictureFront %>" alt="IC Front" class="img-fluid">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Modal for IC Picture Back -->
                        <div class="modal fade" id="modalBack<%= index %>" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">IC Picture (Back)</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body text-center">
                                        <img src="<%= waorder.icPictureBack %>" alt="IC Back" class="img-fluid">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </tbody>
            </table>
        </div>
            </div>
        </div>
    </main>

    <!-- Include the necessary JavaScript libraries for DataTables and other custom scripts if needed -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.2.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.2.2/js/buttons.html5.min.js"></script>

    <script>
        $(document).ready(function () {
            // Initialize DataTable for the order table
            const table = $('#orderTable').DataTable({
                "ordering": false,  // Disable client-side sorting
                "iDisplayLength": 100,  // Set the default number of entries to 100
                "dom": 'Bfrtip', // Add buttons to the DOM
                "buttons": [
                    'copy', 'csv', 'excel', 'pdf', 'print' // Buttons for copy, CSV, Excel, PDF, and print
                ]
            });
        });
    </script>
</body>

</html>