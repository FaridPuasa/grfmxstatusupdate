<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List of PODs</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/mobile-center.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <style>
        th {
            background-color: #f2f2f2;
            font-size: 15px;
            text-align: center;
        }

        td {
            font-size: 15px;
            text-align: center;
        }

        table {
            width: 80%;
            margin: 0 auto;
            vertical-align: middle;
        }

        /* POD detail modal - real Bootstrap Modal, just themed to match the POD's own header color */
        #viewPODModal .modal-header {
            background-color: #6e9e9e;
            color: white;
        }

        #modalPODContent {
            overflow-x: auto;
        }

        #modalPODContent .pod-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 1400px;
        }

        #modalPODContent .pod-table th,
        #modalPODContent .pod-table td {
            border: 1px solid black;
            padding: 6px;
            text-align: center;
            vertical-align: middle;
            font-size: 12px;
        }

        #modalPODContent .pod-table th {
            background-color: #6e9e9e;
            font-weight: bold;
        }

        #modalPODContent .logo-cell img {
            width: 120px;
            height: auto;
        }

        #modalPODContent .barcode-container svg {
            max-width: 150px;
            height: auto;
        }
    </style>
    <link rel="icon" type="image/png" href="/images/smallgorushlogo.png">
    <link rel="icon" href="/images/smallgorushlogo.png" type="image/x-icon">
    <link rel="icon" href="/images/smallgorushlogo.png" type="image/png">
    <link rel="apple-touch-icon" href="/images/favicon.png">
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <main class="container mt-4">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-file-earmark-check"></i> List of PODs</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped" id="podTable">
                        <thead class="table-primary">
                            <tr>
                                <th>POD Name</th>
                                <th>Product</th>
                                <th>Dispatcher</th>
                                <th>Area</th>
                                <th>Delivery Date</th>
                                <th>No. of Deliveries</th>
                                <th>POD Creator</th>
                                <th>POD Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div class="modal fade" id="viewPODModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">POD Details</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="modalPODContent">
                    <div id="podHtmlContainer"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" id="modalPrintBtn">Print</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        // --- Get user role/email from server-side injected variables ---
        const currentUserRole = '<%= user ? user.role : "" %>';
        const currentUserEmail = '<%= user ? user.email : "" %>';
        const allowedRolesForAssign = ['admin', 'cs', 'manager'];
        const allowedEmailsForAssign = ['warehouse@globex.com.bn', 'operation2@globex.com.bn', 'operation3@globex.com.bn', 'dylan.chua@globex.com.bn'];
        const canAssignJobs = allowedRolesForAssign.includes(currentUserRole) || allowedEmailsForAssign.includes(currentUserEmail);

        // --- Helper function to get current date in Brunei timezone (UTC+8) ---
        function getBruneiCurrentDate() {
            try {
                // Use Brunei timezone (Asia/Brunei is UTC+8)
                const now = new Date();
                const bruneiDate = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Brunei' }));
                const year = bruneiDate.getFullYear();
                const month = String(bruneiDate.getMonth() + 1).padStart(2, '0');
                const day = String(bruneiDate.getDate()).padStart(2, '0');
                const bruneiDateString = `${year}-${month}-${day}`;
                return bruneiDateString;
            } catch (error) {
                // Fallback to UTC if timezone detection fails
                console.warn('Timezone detection failed, falling back to UTC:', error);
                const now = new Date();
                return now.toISOString().split('T')[0];
            }
        }

        // --- Helper function to normalize POD delivery date to YYYY-MM-DD ---
        function normalizeDeliveryDate(deliveryDate) {
            if (!deliveryDate) return null;
            
            // Handle format: "15.04.26" (DD.MM.YY)
            if (deliveryDate.match(/^\d{2}\.\d{2}\.\d{2}$/)) {
                const parts = deliveryDate.split('.');
                const day = parts[0];
                const month = parts[1];
                let year = parts[2];
                const fullYear = 2000 + parseInt(year);
                return `${fullYear}-${month}-${day}`;
            }
            // Handle format: "15.04.2026" (DD.MM.YYYY)
            else if (deliveryDate.match(/^\d{2}\.\d{2}\.\d{4}$/)) {
                const parts = deliveryDate.split('.');
                return `${parts[2]}-${parts[1]}-${parts[0]}`;
            }
            // Handle format: "15/04/26" (DD/MM/YY)
            else if (deliveryDate.match(/^\d{2}\/\d{2}\/\d{2}$/)) {
                const parts = deliveryDate.split('/');
                const day = parts[0];
                const month = parts[1];
                const year = 2000 + parseInt(parts[2]);
                return `${year}-${month}-${day}`;
            }
            // Handle format: "15-04-26" (DD-MM-YY)
            else if (deliveryDate.match(/^\d{2}-\d{2}-\d{2}$/)) {
                const parts = deliveryDate.split('-');
                const day = parts[0];
                const month = parts[1];
                const year = 2000 + parseInt(parts[2]);
                return `${year}-${month}-${day}`;
            }
            // Handle if it's already in YYYY-MM-DD format
            else if (deliveryDate.match(/^\d{4}-\d{2}-\d{2}$/)) {
                return deliveryDate;
            }
            // Try parsing as Date object as last resort
            else {
                const parsedDate = new Date(deliveryDate);
                if (!isNaN(parsedDate.getTime())) {
                    const year = parsedDate.getFullYear();
                    const month = String(parsedDate.getMonth() + 1).padStart(2, '0');
                    const day = String(parsedDate.getDate()).padStart(2, '0');
                    return `${year}-${month}-${day}`;
                }
            }
            return null;
        }

        // Helper function to format date from YYYY-MM-DD to DD.MM.YY
function formatDeliveryDate(dateString) {
    if (!dateString) return '';
    if (dateString.match(/^\d{4}-\d{2}-\d{2}$/)) {
        const parts = dateString.split('-');
        const year = parts[0].slice(-2); // Get last 2 digits of year
        return `${parts[2]}.${parts[1]}.${year}`;
    }
    return dateString;
}

$(document).ready(function () {
    let columnDefs = [
        { "data": "podName" },
        { "data": "product" },
        { "data": "dispatcher" },
        { "data": "area" },
        { 
            "data": "deliveryDate",
            "render": function(data, type, row) {
                if (type === 'display') {
                    return formatDeliveryDate(data);
                }
                return data;
            }
        },
        { "data": "rowCount" },
        { "data": "podCreator" },
        { "data": "podDate" },
        {
            "data": "_id",
            "orderable": false,
            "searchable": false,
            "render": function (data, type, row) {
                // Use original deliveryDate for assign button logic (backend expects YYYY-MM-DD)
                let deliveryDateForAssign = row.deliveryDate;
                
                let buttons = `
                    <button class="btn btn-info btn-sm view-btn" data-id="${data}"><i class="bi bi-eye"></i> View</button>
                    <button class="btn btn-secondary btn-sm copy-tracking-btn" data-id="${data}" data-podname="${row.podName}"><i class="bi bi-clipboard"></i> Copy Tracking No</button>
                `;

                if (canAssignJobs) {
                    buttons += `
                        <button class="btn btn-success btn-sm assign-jobs-btn" data-id="${data}" data-podname="${row.podName}" data-deliverydate="${deliveryDateForAssign}" data-dispatcher="${row.dispatcher}"><i class="bi bi-truck"></i> Assign Job(s)</button>
                    `;
                }

                buttons += `<button class="btn btn-danger btn-sm delete-btn" data-id="${data}"><i class="bi bi-trash"></i> Delete</button>`;
                
                return buttons;
            }
        }
    ];

    $('#podTable').DataTable({
    "processing": true,
    "serverSide": true,
    "ajax": {
        "url": "/api/listPOD",
        "type": "GET"
    },
    "columns": columnDefs,
    "order": []  // Empty array = no default sorting, let backend handle it
});
});

        // Get modal elements
        const viewPODModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('viewPODModal'));
        const modalPrintBtn = document.getElementById('modalPrintBtn');

        // Print modal content
        modalPrintBtn.onclick = function () {
            const printContent = document.getElementById('podHtmlContainer').innerHTML;
            const printWindow = window.open('', '_blank');
            printWindow.document.write(`
            <!DOCTYPE html>
            <html>
            <head>
                <title>Print POD</title>
                <style>
                    body { margin: 20px; padding: 0; font-family: Arial, sans-serif; }
                    .pod-table { width: 100%; border-collapse: collapse; page-break-inside: avoid; }
                    .pod-table th, .pod-table td { border: 1px solid black; padding: 6px; text-align: center; vertical-align: middle; font-size: 12px; }
                    .pod-table th { background-color: #6e9e9e; font-weight: bold; }
                    .logo-cell img { width: 120px; height: auto; }
                    .barcode-container { display: flex; flex-direction: column; align-items: center; }
                    .barcode-container svg { margin-bottom: 5px; max-width: 150px; height: auto; }
                    .tracking-number { font-size: 11px; word-break: break-all; }
                    @media print { body { margin: 0; padding: 0; } }
                </style>
            </head>
            <body>
                ${printContent}
                <script>
                    window.onload = function() {
                        window.print();
                        window.onafterprint = function() {
                            window.close();
                        };
                    };
                <\/script>
            </body>
            </html>
        `);
            printWindow.document.close();
        }

        // View button handler
        $(document).on('click', '.view-btn', async function () {
            const podId = $(this).data('id');

            if (!podId || podId.length !== 24) {
                showToast('Invalid POD ID format', 'error');
                return;
            }

            try {
                const response = await axios.get(`/api/view-pod/${podId}`);
                const htmlContent = response.data.htmlContent;

                document.getElementById('podHtmlContainer').innerHTML = htmlContent;
                viewPODModal.show();

            } catch (error) {
                console.error('Error fetching POD:', error);
                showToast('Failed to load POD details: ' + (error.response?.data?.error || error.message), 'error');
                $('#podTable').DataTable().ajax.reload();
            }
        });

        // Copy Tracking Numbers button handler
        $(document).on('click', '.copy-tracking-btn', async function () {
            const podId = $(this).data('id');
            const podName = $(this).data('podname');

            try {
                const response = await axios.get(`/api/view-pod/${podId}`);
                const htmlContent = response.data.htmlContent;

                // Parse the HTML to extract tracking numbers
                const parser = new DOMParser();
                const doc = parser.parseFromString(htmlContent, 'text/html');

                // Find all tracking numbers from the barcode container
                const trackingElements = doc.querySelectorAll('.tracking-number');
                const trackingNumbers = Array.from(trackingElements).map(el => el.textContent.trim());

                if (trackingNumbers.length === 0) {
                    showToast('No tracking numbers found in this POD', 'warning');
                    return;
                }

                // Join tracking numbers with new line
                const trackingText = trackingNumbers.join('\n');

                // Copy to clipboard
                await navigator.clipboard.writeText(trackingText);

                // Show success message
                showToast(`✅ ${trackingNumbers.length} tracking number(s) copied to clipboard!\n\n${trackingNumbers.join('\n')}`, 'success');

            } catch (error) {
                console.error('Error copying tracking numbers:', error);
                showToast('Failed to copy tracking numbers. Please try again.', 'error');
            }
        });

        // Delete button handler
        $(document).on('click', '.delete-btn', async function () {
            const podId = $(this).data('id');
            const ok = await showConfirm("Are you sure you want to delete this POD? This action cannot be undone.");
            if (ok) {
                window.location.href = "/deletePOD/" + podId;
            }
        });

        // Assign Job(s) button handler with Brunei timezone support
        $(document).on('click', '.assign-jobs-btn', async function() {
            // Extra runtime permission check
            if (!canAssignJobs) {
                showToast("You do not have permission to assign jobs. Only CS, Manager, and Admin roles can perform this action.", 'error');
                return;
            }
            
            const podId = $(this).data('id');
            const podName = $(this).data('podname');
            let deliveryDate = $(this).data('deliverydate');
            const dispatcher = $(this).data('dispatcher');
            
            
            // Format dispatcher name
            const formattedDispatcher = dispatcher.charAt(0).toUpperCase() + dispatcher.slice(1).toLowerCase();
            
            // Get today's date in Brunei timezone (UTC+8)
            const todayFormatted = getBruneiCurrentDate();
            
            // Normalize the delivery date from the POD
            const normalizedDeliveryDate = normalizeDeliveryDate(deliveryDate);
            
            if (!normalizedDeliveryDate) {
                showToast(`❌ Cannot parse Delivery Date: "${deliveryDate}". Expected format like "15.04.26"\n\nPlease check the POD data.`, 'error');
                return;
            }
            
            
            // Compare dates (both in YYYY-MM-DD format using Brunei timezone)
            if (normalizedDeliveryDate !== todayFormatted) {
                // Format dates for display (DD.MM.YYYY)
                const displayDeliveryDate = normalizedDeliveryDate.split('-').reverse().join('.');
                const displayTodayDate = todayFormatted.split('-').reverse().join('.');
                
                // Check if date is in the past or future
                const deliveryDateObj = new Date(normalizedDeliveryDate);
                const todayObj = new Date(todayFormatted);
                deliveryDateObj.setHours(0, 0, 0, 0);
                todayObj.setHours(0, 0, 0, 0);
                
                if (deliveryDateObj < todayObj) {
                    showToast(`❌ Cannot assign jobs: Delivery Date (${displayDeliveryDate}) has already passed.\n\nPOD Delivery Date: ${deliveryDate}\nToday's Date (Brunei): ${displayTodayDate}\n\nNote: Only same-day deliveries can be assigned.`, 'error');
                } else {
                    showToast(`❌ Cannot assign jobs: Delivery Date (${displayDeliveryDate}) is in the future.\n\nPlease wait until ${displayDeliveryDate} (Brunei time) to assign these jobs.\n\nPOD Delivery Date: ${deliveryDate}\nToday's Date (Brunei): ${displayTodayDate}`, 'error');
                }
                return;
            }
            
            // Confirm with user
            const confirmMessage = `⚠️ CONFIRM ASSIGNMENT\n\n` +
                `Pod: ${podName}\n` +
                `Delivery Date: ${deliveryDate} (Today - Brunei Time)\n` +
                `Dispatcher: ${formattedDispatcher}\n\n` +
                `All tracking numbers in this POD will be updated to "Out for Delivery" status.\n\n` +
                `This will:\n` +
                `• Update Detrack status to "dispatched"\n` +
                `• Update MongoDB with assignment details\n` +
                `• Send GDEX webhook for GDEX/GDEXT products\n\n` +
                `Proceed?`;
            
            const confirmedAssign = await showConfirm(confirmMessage, { okText: 'Proceed', okClass: 'btn-primary' });
            if (!confirmedAssign) {
                return;
            }
            
            // Show loading modal
            showAssignJobsModal(podName, formattedDispatcher, deliveryDate);
            
            try {
                // Get all tracking numbers from the POD
                const response = await axios.get(`/api/view-pod/${podId}`);
                const htmlContent = response.data.htmlContent;
                
                // Parse HTML to extract tracking numbers
                const parser = new DOMParser();
                const doc = parser.parseFromString(htmlContent, 'text/html');
                
                // Find all tracking numbers
                const trackingElements = doc.querySelectorAll('.tracking-number');
                const trackingNumbers = Array.from(trackingElements).map(el => el.textContent.trim());
                
                if (trackingNumbers.length === 0) {
                    showToast('No tracking numbers found in this POD', 'warning');
                    hideAssignJobsModal();
                    return;
                }
                

                // Update modal with tracking count
                updateAssignJobsStatus(`Processing 0 of ${trackingNumbers.length} job(s)...`);

                // Kick off the background job - use normalized date (already in YYYY-MM-DD).
                // The server responds immediately with a jobId instead of processing
                // everything inline, since a POD with many jobs can take well over
                // Heroku's 30s router timeout to process sequentially.
                const assignResponse = await axios.post('/api/assign-pod-jobs', {
                    podId: podId,
                    podName: podName,
                    trackingNumbers: trackingNumbers,
                    dispatcher: formattedDispatcher,
                    assignDate: normalizedDeliveryDate
                });

                const jobId = assignResponse.data.jobId;
                if (!jobId) throw new Error('No job ID received from server');

                const job = await pollAssignJobsStatus(jobId, trackingNumbers.length);

                if (job.status === 'cancelled') {
                    showToast('Assignment cancelled. Note: any jobs the server had already processed before you cancelled are still assigned.', 'warning');
                    return;
                }

                const results = job.results || [];
                const successCount = results.filter(r => r.success).length;
                const failCount = results.filter(r => !r.success).length;

                let message;
                if (job.status === 'failed') {
                    message = `❌ Assignment failed: ${job.error || 'Unknown error'}`;
                } else {
                    message = `✅ Assignment Complete!\n\n`;
                    message += `Total Jobs: ${trackingNumbers.length}\n`;
                    message += `Successfully Assigned: ${successCount}\n`;
                    message += `Failed: ${failCount}\n\n`;

                    if (failCount > 0) {
                        message += `❌ Failed Jobs:\n`;
                        results.filter(r => !r.success).forEach(r => {
                            message += `• ${r.trackingNumber}: ${r.error}\n`;
                        });
                    }
                }

                showToast(message, job.status === 'failed' ? 'error' : 'success');

                // Refresh the DataTable
                $('#podTable').DataTable().ajax.reload();

            } catch (error) {
                console.error('Error assigning jobs:', error);
                showToast('Failed to assign jobs: ' + (error.response?.data?.error || error.message), 'error');
            } finally {
                hideAssignJobsModal();
            }
        });

        // Set whenever the assign-jobs modal closes (see the 'hidden.bs.modal'
        // listener in showAssignJobsModal below); checked by the poll loop so
        // dismissing the modal actually stops the client from polling/acting
        // on this job, instead of just hiding it while polling silently continued.
        let assignJobsCancelled = false;

        // Polls /api/assign-pod-jobs/status/:jobId until the job reaches a
        // terminal status, updating the modal's progress text as it goes.
        function pollAssignJobsStatus(jobId, total) {
            assignJobsCancelled = false;
            return new Promise((resolve, reject) => {
                const pollTimer = setInterval(async () => {
                    if (assignJobsCancelled) {
                        clearInterval(pollTimer);
                        resolve({ status: 'cancelled' });
                        return;
                    }
                    try {
                        const res = await axios.get(`/api/assign-pod-jobs/status/${jobId}`);
                        const job = res.data;

                        if (assignJobsCancelled) {
                            clearInterval(pollTimer);
                            resolve({ status: 'cancelled' });
                            return;
                        }

                        const processed = job.processed || 0;
                        const pct = total > 0 ? Math.round((processed / total) * 100) : 0;
                        updateAssignJobsStatus(`Processing ${processed} of ${total} job(s)... (${pct}%)`);

                        if (job.status === 'completed' || job.status === 'failed') {
                            clearInterval(pollTimer);
                            resolve(job);
                        }
                    } catch (error) {
                        clearInterval(pollTimer);
                        reject(error);
                    }
                }, 2000);
            });
        }

        // Modal functions for showing progress
        function showAssignJobsModal(podName, dispatcher, deliveryDate) {
            if (!document.getElementById('assignJobsModal')) {
                $('body').append(`
            <div class="modal fade" id="assignJobsModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog" style="max-width: 500px;">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Assigning Jobs</h5>
                            <button type="button" class="btn-close" id="assignJobsModalClose" aria-label="Close"></button>
                        </div>
                        <div class="modal-body text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p id="assignJobsStatus" class="mt-3">Processing jobs...</p>
                            <div id="assignJobsDetails" class="mt-2" style="font-size: 12px; color: #666;"></div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" id="assignJobsModalCancel">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        `);

                const modalEl = document.getElementById('assignJobsModal');

                // However the modal ends up closing - Cancel button, backdrop
                // click, or Escape - treat it as a cancellation so the poll
                // loop stops and the caller doesn't act on a stale result.
                modalEl.addEventListener('hidden.bs.modal', function () {
                    assignJobsCancelled = true;
                });

                $('#assignJobsModalClose, #assignJobsModalCancel').click(function () {
                    hideAssignJobsModal();
                });
            }

            bootstrap.Modal.getOrCreateInstance(document.getElementById('assignJobsModal')).show();
            $('#assignJobsStatus').text(`Assigning jobs for POD: ${podName}`);
            $('#assignJobsDetails').text(`Dispatcher: ${dispatcher} | Delivery Date: ${deliveryDate} (Brunei Time)`);
        }

        function updateAssignJobsStatus(message, details = '') {
            $('#assignJobsStatus').text(message);
            if (details) {
                $('#assignJobsDetails').html(details);
            }
        }

        function hideAssignJobsModal() {
            const modalEl = document.getElementById('assignJobsModal');
            if (modalEl) bootstrap.Modal.getOrCreateInstance(modalEl).hide();
        }
    </script>
</body>

</html>