<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List of Pharmacy Forms</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/mobile-center.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Include DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <style>
        th {
            background-color: #f2f2f2;
            font-size: 15px;
            text-align: center;
            /* Center-align table headers horizontally */
        }

        td {
            font-size: 15px;
            text-align: center;
            /* Center-align table data cells horizontally */
        }

        table {
            width: 80%;
            /* Set the desired width for the table */
            margin: 0 auto;
            /* Center the table horizontally */
            vertical-align: middle;
            /* Center-align table contents vertically */
        }
    </style>
</head>

<body class="bg-light">
    <div class="container-bg">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <%- include('partials/navbar') %>
                </div>
            </div>
        </div>
    </div>

    <main class="container mt-4">
        <div class="card my-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="bi bi-archive"></i> List of Pharmacy Forms</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped" id="formTable">
                        <thead class="table-primary">
                            <tr>
                                <th class="header">Form Name</th>
                                <th class="header">Form For</th>
                                <th class="header">Created By</th>
                                <th class="header">Form Date</th>
                                <th class="header">Batch No</th>
                                <th class="header">No. of Forms</th>
                                <th class="header">First No.</th>
                                <th class="header">Last No.</th>
                                <th class="header">Actions</th> <!-- Add Actions column -->
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#formTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/api/listofpharmacyMOHForms",
                    "type": "GET"
                },
                "ordering": false,  // Disable client-side sorting
                "iDisplayLength": 10,  // Set the default number of entries to 100
                "columns": [
                    { "data": "formName" },
                    { "data": "mohForm" },
                    { "data": "formCreator" },
                    { "data": "formDate" },
                    { "data": "batchNo" },
                    { "data": "numberOfForms" },
                    { "data": "startNo" },
                    { "data": "endNo" },
                    {
                        "data": "_id",
                        "orderable": false,
                        "searchable": false,
                        "render": function (data) {
                            return `
                <button class="btn btn-danger btn-sm" onclick="confirmDelete('${data}')"><i class="bi bi-trash"></i> Delete</button>
            `;
                        }
                    }
                ],
                "order": [[0, "desc"]]  // Default sort by _id (latest first)
            });
        });
    </script>

    <!-- Script for delete confirmation -->
    <script>
        async function confirmDelete(formId) {
            const ok = await showConfirm("Are you sure you want to delete this record?");
            if (!ok) return;
            window.location.href = "/deletePharmacyForm/" + formId; // Redirect to delete route
        }
    </script>

</body>

</html>
