<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report List</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">
    <style>
        .navbar-nav.flex-row {
            flex-direction: row !important;
        }

        .navbar {
            background-color: transparent;
        }

        .container-bg {
            background-color: #333;
        }

        .navbar-nav.flex-row .nav-item {
            margin-right: 10px;
        }

        th {
            background-color: #f2f2f2;
            font-size: 15px;
            text-align: center;
        }

        td {
            font-size: 15px;
            text-align: center;
        }

        table.dataTable {
            width: 90%;
            margin: 0 auto;
            vertical-align: middle;
        }

        .custom-modal {
            display: none;
            position: fixed;
            z-index: 9999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
        }

        .custom-modal-content {
            background-color: #fff;
            margin: 2% auto;
            padding: 0;
            width: 95%;
            max-width: 95%;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
            max-height: 90vh;
            display: flex;
            flex-direction: column;
        }

        .custom-modal-header {
            padding: 15px 20px;
            background-color: #6e9e9e;
            color: white;
            border-radius: 8px 8px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .custom-modal-header h5 {
            margin: 0;
            font-size: 18px;
        }

        .custom-modal-close {
            color: white;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            line-height: 20px;
        }

        .custom-modal-close:hover {
            color: #ddd;
        }

        .custom-modal-body {
            padding: 20px;
            overflow: auto;
            flex: 1;
        }

        .custom-modal-footer {
            padding: 15px 20px;
            border-top: 1px solid #ddd;
            text-align: right;
            border-radius: 0 0 8px 8px;
        }

        .custom-modal-footer button {
            margin-left: 10px;
        }

        /* Styling for the injected reportContent HTML (mirrors reportGenerator.ejs table look) */
        #reportHtmlContainer table {
            border-collapse: collapse;
            width: auto;
            min-width: 300px;
            margin-bottom: 20px;
        }

        #reportHtmlContainer th,
        #reportHtmlContainer td {
            border: 1px solid black;
            padding: 5px;
            vertical-align: middle;
        }

        #reportHtmlContainer th {
            background: yellow;
            font-weight: bold;
            text-align: center;
        }

        #reportHtmlContainer td {
            white-space: pre-line;
            text-align: center;
        }

        #reportHtmlContainer img {
            max-height: 80px;
            display: block;
            margin: 0 auto 10px auto;
        }

        /* Freelancer Job Completed Count Report layout (mirrors reportGenerator.ejs) */
        #reportHtmlContainer #freelancerJobCountResultsContainer {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        #reportHtmlContainer .freelancerJobCountTableWrapper {
            flex: 0 0 auto;
            width: 48%;
            box-sizing: border-box;
        }

        #reportHtmlContainer .freelancerJobCountTableWrapper table {
            width: 100%;
            margin-bottom: 0;
        }

        #reportHtmlContainer .freelancerJobCountTableWrapper th.freelancerNameHeader {
            background-color: #ffffff !important;
            color: #000000 !important;
            text-align: center;
            font-weight: bold;
        }

        #reportHtmlContainer .freelancerJobCountTableWrapper th.dateDeliveredHeader {
            background-color: lightblue !important;
            color: #000000 !important;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container-bg">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <%- include('partials/navbar') %>
                </div>
            </div>
        </div>
    </div>

    <main class="container mt-4">
        <h1 class="text-center mt-4">Report List</h1>
        <div class="table-responsive">
            <table class="table table-bordered table-striped" id="reportTable">
                <thead class="table-primary">
                    <tr>
                        <th>Report Type</th>
                        <th>Report Date</th>
                        <th>Created By</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% reports.forEach(function(report) { %>
                        <tr>
                            <td><%= report.reportType %></td>
                            <td><%= report.reportDateDisplay %></td>
                            <td><%= report.createdBy %></td>
                            <td>
                                <button class="btn btn-primary btn-sm" onclick="viewReport('<%= report._id %>')">View</button>
                                <button class="btn btn-danger btn-sm" onclick="confirmDeleteReport('<%= report._id %>')">Delete</button>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </main>

    <!-- View / Print modal -->
    <div id="viewReportModal" class="custom-modal">
        <div class="custom-modal-content">
            <div class="custom-modal-header">
                <h5 id="viewReportTitle">Report Details</h5>
                <span class="custom-modal-close" id="modalCloseBtn">&times;</span>
            </div>
            <div class="custom-modal-body">
                <div id="reportHtmlContainer"></div>
            </div>
            <div class="custom-modal-footer">
                <button type="button" class="btn btn-primary" id="modalPrintBtn">Print</button>
                <button type="button" class="btn btn-secondary" id="modalCloseFooterBtn">Close</button>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#reportTable').DataTable({
                "iDisplayLength": 10,
                "order": [] // preserve server-side sort (newest first)
            });
        });

        const modal = document.getElementById('viewReportModal');
        const modalCloseBtn = document.getElementById('modalCloseBtn');
        const modalCloseFooterBtn = document.getElementById('modalCloseFooterBtn');
        const modalPrintBtn = document.getElementById('modalPrintBtn');
        let currentReportName = '';
        let currentReportType = '';

        // Each report type has its own bespoke print stylesheet in reportGenerator.ejs
        // (different header colors/selectors, zoom level). Reuse them verbatim here so
        // Print output matches "print preview provided from report generator" exactly.
        const PRINT_STYLES = {
            'Operation Morning Report': `
                body { font-family: Arial, sans-serif; padding: 20px; }
                h2 { text-align: center; margin-bottom: 20px; }
                table { border-collapse: collapse; width: 100%; margin-bottom: 20px; }
                th, td { border: 1px solid black; padding: 5px; text-align: center; vertical-align: middle; white-space: pre-line; }
                th { font-weight: bold; text-align: center; }
                #dispatcherJobsTable thead tr:first-child th, #morningMileageTable thead tr:first-child th { background: yellow; }
                #dispatcherJobsTable thead tr:nth-child(2) th, #morningMileageTable thead tr:nth-child(2) th { background: white; }
                img { max-height: 80px; display: block; margin: 0 auto 10px auto; }
            `,
            'Operation End of Day Report': `
                body { font-family: Arial, sans-serif; padding: 25px; }
                h2 { text-align: center; margin: 10px 0 20px; }
                table { width: 100%; border-collapse: collapse; margin-bottom: 25px; }
                th, td { border: 1px solid #000; padding: 6px 8px; font-size: 14px; text-align: center; vertical-align: middle; }
                th { background-color: #e6f2ff; font-weight: bold; }
                tr:first-child th[colspan] { background-color: lightblue !important; text-align: left; font-size: 15px; }
                img { display: block; margin: 0 auto; max-height: 80px; }
                .checked-by { font-weight: bold; margin-top: 10px; }
                @media print { body { zoom: 90%; } }
            `,
            'Freelancer End of Day Report': `
                body { font-family: Arial, sans-serif; padding: 25px; }
                h2 { text-align: center; margin: 10px 0 20px; }
                table { width: 100%; border-collapse: collapse; margin-bottom: 25px; }
                th, td { border: 1px solid #000; padding: 6px 8px; font-size: 14px; text-align: center; vertical-align: middle; }
                th { background-color: #e6f2ff; font-weight: bold; }
                tr:first-child th[colspan] { background-color: lightblue !important; text-align: left; font-size: 15px; }
                img { display: block; margin: 0 auto; max-height: 80px; }
                .checked-by { font-weight: bold; margin-top: 10px; }
            `,
            'Freelancer Job Completed Count Report': `
                body { font-family: Arial, sans-serif; padding: 25px; }
                h2 { text-align: center; margin: 10px 0 20px; }
                #freelancerJobCountResultsContainer { display: flex; flex-wrap: wrap; gap: 15px; }
                .freelancerJobCountTableWrapper { flex: 0 0 auto; width: 48%; box-sizing: border-box; }
                table { width: 100%; border-collapse: collapse; margin-bottom: 0; }
                th, td { border: 1px solid #000; padding: 6px 8px; font-size: 14px; text-align: center; vertical-align: middle; }
                th.freelancerNameHeader {
                    background-color: #ffffff !important; color: #000000 !important; font-weight: bold;
                    -webkit-print-color-adjust: exact; print-color-adjust: exact; color-adjust: exact;
                }
                th.dateDeliveredHeader {
                    background-color: lightblue !important; color: #000000 !important;
                    -webkit-print-color-adjust: exact; print-color-adjust: exact; color-adjust: exact;
                }
                img { display: block; margin: 0 auto; max-height: 80px; }
                .checked-by { font-weight: bold; margin-top: 10px; }
                @media print { body { zoom: 90%; } }
            `,
            'Freelancer Opening Report': `
                body { font-family: Arial, sans-serif; padding: 25px; }
                h2 { text-align: center; margin: 10px 0 20px; }
                table { width: 100%; border-collapse: collapse; margin-bottom: 25px; }
                th, td { border: 1px solid #000; padding: 6px 8px; font-size: 14px; text-align: center; vertical-align: middle; white-space: pre-line; }
                th { font-weight: bold; }
                thead tr:first-child th { background: yellow; }
                img { display: block; margin: 0 auto; max-height: 80px; }
                @media print { body { zoom: 90%; } }
            `
        };
        const DEFAULT_PRINT_STYLE = `
            body { margin: 20px; padding: 0; font-family: Arial, sans-serif; }
            table { border-collapse: collapse; width: auto; min-width: 300px; margin-bottom: 20px; }
            th, td { border: 1px solid black; padding: 5px; vertical-align: middle; }
            th { background: yellow; font-weight: bold; text-align: center; }
            td { white-space: pre-line; text-align: center; }
            img { max-height: 80px; display: block; margin: 0 auto 10px auto; }
        `;

        function openModal() {
            modal.style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            modal.style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        modalCloseBtn.onclick = closeModal;
        modalCloseFooterBtn.onclick = closeModal;
        window.onclick = function (event) {
            if (event.target === modal) closeModal();
        };

        // Reports are saved with their live "Action" column (Remove buttons) still baked into
        // the table HTML. reportGenerator.ejs's own Print buttons strip that column before
        // printing (it's only useful while editing); do the same here so View/Print match.
        function stripActionColumns(root) {
            root.querySelectorAll('table').forEach(function (table) {
                const headerRow = table.querySelector('thead tr:last-of-type') || table.querySelector('tr');
                if (!headerRow) return;
                const hasActionColumn = Array.from(headerRow.children).some(function (th) {
                    return th.textContent.trim().toLowerCase() === 'action';
                });
                if (!hasActionColumn) return;
                table.querySelectorAll('tr').forEach(function (row) {
                    const cells = row.children;
                    if (cells.length > 1) row.removeChild(cells[cells.length - 1]);
                });
            });
        }

        function viewReport(id) {
            fetch('/api/reportList/view/' + id)
                .then(function (res) {
                    if (!res.ok) throw new Error('Failed to load');
                    return res.json();
                })
                .then(function (data) {
                    currentReportName = data.reportName;
                    currentReportType = data.reportType;
                    document.getElementById('viewReportTitle').textContent = data.reportName;
                    const container = document.getElementById('reportHtmlContainer');
                    container.innerHTML = data.reportContent;
                    stripActionColumns(container);
                    openModal();
                })
                .catch(function (err) {
                    console.error(err);
                    alert('Failed to load report.');
                });
        }

        modalPrintBtn.onclick = function () {
            const printContent = document.getElementById('reportHtmlContainer').innerHTML;
            const style = PRINT_STYLES[currentReportType] || DEFAULT_PRINT_STYLE;
            const printWindow = window.open('', '_blank');
            printWindow.document.write(`
                <!DOCTYPE html>
                <html>
                <head>
                    <title>${currentReportName || 'Report'}</title>
                    <style>${style}</style>
                </head>
                <body>
                    ${printContent}
                    <script>
                        window.onload = function() {
                            window.print();
                            window.onafterprint = function() {
                                window.close();
                            };
                        };
                    <\/script>
                </body>
                </html>
            `);
            printWindow.document.close();
        };

        function confirmDeleteReport(id) {
            if (confirm("Are you sure you want to delete this report? This action cannot be undone.")) {
                window.location.href = "/deleteReport/" + id;
            }
        }
    </script>
</body>

</html>
