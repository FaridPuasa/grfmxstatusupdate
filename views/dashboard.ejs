/* ===== Dashboard redesign ===== */
:root {
    --gr-warehouse: #475569;
    --gr-progress: #16a34a;
    --gr-neworders: #2563eb;
    --gr-bg: #f3f5f9;
    --gr-radius: 14px;
}

html {
    scroll-behavior: smooth;
}

body {
    background: var(--gr-bg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

h1.text-center {
    font-weight: 700;
    letter-spacing: -0.02em;
}

/* KPI summary strip */
.kpi-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
}

.kpi-tile {
    flex: 1 1 130px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.65rem 0.9rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.kpi-tile .kpi-value {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.1;
    color: #1e293b;
}

.kpi-tile .kpi-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
    margin-top: 0.15rem;
}

.kpi-tile.kpi-warn .kpi-value { color: #b45309; }
.kpi-tile.kpi-danger .kpi-value { color: #b91c1c; }
.kpi-tile.kpi-dark .kpi-value { color: #111827; }
.kpi-tile.kpi-muted .kpi-value { color: #6b7280; }

/* Card polish */
.card {
    border: 1px solid #e5e7eb;
    border-radius: var(--gr-radius);
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    overflow: hidden;
}

.card > .card-header:first-child {
    border-top-left-radius: var(--gr-radius);
    border-top-right-radius: var(--gr-radius);
}

#section-warehouse > .card-header { border-left: 4px solid var(--gr-warehouse); }
#section-progress > .card-header { border-left: 4px solid var(--gr-progress); }
#section-neworders > .card-header { border-left: 4px solid var(--gr-neworders); }

.toggle-header {
    transition: background 0.12s ease;
}

.toggle-header:hover {
    background: rgba(0, 0, 0, 0.03);
}

/* Rotate the collapse caret based on aria-expanded, set automatically by Bootstrap */
.bi-caret-down-fill {
    display: inline-block;
    transition: transform 0.2s ease;
}

.toggle-header[aria-expanded="true"] .bi-caret-down-fill,
i.bi-caret-down-fill[aria-expanded="true"] {
    transform: rotate(180deg);
}

/* Tables: sticky header + zebra striping within their own scroll area */
.table-responsive {
    max-height: 480px;
}

.table-responsive thead th {
    position: sticky;
    top: 0;
    z-index: 1;
    background: #f8fafc;
    box-shadow: inset 0 -1px 0 #e2e8f0;
}

.table-hover tbody tr:hover,
.table tbody tr:hover {
    background-color: rgba(37, 99, 235, 0.04);
}

/* Copy/Export toolbar */
.section-toolbar {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
}

.toolbar-btn {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    white-space: nowrap;
}

/* Back to top */
#backToTopBtn {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 1040;
    display: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    padding: 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}
    </style>

