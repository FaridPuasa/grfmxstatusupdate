<script>
    let codBtData = null;
let codBtLoaded = false;  // flag to prevent multiple loads

let completedJobsData = null;
let completedJobsLoaded = false;

async function loadCompletedJobs() {
    const datePicker = document.getElementById('completed-jobs-date-picker');
    const selectedDate = datePicker.value || moment().format('YYYY-MM-DD');

    const formattedDateKey = moment(selectedDate).format('YYYY-MM-DD');
    const tableBody = document.getElementById('completed-jobs-table-body');

    // Show loading spinner
    tableBody.innerHTML = `
        <tr><td colspan="4" class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
        </td></tr>
    `;

    try {
        const response = await fetch(`/api/completed-jobs?date=${formattedDateKey}`);
        const data = await response.json();
        completedJobsData = data;

        renderOverallSummary(data);
        renderDispatcherSummaryCards(data);
        renderCompletedJobsTable(data);
        completedJobsLoaded = true;
    } catch (error) {
        console.error('Failed to load completed jobs:', error);
        tableBody.innerHTML = `<tr><td colspan="4" class="text-center text-danger">Failed to load data.</td></tr>`;
        const summaryEl = document.getElementById('dispatcherSummaryStrip');
        if (summaryEl) summaryEl.innerHTML = '<p class="text-danger mb-0">Failed to load dispatcher summary.</p>';
        ['overallSummaryTotal', 'overallSummaryActive', 'overallSummaryCompleted', 'overallSummaryFailed'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.textContent = '-';
        });
    }
}

function createBadge(count, color='primary') {
    return `<span class="badge bg-${color} ms-2">${count}</span>`;
}

// Overall Total/Active/Completed/Failed row — aggregated across all dispatchers/freelancers
function renderOverallSummary(data) {
    let active = 0, completed = 0, failed = 0;
    Object.keys(data).forEach(dispatcher => {
        const d = data[dispatcher];
        active += (d.inProgress || []).length;
        completed += (d.completed || []).length;
        failed += (d.failed || []).length;
    });
    const total = active + completed + failed;

    document.getElementById('overallSummaryTotal').textContent = total;
    document.getElementById('overallSummaryActive').textContent = active;
    document.getElementById('overallSummaryCompleted').textContent = completed;
    document.getElementById('overallSummaryFailed').textContent = failed;
}

// Assignees on this list are in-house dispatch staff; everyone else is treated as a freelancer.
const DISPATCHER_STAFF = ["Sowdeq", "Leo", "Hamidin", "Wafi", "Edey", "Zura", "Adiwardi", "Haiqal", "Hjazam"];

// Dispatcher/freelancer summary cards — only shown for dispatchers with active jobs right now
function renderDispatcherSummaryCards(data) {
    const container = document.getElementById('dispatcherSummaryStrip');
    if (!container) return;
    container.innerHTML = '';

    const totalFor = (dispatcher) => {
        const d = data[dispatcher];
        return (d.inProgress || []).length + (d.completed || []).length + (d.failed || []).length;
    };

    const activeDispatchers = Object.keys(data)
        .filter(dispatcher => (data[dispatcher].inProgress || []).length > 0)
        .sort((a, b) => totalFor(b) - totalFor(a));

    if (activeDispatchers.length === 0) {
        container.innerHTML = '<p class="text-muted mb-0">No active jobs right now.</p>';
        return;
    }

    const renderCard = (dispatcher, type) => {
        const d = data[dispatcher];
        const activeCount = d.inProgress.length;
        const completedCount = (d.completed || []).length;
        const failedCount = (d.failed || []).length;
        const totalCount = activeCount + completedCount + failedCount;
        const areas = [...new Set(d.inProgress.map(job => job.area).filter(Boolean))];

        container.insertAdjacentHTML('beforeend', `
            <div class="dispatcher-card type-${type}">
                <div class="dispatcher-card-name"><i class="bi bi-person-badge"></i>${dispatcher}</div>
                <div class="dispatcher-card-area">${areas.length ? areas.join(', ') : '-'}</div>
                <div class="dispatcher-card-stats">
                    <span class="badge bg-secondary"><i class="bi bi-collection"></i> Total ${totalCount}</span>
                    <span class="badge bg-info"><i class="bi bi-lightning-charge-fill"></i> Active ${activeCount}</span>
                    <span class="badge bg-success"><i class="bi bi-check-circle-fill"></i> Completed ${completedCount}</span>
                    <span class="badge bg-danger"><i class="bi bi-x-circle-fill"></i> Failed ${failedCount}</span>
                </div>
            </div>
        `);
    };

    // Group dispatchers first, then freelancers — most jobs to least within each group
    const dispatcherGroup = activeDispatchers.filter(name => DISPATCHER_STAFF.includes(name));
    const freelancerGroup = activeDispatchers.filter(name => !DISPATCHER_STAFF.includes(name));

    if (dispatcherGroup.length > 0) {
        container.insertAdjacentHTML('beforeend', '<div class="dispatcher-group-label type-dispatcher"><i class="bi bi-truck"></i> Dispatchers</div>');
        dispatcherGroup.forEach(name => renderCard(name, 'dispatcher'));
    }
    if (freelancerGroup.length > 0) {
        container.insertAdjacentHTML('beforeend', '<div class="dispatcher-group-label type-freelancer"><i class="bi bi-bicycle"></i> Freelancers</div>');
        freelancerGroup.forEach(name => renderCard(name, 'freelancer'));
    }
}

function renderCompletedJobsTable(data) {
    const tableBody = document.getElementById('completed-jobs-table-body');
    tableBody.innerHTML = '';

    const allDispatchers = Object.keys(data);
    if (allDispatchers.length === 0) {
        tableBody.innerHTML = `<tr><td colspan="4" class="text-center text-muted">No records found for selected date.</td></tr>`;
        return;
    }

    const totalFor = (dispatcher) => {
        const d = data[dispatcher];
        return d.inProgress.length + d.completed.length + d.failed.length;
    };

    // Split into Dispatcher / Freelancer groups, most jobs to least within each group
    const dispatcherGroup = allDispatchers
        .filter(name => DISPATCHER_STAFF.includes(name))
        .sort((a, b) => totalFor(b) - totalFor(a));
    const freelancerGroup = allDispatchers
        .filter(name => !DISPATCHER_STAFF.includes(name))
        .sort((a, b) => totalFor(b) - totalFor(a));

    let totalInProgress = 0;
    let totalCompleted = 0;
    let totalFailed = 0;
    let rowIdx = 0;

    const renderGroupLabel = (label) => {
        tableBody.insertAdjacentHTML('beforeend', `
            <tr class="table-light">
                <td colspan="4" style="font-weight:700; text-transform:uppercase; font-size:0.8rem; letter-spacing:0.05em; color:#475569;">${label}</td>
            </tr>
        `);
    };

    const renderDispatcherRow = (dispatcher) => {
        const d = data[dispatcher];
        const inProgressCount = d.inProgress.length;
        const completedCount = d.completed.length;
        const failedCount = d.failed.length;

        totalInProgress += inProgressCount;
        totalCompleted += completedCount;
        totalFailed += failedCount;

        const dispatcherCollapseId = `dispatcher-collapse-${rowIdx++}`;

        // Dispatcher summary row
        tableBody.insertAdjacentHTML('beforeend', `
            <tr data-bs-toggle="collapse" data-bs-target="#${dispatcherCollapseId}" style="cursor:pointer; background-color:#f8f9fa;">
                <td>${dispatcher}</td>
                <td>In Progress ${createBadge(inProgressCount, 'info')}</td>
                <td>Completed ${createBadge(completedCount, 'success')}</td>
                <td>Failed ${createBadge(failedCount, 'danger')}</td>
            </tr>
        `);

        // Dispatcher-level collapse row containing the statuses
        let statusRows = '';

        // In Progress
        if (inProgressCount > 0) {
            const statusCollapseId = `${dispatcherCollapseId}-inprogress`;
            statusRows += `
                <tr data-bs-toggle="collapse" data-bs-target="#${statusCollapseId}" style="cursor:pointer; background-color:#e9f5ff;">
                    <td colspan="4">In Progress Jobs ${createBadge(inProgressCount, 'info')}</td>
                </tr>
                <tr class="collapse" id="${statusCollapseId}">
                    <td colspan="4" style="padding:0;">
                        <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-0">
                            <thead>
                                <tr>
                                    <th>Tracking Number</th>
                                    <th>Product</th>
                                    <th>Job Method</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${d.inProgress.map(job => `
                                    <tr>
                                        <td class="track-no">${job.doTrackingNumber || '-'}</td>
                                        <td>${job.product || '-'}</td>
                                        <td>${job.jobMethod || '-'}</td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                        </div>
                    </td>
                </tr>
            `;
        }

        // Completed
        if (completedCount > 0) {
            const statusCollapseId = `${dispatcherCollapseId}-completed`;
            statusRows += `
                <tr data-bs-toggle="collapse" data-bs-target="#${statusCollapseId}" style="cursor:pointer; background-color:#e6f4ea;">
                    <td colspan="4">Completed Jobs ${createBadge(completedCount, 'success')}</td>
                </tr>
                <tr class="collapse" id="${statusCollapseId}">
                    <td colspan="4" style="padding:0;">
                        <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-0">
                            <thead>
                                <tr>
                                    <th>Tracking Number</th>
                                    <th>Product</th>
                                    <th>Job Method</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${d.completed.map(job => `
                                    <tr>
                                        <td class="track-no">${job.doTrackingNumber || '-'}</td>
                                        <td>${job.product || '-'}</td>
                                        <td>${job.jobMethod || '-'}</td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                        </div>
                    </td>
                </tr>
            `;
        }

        // Failed
        if (failedCount > 0) {
            const statusCollapseId = `${dispatcherCollapseId}-failed`;
            statusRows += `
                <tr data-bs-toggle="collapse" data-bs-target="#${statusCollapseId}" style="cursor:pointer; background-color:#fdecea;">
                    <td colspan="4">Failed Jobs ${createBadge(failedCount, 'danger')}</td>
                </tr>
                <tr class="collapse" id="${statusCollapseId}">
                    <td colspan="4" style="padding:0;">
                        <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-0">
                            <thead>
                                <tr>
                                    <th>Tracking Number</th>
                                    <th>Product</th>
                                    <th>Job Method</th>
                                    <th>Reason</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${d.failed.map(job => `
                                    <tr>
                                        <td class="track-no">${job.doTrackingNumber || '-'}</td>
                                        <td>${job.product || '-'}</td>
                                        <td>${job.jobMethod || '-'}</td>
                                        <td>${job.reason || '-'}</td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                        </div>
                    </td>
                </tr>
            `;
        }

        tableBody.insertAdjacentHTML('beforeend', `
            <tr class="collapse" id="${dispatcherCollapseId}">
                <td colspan="4" style="padding:0;">
                    <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <tbody>${statusRows}</tbody>
                    </table>
                    </div>
                </td>
            </tr>
        `);
    };

    if (dispatcherGroup.length > 0) {
        renderGroupLabel('Dispatchers');
        dispatcherGroup.forEach(renderDispatcherRow);
    }
    if (freelancerGroup.length > 0) {
        renderGroupLabel('Freelancers');
        freelancerGroup.forEach(renderDispatcherRow);
    }

    // Grand total row (sums both groups)
    tableBody.insertAdjacentHTML('beforeend', `
        <tr class="table-secondary fw-bold" style="position: sticky; bottom: 0; background-color: #f1f1f1;">
            <td>Grand Total</td>
            <td>In Progress: ${totalInProgress}</td>
            <td>Completed: ${totalCompleted}</td>
            <td>Failed: ${totalFailed}</td>
        </tr>
    `);
}

// Initial load, so the dispatcher summary cards are populated without needing to open the tab
document.getElementById('completed-jobs-date-picker').value = moment().format('YYYY-MM-DD');
loadCompletedJobs();

// Event Listeners
