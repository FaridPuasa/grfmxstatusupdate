        function trackCount(map) {
            let total = 0;
            Object.keys(map).forEach(location => {
                Object.keys(map[location]).forEach(product => {
                    Object.keys(map[location][product]).forEach(area => {
                        total += map[location][product][area].length;
                    });
                });
            });
            return total;
        }
        function locationCount(map, location) {
            if (!map[location]) return 0;
            let total = 0;
            Object.keys(map[location]).forEach(product => {
                Object.keys(map[location][product]).forEach(area => {
                    total += map[location][product][area].length;
                });
            });
            return total;
        }
        function methodCount(map, filterFn) {
            let total = 0;
            Object.keys(map).forEach(product => {
                Object.keys(map[product]).forEach(method => {
                    const arr = map[product][method];
                    total += filterFn ? arr.filter(filterFn).length : arr.length;
                });
            });
            return total;
        }
        const kpi = {
            current: trackCount(currentMap),
            warehouseK1: locationCount(currentMap, 'Warehouse K1'),
            warehouseK2: locationCount(currentMap, 'Warehouse K2'),
            plannedSelfCollect: methodCount(plannedSelfCollectMap),
            urgent: methodCount(urgentMap),
            overdue: methodCount(overdueMap),
            maxAttempt: methodCount(maxAttemptMap, o => o.age < 30),
            archived: methodCount(archivedMap)
        };
