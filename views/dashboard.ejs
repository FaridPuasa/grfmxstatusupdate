/* ===== Dashboard redesign ===== */
:root {
    --gr-warehouse: #475569;
    --gr-progress: #16a34a;
    --gr-neworders: #2563eb;
    --gr-bg: #f3f5f9;
    --gr-radius: 14px;
}

html {
    scroll-behavior: smooth;
}

body {
    background: var(--gr-bg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

h1.text-center {
    font-weight: 700;
    letter-spacing: -0.02em;
}

/* KPI summary strip */
.kpi-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
}

.kpi-tile {
    flex: 1 1 130px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.65rem 0.9rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.kpi-tile .kpi-icon {
    font-size: 1.3rem;
    line-height: 1;
    margin-bottom: 0.25rem;
    color: #94a3b8;
}

.kpi-tile .kpi-value {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.1;
    color: #1e293b;
}

.kpi-tile .kpi-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
    margin-top: 0.15rem;
}

.kpi-tile.kpi-warn .kpi-value, .kpi-tile.kpi-warn .kpi-icon { color: #b45309; }
.kpi-tile.kpi-danger .kpi-value, .kpi-tile.kpi-danger .kpi-icon { color: #b91c1c; }
.kpi-tile.kpi-dark .kpi-value, .kpi-tile.kpi-dark .kpi-icon { color: #111827; }
.kpi-tile.kpi-muted .kpi-value, .kpi-tile.kpi-muted .kpi-icon { color: #6b7280; }
.kpi-tile.kpi-info .kpi-value, .kpi-tile.kpi-info .kpi-icon { color: #0369a1; }
.kpi-tile.kpi-success .kpi-value, .kpi-tile.kpi-success .kpi-icon { color: #15803d; }

/* Dispatcher/freelancer summary cards (In Progress / Completed section) */
.dispatcher-summary-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
}

.dispatcher-card {
    flex: 1 1 170px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-left: 3px solid var(--gr-progress);
    border-radius: 12px;
    padding: 0.65rem 0.9rem;
    text-align: center;
}

.dispatcher-card-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: #1e293b;
    line-height: 1.2;
}

.dispatcher-card-name .bi {
    margin-right: 0.3rem;
    color: var(--gr-progress);
}

/* Dispatcher (in-house staff) vs Freelancer — distinct accent colors */
.dispatcher-card.type-freelancer {
    border-left-color: #7c3aed;
}

.dispatcher-card.type-freelancer .dispatcher-card-name .bi {
    color: #7c3aed;
}

.dispatcher-group-label {
    flex-basis: 100%;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #475569;
    margin: 0.5rem 0 0.1rem;
}

.dispatcher-group-label:first-child {
    margin-top: 0;
}

.dispatcher-group-label.type-dispatcher .bi { color: var(--gr-progress); }
.dispatcher-group-label.type-freelancer .bi { color: #7c3aed; }

.dispatcher-card-area {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
    margin: 0.1rem 0 0.5rem;
}

.dispatcher-card-stats {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: center;
}

.dispatcher-card-stats .badge {
    font-weight: 600;
}

.dispatcher-card-stats .badge .bi {
    margin-right: 0.2rem;
}

/* Card polish */
.card {
    border: 1px solid #e5e7eb;
    border-radius: var(--gr-radius);
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    overflow: hidden;
}

.card > .card-header:first-child {
    border-top-left-radius: var(--gr-radius);
    border-top-right-radius: var(--gr-radius);
}

#section-warehouse > .card-header { border-left: 4px solid var(--gr-warehouse); }
#section-progress > .card-header { border-left: 4px solid var(--gr-progress); }
#section-neworders > .card-header { border-left: 4px solid var(--gr-neworders); }

.toggle-header {
    transition: background 0.12s ease;
}

.toggle-header:hover {
    background: rgba(0, 0, 0, 0.03);
}

/* Rotate the collapse caret based on aria-expanded, set automatically by Bootstrap */
.bi-caret-down-fill {
    display: inline-block;
    transition: transform 0.2s ease;
}

.toggle-header[aria-expanded="true"] .bi-caret-down-fill,
i.bi-caret-down-fill[aria-expanded="true"] {
    transform: rotate(180deg);
}

/* Section Show/Hide toggle — stretched full-width, bold, centered */
.toggle-section-btn {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    padding: 0.55rem 1rem;
}

.toggle-section-btn .bi {
    transition: transform 0.2s ease;
}

.toggle-section-btn[aria-expanded="true"] .bi {
    transform: rotate(180deg);
}

/* Tables: sticky header + zebra striping within their own scroll area */
.table-responsive {
    max-height: 480px;
}

.table-responsive thead th {
    position: sticky;
    top: 0;
    z-index: 1;
    background: #f8fafc;
    box-shadow: inset 0 -1px 0 #e2e8f0;
}

.table-hover tbody tr:hover,
.table tbody tr:hover {
    background-color: rgba(37, 99, 235, 0.04);
}

/* Copy/Export toolbar */
.section-toolbar {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
}

.toolbar-btn {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    white-space: nowrap;
}

/* Back to top */
#backToTopBtn {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 1040;
    display: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    padding: 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}
