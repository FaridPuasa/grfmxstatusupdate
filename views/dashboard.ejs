    <ul class="nav nav-tabs mb-3" id="deliveryTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="activejobs-tab" data-bs-toggle="tab" data-bs-target="#activejobs-content" type="button" role="tab" aria-controls="activejobs-content" aria-selected="true">
                Active Jobs
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="codbt-tab" data-bs-toggle="tab" data-bs-target="#codbt-content" type="button" role="tab" aria-controls="codbt-content" aria-selected="false">
                COD/BT Collected
            </button>
        </li>
        <li class="nav-item" role="presentation">
    <button class="nav-link" id="completed-jobs-tab" data-bs-toggle="tab" data-bs-target="#completed-jobs" type="button" role="tab" aria-controls="completed-jobs" aria-selected="false">
        Completed Jobs
    </button>
</li>
    </ul>

    <div class="tab-content">
        <!-- Active Jobs Tab -->
        <!-- Active Jobs Tab -->
<!-- Active Jobs Tab -->
<div class="tab-pane fade show active" id="activejobs-content" role="tabpanel" aria-labelledby="activejobs-tab">
    <% if (Object.keys(deliveriesMap).length === 0) { %>
        <p class="text-center text-muted">No jobs found.</p>
    <% } else { %>
        <% Object.keys(deliveriesMap).forEach((date, dateIndex) => {
            // Calculate total jobs for badge
            let dateCount = 0;
            Object.keys(deliveriesMap[date]).forEach(assignee => {
                if (assignee === 'Selfcollect') {
                    // Sum all job method counts for Selfcollect
                    const statuses = deliveriesMap[date][assignee].__statuses || {};
                    Object.keys(statuses).forEach(st => {
                        dateCount += statuses[st].length;
                    });
                } else {
                    Object.keys(deliveriesMap[date][assignee].__products).forEach(product => {
                        dateCount += deliveriesMap[date][assignee].__products[product].length;
                    });
                }
            });
        %>
            <div class="card my-3">
                <div class="card-header" style="padding: 0.75rem 1rem;">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="toggle-header" style="cursor: pointer; flex-grow: 1;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>">
                            <strong><%= date %></strong>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-primary"><%= dateCount %> jobs</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                    data-target="#collapse-activejobs-<%= dateIndex %>"
                                    data-section-name="Active Jobs - <%= date %>">📋 Copy</button>
                            <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                    data-target="#collapse-activejobs-<%= dateIndex %>"
                                    data-section-name="Active Jobs - <%= date %>">📊 Excel</button>
                            <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>"></i>
                        </div>
                    </div>
                </div>
                <div class="collapse" id="collapse-activejobs-<%= dateIndex %>">
                    <div class="card-body p-0">
                        <% 
                            // Separate Selfcollect and other dispatchers
                            const otherDispatchers = [];
                            let selfcollectDispatcher = null;
                            Object.keys(deliveriesMap[date]).forEach(assignee => {
                                if (assignee === 'Selfcollect') {
                                    selfcollectDispatcher = deliveriesMap[date][assignee];
                                } else {
                                    otherDispatchers.push({ name: assignee, data: deliveriesMap[date][assignee] });
                                }
                            });

                            // Sort other dispatchers alphabetically
                            otherDispatchers.sort((a,b) => a.name.localeCompare(b.name));

                            // Render other dispatchers first
                            otherDispatchers.forEach((disp, assignIndex) => {
                                let assigneeCount = 0;
                                Object.keys(disp.data.__products).forEach(product => {
                                    assigneeCount += disp.data.__products[product].length;
                                });
                        %>
                            <div class="card my-2 mx-3">
                                <div class="card-header" style="padding: 0.75rem 1rem;">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="toggle-header" style="cursor: pointer; flex-grow: 1;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>">
                                            <strong><%= disp.name %> <span style="font-weight:normal;">(<%= disp.data.__areas ? disp.data.__areas.join(', ') : '' %>)</span></strong>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge bg-success"><%= assigneeCount %> jobs</span>
                                            <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                                    data-target="#collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>"
                                                    data-section-name="<%= disp.name %> (<%= date %>)">📋 Copy</button>
                                            <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                                    data-target="#collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>"
                                                    data-section-name="<%= disp.name %> (<%= date %>)">📊 Excel</button>
                                            <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="collapse" id="collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>">
                                    <div class="card-body p-0">
                                        <% Object.keys(disp.data.__products).forEach((product, prodIndex) => {
                                            const productCount = disp.data.__products[product].length;
                                        %>
                                            <div class="card my-2 mx-3">
                                                <div class="card-header" style="padding: 0.75rem 1rem;">
                                                    <div class="d-flex align-items-center justify-content-between">
                                                        <div class="toggle-header" style="cursor: pointer; flex-grow: 1;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>-<%= prodIndex %>">
                                                            <strong><%= product.toUpperCase() %></strong>
                                                        </div>
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="badge bg-warning text-dark"><%= productCount %> jobs</span>
                                                            <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                                                    data-target="#collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>-<%= prodIndex %>"
                                                                    data-section-name="<%= disp.name %> - <%= product.toUpperCase() %>">📋 Copy</button>
                                                            <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                                                    data-target="#collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>-<%= prodIndex %>"
                                                                    data-section-name="<%= disp.name %> - <%= product.toUpperCase() %>">📊 Excel</button>
                                                            <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>-<%= prodIndex %>"></i>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="collapse" id="collapse-activejobs-<%= dateIndex %>-<%= assignIndex %>-<%= prodIndex %>">
                                                    <div class="card-body p-0">
                                                        <div class="table-responsive">
                                                        <table class="table table-sm table-bordered mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th>Tracking Number</th>
                                                                    <th>Area</th>
                                                                    <th>Name</th>
                                                                    <th>Main Phone</th>
                                                                    <th>Go Rush Remark</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% disp.data.__products[product].forEach(order => { %>
                                                                    <tr>
                                                                        <td class="track-no"><%= order.doTrackingNumber %></td>
                                                                        <td><%= order.area || '-' %></td>
                                                                        <td><%= order.receiverName %></td>
                                                                        <td><%= order.receiverPhoneNumber %></td>
                                                                        <td><%= order.grRemark %></td>
                                                                    </tr>
                                                                <% }) %>
                                                            </tbody>
                                                        </table>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>

                        <% if (selfcollectDispatcher) { 
                            // Get job methods for Selfcollect in sorted order
                            const statuses = selfcollectDispatcher.__statuses || {};
                            const jobMethodsOrder = ['Self Collect', 'Drop Off'];
                            const availableJobMethods = jobMethodsOrder.filter(m => statuses[m] && statuses[m].length > 0);
                        %>
                            <div class="card my-2 mx-3">
                                <div class="card-header" style="padding: 0.75rem 1rem;">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="toggle-header" style="cursor: pointer; flex-grow: 1;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>-selfcollect">
                                            <strong>Selfcollect <span style="font-weight:normal;">(<%= availableJobMethods.join(', ') %>)</span></strong>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge bg-success">
                                                <%= availableJobMethods.reduce((acc, method) => acc + statuses[method].length, 0) %> jobs
                                            </span>
                                            <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                                    data-target="#collapse-activejobs-<%= dateIndex %>-selfcollect"
                                                    data-section-name="Selfcollect (<%= date %>)">📋 Copy</button>
                                            <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                                    data-target="#collapse-activejobs-<%= dateIndex %>-selfcollect"
                                                    data-section-name="Selfcollect (<%= date %>)">📊 Excel</button>
                                            <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>-selfcollect"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="collapse" id="collapse-activejobs-<%= dateIndex %>-selfcollect">
                                    <div class="card-body p-0">
                                        <% availableJobMethods.forEach((jobMethod, statusIndex) => {
                                            const jobs = statuses[jobMethod];
                                        %>
                                            <div class="card my-2 mx-3">
                                                <div class="card-header" style="padding: 0.75rem 1rem;">
                                                    <div class="d-flex align-items-center justify-content-between">
                                                        <div class="toggle-header" style="cursor: pointer; flex-grow: 1;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>-selfcollect-<%= statusIndex %>">
                                                            <strong><%= jobMethod %></strong>
                                                        </div>
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="badge bg-success"><%= jobs.length %> jobs</span>
                                                            <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                                                    data-target="#collapse-activejobs-<%= dateIndex %>-selfcollect-<%= statusIndex %>"
                                                                    data-section-name="Selfcollect - <%= jobMethod %>">📋 Copy</button>
                                                            <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                                                    data-target="#collapse-activejobs-<%= dateIndex %>-selfcollect-<%= statusIndex %>"
                                                                    data-section-name="Selfcollect - <%= jobMethod %>">📊 Excel</button>
                                                            <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#collapse-activejobs-<%= dateIndex %>-selfcollect-<%= statusIndex %>"></i>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="collapse" id="collapse-activejobs-<%= dateIndex %>-selfcollect-<%= statusIndex %>">
                                                    <div class="card-body p-0">
                                                        <div class="table-responsive">
                                                        <table class="table table-sm table-bordered mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th>Tracking Number</th>
                                                                    <th>Name</th>
                                                                    <th>Main Phone</th>
                                                                    <th>Go Rush Remark</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% jobs.forEach(order => { %>
                                                                    <tr>
                                                                        <td class="track-no"><%= order.doTrackingNumber %></td>
                                                                        <td><%= order.receiverName %></td>
                                                                        <td><%= order.receiverPhoneNumber %></td>
                                                                        <td><%= order.grRemark %></td>
                                                                    </tr>
                                                                <% }) %>
                                                            </tbody>
                                                        </table>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

