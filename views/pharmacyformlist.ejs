<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pharmacy Form List</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/mobile-center.css">
    <!-- Include DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.16.9/dist/xlsx.full.min.js"></script>
    <style>
        th {
            background-color: #f2f2f2;
            font-size: 15px;
            text-align: center;
        }

        td {
            font-size: 15px;
            text-align: center;
        }

        table {
            width: 90%;
            margin: 0 auto;
            vertical-align: middle;
        }

    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <main class="container mt-4">
        <div class="card my-4">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0"><i class="bi bi-clipboard-data"></i> Pharmacy Form List</h5>
                <a href="/templates/PRINT%20PHARMACY%20ORDERS%20TEMPLATE.docx" class="btn btn-light btn-sm"
                    download="PRINT PHARMACY ORDERS.docx"><i class="bi bi-download"></i> Download Template</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped" id="formTable">
                        <thead class="table-primary">
                            <tr>
                                <th class="header">Form Name</th>
                                <th class="header">Form For</th>
                                <th class="header">Created By</th>
                                <th class="header">Form Date</th>
                                <th class="header">Batch No</th>
                                <th class="header">No. of Forms</th>
                                <th class="header">First No.</th>
                                <th class="header">Last No.</th>
                                <th class="header">Tracking Numbers</th>
                                <th class="header">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% forms.forEach(function(form) { %>
                                <tr>
                                    <td><%= form.formName %></td>
                                    <td><%= form.formFor %></td>
                                    <td><%= form.createdBy %></td>
                                    <td><%= form.formDateDisplay %></td>
                                    <td><%= form.batchNo %></td>
                                    <td><%= form.numberOfForms %></td>
                                    <td><%= form.firstNo %></td>
                                    <td><%= form.lastNo %></td>
                                    <td><%= form.trackingNumbers %></td>
                                    <td>
                                        <button class="btn btn-primary btn-sm" onclick="viewForm('<%= form._id %>')"><i class="bi bi-eye"></i> View</button>
                                        <button class="btn btn-danger btn-sm" onclick="confirmDelete('<%= form._id %>')"><i class="bi bi-trash"></i> Delete</button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div class="modal fade" id="viewFormModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 id="viewFormTitle" class="modal-title"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped" id="viewFormTable">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Form Number</th>
                                    <th>Tracking No.</th>
                                    <th>Name</th>
                                    <th>Address</th>
                                    <th>Area</th>
                                    <th>BruHIMS No</th>
                                    <th>IC No</th>
                                    <th>Phone No</th>
                                    <th>Additional Phone No</th>
                                    <th>Remark</th>
                                    <th>Code</th>
                                </tr>
                            </thead>
                            <tbody id="viewFormTableBody"></tbody>
                        </table>
                    </div>
                    <div class="text-center mt-3">
                        <button id="viewExportExcelButton" class="btn btn-success">Export Excel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Loaded here (not <head>) because Bootstrap 5.0.0-alpha1's JS bundle references
         document.body during evaluation, which is null if the script runs before <body> exists. -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#formTable').DataTable({
                "iDisplayLength": 10,
                "order": [], // preserve the server-side sort (formDate newest to oldest)
                "columnDefs": [
                    { targets: 8, visible: false, searchable: true } // Tracking Numbers: searchable but hidden
                ]
            });
        });

        async function confirmDelete(formId) {
            const ok = await showConfirm("Are you sure you want to delete this record?");
            if (!ok) return;
            window.location.href = "/deletePharmacyFormBatch/" + formId;
        }

        let currentViewFormName = '';

        function makeCell(text) {
            const td = document.createElement('td');
            td.textContent = text || '';
            return td;
        }

        function viewForm(id) {
            fetch('/api/pharmacyformlist/view/' + id)
                .then(function (res) {
                    if (!res.ok) throw new Error('Failed to load');
                    return res.json();
                })
                .then(function (data) {
                    currentViewFormName = data.formName;
                    document.getElementById('viewFormTitle').textContent = data.formName;

                    const formDate = new Date(data.formDate);
                    const dd = String(formDate.getDate()).padStart(2, '0');
                    const mm = String(formDate.getMonth() + 1).padStart(2, '0');
                    const yyyy = String(formDate.getFullYear());
                    const dateStr = dd + '.' + mm + '.' + yyyy;

                    const tbody = document.getElementById('viewFormTableBody');
                    tbody.innerHTML = '';

                    data.orders.forEach(function (order) {
                        const tr = document.createElement('tr');
                        tr.appendChild(makeCell(dateStr));
                        tr.appendChild(makeCell(order.formNumber));
                        tr.appendChild(makeCell(order.doTrackingNumber));
                        tr.appendChild(makeCell(order.receiverName));
                        tr.appendChild(makeCell(order.receiverAddress));
                        tr.appendChild(makeCell(order.area));
                        tr.appendChild(makeCell(order.patientNumber));
                        const icCell = makeCell(order.icPassNum);
                        icCell.setAttribute('style', "mso-number-format:'\\@';");
                        tr.appendChild(icCell);
                        tr.appendChild(makeCell(order.receiverPhoneNumber));
                        tr.appendChild(makeCell(order.additionalPhoneNumber));
                        tr.appendChild(makeCell(order.remarks));
                        tr.appendChild(makeCell(order.deliveryTypeCode));
                        tbody.appendChild(tr);
                    });

                    bootstrap.Modal.getOrCreateInstance(document.getElementById('viewFormModal')).show();
                })
                .catch(function (err) {
                    console.error(err);
                    showToast('Failed to load form data.', 'error');
                });
        }

        document.getElementById('viewExportExcelButton').addEventListener('click', function () {
            const wb = XLSX.utils.book_new();
            const table = document.querySelector('#viewFormTable');
            const ws = XLSX.utils.table_to_sheet(table, { raw: true });

            const range = XLSX.utils.decode_range(ws['!ref']);
            for (let R = range.s.r + 1; R <= range.e.r; ++R) {
                // Force Date column (0) to plain text so Excel doesn't reinterpret "dd.mm.yyyy" as a date/time value
                const dateCellRef = XLSX.utils.encode_cell({ c: 0, r: R });
                const dateCell = ws[dateCellRef];
                if (dateCell && typeof dateCell.v !== 'undefined') {
                    dateCell.t = 's';
                    dateCell.v = dateCell.v.toString();
                }

                // Force IC No column (7) to text and keep leading zeros
                const icCellRef = XLSX.utils.encode_cell({ c: 7, r: R });
                const icCell = ws[icCellRef];
                if (icCell && typeof icCell.v !== 'undefined') {
                    icCell.t = 's';
                    icCell.v = icCell.v.toString().padStart(8, '0');
                }
            }

            XLSX.utils.book_append_sheet(wb, ws, 'Sheet1');
            XLSX.writeFile(wb, (currentViewFormName || 'PharmacyForm') + '.xlsx');
        });
    </script>
</body>

</html>
