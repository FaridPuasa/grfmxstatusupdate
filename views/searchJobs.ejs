      } else {
        // Reset colReorder to default order
        dt.colReorder.reset();
        
        // Show all columns
        dt.columns().visible(true);
        
        // Reset all column headers to original
        resetColumnHeaders(dt);
        
        // Reset status mapping
        dt.rows().every(function() {
  const data = this.data();
  if (this.nodes().length) {
    // Find and reset all status cells
    const cells = $(this.nodes()).find('td');
    for (let i = 0; i < cells.length; i++) {
      const cellText = $(cells[i]).text();
      // Check for any of the mapped values
      if (cellText === 'POD' || cellText === 'RTS' || cellText === 'UNDEL') {
        $(cells[i]).text(data.currentStatus || '');
        break;
      }
    }
  }
});
        
        gdexView = false;
      }
      dt.draw();
    } catch (e) {
      console.log('Error in GDEX button action', e);
    }
  }
}
