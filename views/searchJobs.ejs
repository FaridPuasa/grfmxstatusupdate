<script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.2.2/js/buttons.colVis.min.js"></script>
<script src="https://cdn.datatables.net/colreorder/1.5.6/js/dataTables.colReorder.min.js"></script>
<script>
// --- Get user role/email from server-side injected variables (Reorder button gating) ---
const currentUserRole = '<%= user ? user.role : "" %>';
const currentUserEmail = '<%= user ? user.email : "" %>';
const allowedRolesForReorder = ['admin', 'cs'];
const allowedEmailsForReorder = ['operation2@globex.com.bn', 'operation3@globex.com.bn'];
const canReorder = allowedRolesForReorder.includes(currentUserRole) || allowedEmailsForReorder.includes(currentUserEmail);

// --- Brunei date/time formatting (DD.MM.YYYY, 12-hour AM/PM) ---
// Source data is inconsistent: some strings are date-only ("2026-07-22"), some
// carry an explicit UTC offset/Z (genuine instants that need converting to
// Brunei time, UTC+8, no DST), and some are naive datetimes with no offset at
// all (already recorded as Brunei wall-clock time). Detect which case we're in
// from the raw string rather than assuming one format everywhere.
function parseFlexibleDate(raw) {
  if (raw === null || raw === undefined) return null;
  const str = String(raw).trim();
  if (!str) return null;

  // Date-only, no time component
  if (/^\d{4}-\d{2}-\d{2}$/.test(str)) {
    const d = moment(str, 'YYYY-MM-DD', true);
    return d.isValid() ? { moment: d, hasTime: false } : null;
  }

  const hasOffset = /(Z|[+-]\d{2}:?\d{2})$/.test(str);
  let d;
  if (hasOffset) {
    d = moment.parseZone(str).utcOffset(8);
  } else {
    d = moment(str, [moment.ISO_8601, 'YYYY-MM-DD HH:mm:ss', 'DD/MM/YYYY HH:mm:ss', 'MM/DD/YYYY HH:mm:ss'], true);
    if (!d.isValid()) d = moment(str); // last-resort loose parse
  }

  return (d && d.isValid()) ? { moment: d, hasTime: true } : null;
}

function formatBruneiDateTime(raw) {
  const parsed = parseFlexibleDate(raw);
  if (!parsed) return raw === null || raw === undefined ? '' : String(raw).trim(); // unparseable -> show the raw value rather than hide it
  return parsed.hasTime ? parsed.moment.format('DD.MM.YYYY hh:mm A') : parsed.moment.format('DD.MM.YYYY');
}

function formatBruneiDate(raw) {
  const parsed = parseFlexibleDate(raw);
  if (!parsed) return raw === null || raw === undefined ? '' : String(raw).trim();
  return parsed.moment.format('DD.MM.YYYY');
}

function escapeHtml(str) {
  return $('<div>').text(str === null || str === undefined ? '' : str).html();
}

// --- Tracking history timeline (History button / modal) ---
const STATUS_META = {
  'info received': { icon: 'bi-info-circle-fill', color: '#0d6efd' },
  'on hold': { icon: 'bi-pause-circle-fill', color: '#ffc107' },
  'queued for warehouse': { icon: 'bi-hourglass-split', color: '#fd7e14' },
  'at warehouse': { icon: 'bi-building', color: '#6610f2' },
  'in sorting area': { icon: 'bi-diagram-3-fill', color: '#6f42c1' },
  'out for delivery': { icon: 'bi-truck', color: '#0dcaf0' },
  'self collect': { icon: 'bi-person-check-fill', color: '#20c997' },
  'completed': { icon: 'bi-check-circle-fill', color: '#198754' },
  'return to warehouse': { icon: 'bi-arrow-return-left', color: '#fd7e14' },
  'failed delivery': { icon: 'bi-x-circle-fill', color: '#dc3545' },
  'cancelled': { icon: 'bi-slash-circle-fill', color: '#dc3545' },
  'disposed': { icon: 'bi-trash-fill', color: '#6c757d' },
  'return': { icon: 'bi-arrow-repeat', color: '#a52a2a' },
  'pod resent to gdex': { icon: 'bi-send-fill', color: '#0d6efd' },
  'custom clearing': { icon: 'bi-shield-check', color: '#6610f2' }
};
function getStatusMeta(status) {
  const key = (status || '').toLowerCase().trim();
  return STATUS_META[key] || { icon: 'bi-record-circle', color: '#6c757d' };
}

function renderHistoryTimeline(history, currentStatus) {
  const $container = $('#historyTimeline');
  $container.empty();

  if (!history || !history.length) {
    $container.html('<p class="text-muted text-center py-3 mb-0">No tracking history available for this job.</p>');
    return;
  }

  // Data is stored oldest -> newest; show newest first, like a courier tracker.
  const entries = history.slice().reverse();

  entries.forEach(function(entry, idx) {
    const meta = getStatusMeta(entry.statusHistory);
    const isCurrent = idx === 0;
    const dateStr = formatBruneiDateTime(entry.dateUpdated);

    let detailsHtml = '';
    if (entry.updatedBy) {
      detailsHtml += `<div class="tracker-meta"><i class="bi bi-person-fill"></i> Updated by: ${escapeHtml(entry.updatedBy)}</div>`;
    }
    if (entry.lastAssignedTo) {
      detailsHtml += `<div class="tracker-meta"><i class="bi bi-person-badge-fill"></i> Assigned to: ${escapeHtml(entry.lastAssignedTo)}</div>`;
    }
    if (entry.reason) {
      detailsHtml += `<div class="tracker-meta"><i class="bi bi-chat-left-text-fill"></i> ${escapeHtml(entry.reason)}</div>`;
    }
    if (entry.lastLocation) {
      detailsHtml += `<div class="tracker-meta"><i class="bi bi-geo-alt-fill"></i> ${escapeHtml(entry.lastLocation)}</div>`;
    }

    const itemHtml = `
      <div class="tracker-item${isCurrent ? ' current' : ''}">
        <div class="tracker-icon" style="background:${meta.color};">
          <i class="bi ${meta.icon}"></i>
        </div>
        <div class="tracker-card">
          <div class="d-flex justify-content-between align-items-start flex-wrap">
            <span class="tracker-status" style="color:${meta.color};">${escapeHtml(entry.statusHistory || 'Unknown')}</span>
            ${isCurrent ? '<span class="badge bg-primary current-badge">Current</span>' : ''}
          </div>
          <div class="tracker-meta"><i class="bi bi-calendar-event"></i> ${dateStr || '&mdash;'}</div>
          ${detailsHtml}
        </div>
      </div>`;
    $container.append(itemHtml);
  });
}

$(document).ready(function() {
  // Initialize Select2
  $('.select2').select2({ width: '100%' });

  let manifestView = false;
  let gdexView = false;

  // Store original column headers (including Shipment Received)
  const originalHeaders = [
    'S/N', 'Action', 'Go Rush Remark', 'Customer Remark', 'Go Rush Tracking No.',
    'Product', 'Job Status', 'Latest Location', 'Age (Days)', 'Job Method',
    'Job Date', 'Assigned To', 'Attempt', 'Payment Method', 'Payment Amount',
    'Name', 'Main Phone No.', 'Additional Phone No.', 'Customer Address',
    'Postal Code', 'Area', 'Job Created Date', 'MAWB No.', 'IC/Passport No.',
    'Patient No.', 'Item Description', 'Quantity', 'Invoice/Item Screenshot',
    'Original Tracking No.', 'Item Original Price', 'Weight (KG)', 'No. of Packages',
    'Handling Charge', 'Shipment Received'
  ];

  // Function to safely update column header
  function safeUpdateHeader(dt, columnIndex, newHeader) {
    try {
      if (dt.column(columnIndex) && dt.column(columnIndex).header()) {
        dt.column(columnIndex).header().innerHTML = newHeader;
      }
    } catch (e) {
      console.log('Error updating header for column', columnIndex, e);
    }
  }

  // Function to reset all column headers to original
  function resetColumnHeaders(dt) {
    try {
      for (let i = 0; i < originalHeaders.length; i++) {
        safeUpdateHeader(dt, i, originalHeaders[i]);
      }
    } catch (e) {
      console.log('Error resetting column headers', e);
    }
  }

  // Function to update column headers for GDEX view
  function setGDEXHeaders(dt) {
    try {
      safeUpdateHeader(dt, 0, 'Bil');
      safeUpdateHeader(dt, 4, 'Consignment Note');
      safeUpdateHeader(dt, 15, 'Receiver name');
      safeUpdateHeader(dt, 30, 'Weight (KG)');
      safeUpdateHeader(dt, 32, 'Service Charge');
      safeUpdateHeader(dt, 33, 'Shipment Received');
      safeUpdateHeader(dt, 22, 'MAWB');
      safeUpdateHeader(dt, 6, 'Latest Scan');
    } catch (e) {
      console.log('Error setting GDEX headers', e);
    }
  }

  // Function to update column headers for Manifest view
  function setManifestHeaders(dt) {
    try {
      safeUpdateHeader(dt, 0, 'S/N');
      safeUpdateHeader(dt, 4, 'Go Rush Tracking No.');
      safeUpdateHeader(dt, 15, 'Name');
      safeUpdateHeader(dt, 16, 'Main Phone No.');
      safeUpdateHeader(dt, 18, 'Customer Address');
      safeUpdateHeader(dt, 19, 'Postal Code');
      safeUpdateHeader(dt, 30, 'Weight (KG)');
      safeUpdateHeader(dt, 31, 'No. of Packages');
      safeUpdateHeader(dt, 32, 'Handling Charge');
    } catch (e) {
      console.log('Error setting Manifest headers', e);
    }
  }

  // Function to reset all views
  function resetAllViews(dt) {
    try {
      dt.columns().visible(true);
      resetColumnHeaders(dt);
      dt.rows().every(function() {
        const data = this.data();
        if (this.nodes().length) {
          $(this.nodes()).find('td:eq(6)').text(data.currentStatus || '');
        }
      });
      dt.draw();
    } catch (e) {
      console.log('Error resetting views', e);
    }
  }

  // Initialize DataTable
  let table = $('#jobsTable').DataTable({
    scrollX: true,
    dom: 'lBfrtip',
    colReorder: true, // Enable colReorder
    buttons: [
      {
  extend: 'excelHtml5',
  text: '<i class="bi bi-file-earmark-excel"></i> Export Excel',
  exportOptions: {
    columns: ':visible',
    orthogonal: 'export', // This tells DataTables to use the 'export' type from render functions
    format: {
      body: function (data, row, column, node) {
        if (column === 0) return row + 1; // S/N column
        
        // For the Job Status column (column 6 in original, but we need to handle it dynamically)
        const headerText = $(node).closest('table').find('th').eq(column).text();
        if (headerText === 'Latest Scan' || headerText === 'Job Status') {
          // Get the row data
          const rowData = table.row(row).data();
          if (rowData) {
            const jobStatus = rowData.currentStatus || '';
            if (gdexView) {
              if (jobStatus === 'Completed') return 'POD';
              if (jobStatus === 'Return') return 'RTS';
              return 'UNDEL';
            }
          }
        }
        
        return data;
      }
    }
  },
  filename: function() {
    let filters = [];
    $('#searchForm').find('input[type="text"], textarea').each(function() {
      const val = $(this).val().trim();
      if (val) filters.push(val.replace(/[\s\/\\:*?"<>|]/g, '_'));
    });
    $('#searchForm').find('select.select2').each(function() {
      const val = $(this).val();
      if (val && val.length) filters.push(val.join('-').replace(/[\s\/\\:*?"<>|]/g, '_'));
    });
    const filterText = filters.length ? filters.join('_') : 'SearchJob';
    const today = moment().format('DD.MM.YYYY');
    const rowCount = table.rows({ filter: 'applied' }).data().length;
    
    // Add GDEX to filename if in that view
    const viewSuffix = gdexView ? '_GDEX' : '';
    return `${filterText}${viewSuffix}_${today}(${rowCount})`;
  }
},
      {
        extend: 'colvis',
        text: '<i class="bi bi-eye-slash"></i> Show/Hide Columns'
      },
      <% if (['finance', 'manager', 'admin'].includes(user.role)) { %>
      {
        text: '<i class="bi bi-receipt"></i> Manifest to Bill',
        action: function(e, dt, node, config) {
          try {
            if (!manifestView) {
              // Turn off GDEX view
              gdexView = false;
              
              // First reset everything to default
              dt.columns().visible(true);
              
              // Then hide non-manifest columns
              for (let i = 0; i < originalHeaders.length; i++) {
                if (![0, 4, 15, 16, 18, 19, 30, 31, 32].includes(i)) {
                  dt.column(i).visible(false);
                }
              }
              
              // Set manifest headers
              setManifestHeaders(dt);
              
              manifestView = true;
            } else {
              resetAllViews(dt);
              manifestView = false;
            }
            dt.draw();
          } catch (e) {
            console.log('Error in Manifest button action', e);
          }
        }
      },
      {
  text: '<i class="bi bi-truck"></i> GDEX Billing',
  action: function(e, dt, node, config) {
    try {
      if (!gdexView) {
        // Turn off Manifest view
        manifestView = false;
        
        // First, hide all columns
        dt.columns().visible(false);
        
        // Reorder columns using colReorder to the exact order you want
        // Original indices: [0, 4, 15, 30, 32, 33, 22, 6]
        dt.colReorder.order([0, 4, 15, 30, 32, 33, 22, 6]);
        
        // Now show the columns (they will appear in the reordered sequence)
        dt.column(0).visible(true);  // Bil (was S/N)
        dt.column(1).visible(true);  // Consignment Note (was Go Rush Tracking No.)
        dt.column(2).visible(true);  // Receiver name (was Name)
        dt.column(3).visible(true);  // Weight (KG)
        dt.column(4).visible(true);  // Service Charge (was Handling Charge)
        dt.column(5).visible(true);  // Shipment Received (was warehouseEntryDateTime)
        dt.column(6).visible(true);  // MAWB
        dt.column(7).visible(true);  // Latest Scan (was Job Status)
        
        // Update column headers
        dt.column(0).header().innerHTML = 'Bil';
        dt.column(1).header().innerHTML = 'Consignment Note';
        dt.column(2).header().innerHTML = 'Receiver name';
        dt.column(3).header().innerHTML = 'Weight (KG)';
        dt.column(4).header().innerHTML = 'Service Charge';
        dt.column(5).header().innerHTML = 'Shipment Received';
        dt.column(6).header().innerHTML = 'MAWB';
        dt.column(7).header().innerHTML = 'Latest Scan';
        
        // Update status mapping for Latest Scan column (now at position 7)
        dt.rows().every(function() {
          const data = this.data();
          if (this.nodes().length) {
            const jobStatus = data.currentStatus || '';
            let latestScan = 'UNDEL';
            if (jobStatus === 'Completed') {
              latestScan = 'POD';
            } else if (jobStatus === 'Return') {
              latestScan = 'RTS';
            }
            // Update the cell at the current position of the Job Status column
            // After reordering, we need to find which column index contains the currentStatus data
            const cells = $(this.nodes()).find('td');
            // The status should be in the last visible column (position 7)
            if (cells.length > 7) {
              $(cells[7]).text(latestScan);
            }
          }
        });
        
        gdexView = true;
      } else {
        // Reset colReorder to default order
        dt.colReorder.reset();
        
        // Show all columns
        dt.columns().visible(true);
        
        // Reset all column headers to original
        resetColumnHeaders(dt);
        
        // Reset status mapping
        dt.rows().every(function() {
  const data = this.data();
  if (this.nodes().length) {
    // Find and reset all status cells
    const cells = $(this.nodes()).find('td');
    for (let i = 0; i < cells.length; i++) {
      const cellText = $(cells[i]).text();
      // Check for any of the mapped values
      if (cellText === 'POD' || cellText === 'RTS' || cellText === 'UNDEL') {
        $(cells[i]).text(data.currentStatus || '');
        break;
      }
    }
  }
});
        
        gdexView = false;
      }
      dt.draw();
    } catch (e) {
      console.log('Error in GDEX button action', e);
    }
  }
}
      <% } %>
    ],
    pageLength: 25,
    lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
    ordering: true,
    order: [[1, 'desc']],
    columns: [
      {
        data: null,
        orderable: false,
        className: 'no-export',
        render: function(data, type, row, meta) {
          return meta.row + 1;
        }
      },
      {
        data: null,
        orderable: false,
        className: 'no-export',
        render: function(data, type, row) {
          let html = '<div class="d-flex flex-column gap-1">';
          html += `<button type="button" class="btn btn-sm btn-outline-secondary history-btn" data-tracking="${row && row.doTrackingNumber ? row.doTrackingNumber : ''}"><i class="bi bi-clock-history"></i> History</button>`;
          if (canReorder && row && row.product && ['pharmacymoh','pharmacyjpmc','pharmacyphc'].includes(row.product.toLowerCase())) {
            html += `<button class="btn btn-sm btn-primary reorder-btn"
                      data-tracking="${row.doTrackingNumber || ''}"
                      data-address="${row.receiverAddress || ''}"
                      data-product="${row.product || ''}"><i class="bi bi-arrow-repeat"></i> Reorder</button>`;
          }
          html += '</div>';
          return html;
        }
      },
      { data: 'grRemark', defaultContent: '' },
      { data: 'remarks', defaultContent: '' },
      { data: 'doTrackingNumber', defaultContent: '' },
      { data: 'product', defaultContent: '' },
      { 
  data: 'currentStatus',
  defaultContent: '',
  render: function(data, type, row, meta) {
    // For export (excel) in GDEX view, return mapped value
    if (type === 'export' || type === 'excel') {
      if (gdexView) {
        if (data === 'Completed') return 'POD';
        if (data === 'Return') return 'RTS';
        return 'UNDEL';
      }
    }
    // For display in GDEX view, return mapped value
    if (type === 'display') {
      if (gdexView) {
        if (data === 'Completed') return 'POD';
        if (data === 'Return') return 'RTS';
        return 'UNDEL';
      }
      // Flag jobs sitting in the 30-min delayed-warehouse queue, with the time
      // they'll flip to "At Warehouse", so they're easy to spot at a glance.
      if (data === 'Queued for Warehouse' && row.queueScheduledTime) {
        const unlockTime = new Date(row.queueScheduledTime);
        if (!isNaN(unlockTime.getTime())) {
          const timeStr = unlockTime.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
          return `<span class="badge bg-warning text-dark">Queued for Warehouse</span><br><small class="text-muted">30 min delay &middot; until ${timeStr}</small>`;
        }
      }
    }
    return data || '';
  }
},
      { data: 'latestLocation', defaultContent: '' },
      { data: 'age', defaultContent: '' },
      { data: 'jobMethod', defaultContent: '' },
      {
        data: 'jobDate',
        defaultContent: '',
        render: function(data, type, row) {
          if (type === 'display' || type === 'export' || type === 'excel') {
            return formatBruneiDate(data);
          }
          return data || '';
        }
      },
      { data: 'assignedTo', defaultContent: '' },
      { data: 'attempt', defaultContent: '' },
      { data: 'paymentMethod', defaultContent: '' },
      { data: 'paymentAmount', defaultContent: '' },
      { data: 'receiverName', defaultContent: '' },
      { data: 'receiverPhoneNumber', defaultContent: '' },
      { data: 'additionalPhoneNumber', defaultContent: '' },
      { data: 'receiverAddress', defaultContent: '' },
      { data: 'receiverPostalCode', defaultContent: '' },
      { data: 'area', defaultContent: '' },
      {
        data: 'creationDate',
        defaultContent: '',
        render: function(data, type, row) {
          if (type === 'display' || type === 'export' || type === 'excel') {
            return formatBruneiDateTime(data);
          }
          return data || '';
        }
      },
      { data: 'mawbNo', defaultContent: '' },
      { data: 'icPassNum', defaultContent: '' },
      { data: 'patientNumber', defaultContent: '' },
      { data: 'itemsDescription', defaultContent: '' },
      { data: 'itemsQuantity', defaultContent: '' },
      { 
        data: 'screenshotInvoice',
        defaultContent: '',
        render: function (data, type, row) {
          if (type === 'export' || type === 'excel') return data || '';
          if (!data) return '';
          return '<a href="' + data + '" target="_blank">View Invoice</a>';
        }
      },
      { data: 'parcelTrackingNum', defaultContent: '' },
      { data: 'cargoPrice', defaultContent: '' },
      { data: 'parcelWeight', defaultContent: '' },
      { data: 'noOfpackages', defaultContent: '' },
      <% if (['finance', 'manager', 'admin'].includes(user.role)) { %>
      { data: 'handlingCharge', defaultContent: '' },
      <% } else { %>
      { data: 'handlingCharge', visible: false, defaultContent: '' },
      <% } %>
      { 
        data: 'warehouseEntryDateTime',
        defaultContent: '',
        render: function(data, type, row) {
          if (type === 'display' || type === 'export' || type === 'excel') {
            return formatBruneiDate(data);
          }
          return data || '';
        }
      }
    ],
    // Add error handling to drawCallback
    drawCallback: function(settings) {
      try {
        if (gdexView) {
          setGDEXHeaders(this);
        } else if (manifestView) {
          setManifestHeaders(this);
        }
      } catch (e) {
        console.log('Error in drawCallback', e);
      }
    }
  });

  // Reset Filters
  $('#resetFilters').on('click', function() {
    $('#searchForm')[0].reset();
    $('.select2').val(null).trigger('change');
    $('#searchForm').find('input, textarea, select').removeClass('filter-applied');
    $('#tableHeader').text('');
    
    // Reset views if any are active
    if (manifestView || gdexView) {
      resetAllViews(table);
      manifestView = false;
      gdexView = false;
    }
  });

  // Handle search form submission
  $('#searchForm').on('submit', function(e) {
    e.preventDefault();
    const filters = {};

    $('#loadingOverlay').show();

    $(this).find('input[type="text"], input[type="date"], textarea').each(function() {
      const val = $(this).val();
      if (val) { 
        filters[$(this).attr('name')] = val; 
        $(this).addClass('filter-applied'); 
      }
      else { 
        $(this).removeClass('filter-applied'); 
      }
    });

    $(this).find('select.select2').each(function() {
      const name = $(this).attr('name').replace('[]','');
      const val = $(this).val();
      if (val && val.length) { 
        filters[name] = val; 
        $(this).addClass('filter-applied'); 
      }
      else { 
        $(this).removeClass('filter-applied'); 
      }
    });

    $.ajax({
      url: '/searchJobs',
      type: 'POST',
      contentType: 'application/json',
      data: JSON.stringify(filters),
      success: function(data) {
        table.clear().rows.add(data).draw();

        // Build header with applied filters and row count
        let filterNames = [];
        $('#searchForm').find('input[type="text"], textarea').each(function() {
          const val = $(this).val().trim();
          if (val) filterNames.push(val);
        });
        $('#searchForm').find('select.select2').each(function() {
          const val = $(this).val();
          if (val && val.length) filterNames.push(val.join(', '));
        });
        const filterText = filterNames.length ? filterNames.join(' | ') : 'All Jobs';
        const rowCount = data.length;
        $('#tableHeader').text(`${filterText} (${rowCount})`);
        
        // Reapply current view if active
        if (gdexView) {
          setGDEXHeaders(table);
        } else if (manifestView) {
          setManifestHeaders(table);
        }
      },
      error: function(xhr) {
        const msg = xhr.responseJSON && xhr.responseJSON.error
          ? xhr.responseJSON.error
          : 'Error fetching jobs';
        showToast(msg, 'error');
      },
      complete: function() { $('#loadingOverlay').hide(); }
    });
  });

  table.on('draw', function() {
    $('#loadingOverlay').hide();
  });

  // History button click
  $(document).on('click', '.history-btn', function() {
    const trackingNumber = $(this).data('tracking');
    if (!trackingNumber) return;

    $('#historyTrackingNo').text(`(${trackingNumber})`);
    $('#historyTimeline').empty();
    $('#historyError').addClass('d-none').text('');
    $('#historyLoading').removeClass('d-none');
    $('#historyModal').modal('show');

    $.ajax({
      url: '/searchJobs/' + encodeURIComponent(trackingNumber) + '/history',
      type: 'GET',
      success: function(res) {
        $('#historyLoading').addClass('d-none');
        renderHistoryTimeline(res.history || [], res.currentStatus || '');
      },
      error: function(xhr) {
        $('#historyLoading').addClass('d-none');
        const msg = xhr.responseJSON && xhr.responseJSON.error ? xhr.responseJSON.error : 'Failed to load job history';
        $('#historyError').removeClass('d-none').text(msg);
      }
    });
  });

  // Reorder button click
  $(document).on('click', '.reorder-btn', function() {
    const trackingNumber = $(this).data('tracking');
    const address = $(this).data('address').toLowerCase();
    const product = $(this).data('product').toLowerCase();

    const jobMethodSelect = $('#jobMethod');
    jobMethodSelect.empty();

    const currentDay = moment().day();
    const currentTime = moment().hour();

    function isExpressAvailable() {
      if (currentDay === 4 && currentTime >= 11) return false;
      if (currentDay === 5 || currentDay === 6) return false;
      return true;
    }
    function isImmediateAvailable() {
      if (currentDay === 0 || currentDay === 5) return false;
      return currentTime >= 8 && currentTime <= 15;
    }

    if (product === 'pharmacymoh' || product === 'pharmacyjpmc') {
      if (address.includes('brunei muara') || address.includes('brunei-muara')) {
        jobMethodSelect.append('<option value="Standard">Standard</option>');
        if (isExpressAvailable()) jobMethodSelect.append('<option value="Express">Express</option>');
        if (isImmediateAvailable()) jobMethodSelect.append('<option value="Immediate">Immediate</option>');
        jobMethodSelect.append('<option value="Self Collect">Self Collect</option>');
      } else {
        jobMethodSelect.append('<option value="Standard">Standard</option>');
        jobMethodSelect.append('<option value="Self Collect">Self Collect</option>');
      }
    } else if (product === 'pharmacyphc') {
      jobMethodSelect.append('<option value="Standard">Standard</option>');
      jobMethodSelect.append('<option value="Self Collect">Self Collect</option>');
    }

    $('#trackingNumber').val(trackingNumber);
    $('#reorderModal').modal('show');
  });

  $('#reorderForm').on('submit', async function(e) {
    e.preventDefault();
    const trackingNumber = $('#trackingNumber').val();
    const jobMethod = $('#jobMethod').val();
    const paymentMethod = $('#paymentMethod').val();
    const remarks = $('#remarks').val();

    try {
      const response = await fetch('/reorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ trackingNumber, jobMethod, paymentMethod, remarks })
      });
      const result = await response.json();
      if (result.success) showToast('Order is submitted', 'success');
      else showToast('Order submission failed: ' + result.message, 'error');
      $('#reorderModal').modal('hide');
    } catch(err) {
      console.error(err);
      showToast('Error submitting reorder', 'error');
    }
  });
});
</script>

