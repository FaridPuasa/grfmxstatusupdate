        dt.column(shipmentReceivedColIndex).header().innerHTML = 'Shipment Received';
        
        // Update Latest Scan column with mapped status
        updateLatestScanColumn(dt);
        
        // Update the order of columns to match GDEX Billing format
        // Bil (0), Consignment Note (4), Receiver name (15), Weight (30), 
        // Service Charge (32), Shipment Received (33), MAWB (22), Latest Scan (6)
        
        // Reorder columns
        dt.columns([0, 4, 15, 30, 32, shipmentReceivedColIndex, 22, 6]).order();
      } else {
        // Show all columns
        dt.columns().visible(true);
        // Reset all column headers to original
        resetColumnHeaders(dt);
        
        // Hide the Shipment Received column if it was added
        if (dt.columns().indexes().length > 33) {
          dt.column(33).visible(false);
        }
      }

      gdexView = !gdexView;
      manifestView = false; // Turn off Manifest view if it was on
    }
  }
  <% } %>
],
    pageLength: 25,
    lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
    ordering: true,
