    'Original Tracking No.', 'Item Original Price', 'Weight (KG)', 'No. of Packages',
    'Handling Charge', 'Shipment Received'
  ];

  // Function to safely update column header
  function safeUpdateHeader(dt, columnIndex, newHeader) {
    try {
      if (dt.column(columnIndex) && dt.column(columnIndex).header()) {
        dt.column(columnIndex).header().innerHTML = newHeader;
      }
    } catch (e) {
      console.log('Error updating header for column', columnIndex, e);
    }
  }

  // Function to reset all column headers to original
  function resetColumnHeaders(dt) {
    try {
      for (let i = 0; i < originalHeaders.length; i++) {
        safeUpdateHeader(dt, i, originalHeaders[i]);
      }
    } catch (e) {
      console.log('Error resetting column headers', e);
    }
  }

  // Function to update column headers for GDEX view
  function setGDEXHeaders(dt) {
    try {
      safeUpdateHeader(dt, 0, 'Bil');
      safeUpdateHeader(dt, 4, 'Consignment Note');
      safeUpdateHeader(dt, 15, 'Receiver name');
      safeUpdateHeader(dt, 30, 'Weight (KG)');
      safeUpdateHeader(dt, 32, 'Service Charge');
      safeUpdateHeader(dt, 33, 'Shipment Received');
      safeUpdateHeader(dt, 22, 'MAWB');
      safeUpdateHeader(dt, 6, 'Latest Scan');
    } catch (e) {
      console.log('Error setting GDEX headers', e);
    }
  }

  // Function to update column headers for Manifest view
  function setManifestHeaders(dt) {
    try {
      safeUpdateHeader(dt, 0, 'S/N');
      safeUpdateHeader(dt, 4, 'Go Rush Tracking No.');
      safeUpdateHeader(dt, 15, 'Name');
      safeUpdateHeader(dt, 16, 'Main Phone No.');
      safeUpdateHeader(dt, 18, 'Customer Address');
      safeUpdateHeader(dt, 19, 'Postal Code');
      safeUpdateHeader(dt, 30, 'Weight (KG)');
      safeUpdateHeader(dt, 31, 'No. of Packages');
      safeUpdateHeader(dt, 32, 'Handling Charge');
    } catch (e) {
      console.log('Error setting Manifest headers', e);
    }
  }

  // Function to reset all views
  function resetAllViews(dt) {
    try {
      dt.columns().visible(true);
      resetColumnHeaders(dt);
      dt.rows().every(function() {
        const data = this.data();
        if (this.nodes().length) {
          $(this.nodes()).find('td:eq(6)').text(data.currentStatus || '');
        }
      });
      dt.draw();
    } catch (e) {
      console.log('Error resetting views', e);
