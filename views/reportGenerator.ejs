<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Report Generator</title>
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.0.0-alpha1/css/bootstrap.min.css">
  <style>
    #formSection {
      margin-top: 20px;
    }

    .hidden {
      display: none;
    }

    td,
    th {
      vertical-align: middle;
    }

    table {
      border-collapse: collapse;
      width: auto;
      min-width: 300px;
      margin-bottom: 20px;
    }

    th,
    td {
      border: 1px solid black;
      padding: 5px;
    }

    th {
      background: yellow;
      font-weight: bold;
      text-align: center;
    }

    td {
      white-space: pre-line;
      text-align: center;
    }

    #reportLogoHeader img {
      max-height: 80px;
      display: block;
      margin: 0 auto 10px auto;
    }

    #assignedByContainer {
      margin-top: 10px;
      font-weight: bold;
    }

    button.removeRow {
      font-size: 0.8rem;
      padding: 2px 6px;
    }

    .navbar-nav.flex-row {
      flex-direction: row !important;
    }

    .navbar {
      background-color: transparent;
    }

    .container-bg {
      background-color: #333;
    }

    .navbar-nav.flex-row .nav-item {
      margin-right: 10px;
    }

    .logo {
      height: 40px;
      width: auto;
      max-height: 40px;
    }

    @media (max-width: 768px) {
      .logo {
        height: 30px;
        max-height: 30px;
      }
    }

    @media (max-width: 480px) {
      .logo {
        height: 25px;
        max-height: 25px;
      }
    }
  </style>
</head>

<body>
  <div class="container-bg">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <%- include('partials/navbar') %>
        </div>
      </div>
    </div>
  </div>
  <div class="container">
    <h1 class="text-center mt-4">Report Generator</h1>

    <div class="mb-3">
      <label for="reportType" class="form-label">Select Report</label>
      <select id="reportType" class="form-select">
        <option value="">-- Select Report --</option>
        <option value="Operation Morning Report">Operation Morning Report</option>
        <option value="Operation End of Day Report">Operation End of Day Report</option>
        <option value="Freelancer End of Day Report">Freelancer End of Day Report</option>
      </select>
    </div>

    <div id="morningReportSection" class="hidden">
      <form id="reportForm">
        <div class="row mb-3">
          <div class="col-md-3">
            <label for="reportDate" class="form-label">Date</label>
            <input type="date" id="reportDate" name="reportDate" class="form-control" required>
          </div>
          <div class="col-md-3">
            <label for="vehicle" class="form-label">Car</label>
            <select id="vehicle" class="form-select">
              <option value="">N/A</option>
              <% vehicles.forEach(v=> { %>
                <option value="<%= v.plate %>">
                  <%= v.plate %>
                </option>
                <% }) %>
            </select>
          </div>
          <div class="col-md-3">
            <label for="dispatcher" class="form-label">Dispatcher</label>
            <select id="dispatcher" class="form-select" required>
              <option value="">-- Select Dispatcher --</option>
              <optgroup label="Dispatchers">
                <option value="Edey">Edey</option>
                <option value="Ghafar">Ghafar</option>
                <option value="Hairol">Hairol</option>
                <option value="Hamidin">Hamidin</option>
                <option value="Leo">Leo</option>
                <option value="Sowdeq">Sowdeq</option>
                <option value="Wafi">Wafi</option>
                <option value="Zura">Zura</option>
              </optgroup>
              <optgroup label="Freelancers">
                <option value="Azreena">Azreena</option>
                <option value="Bob">Bob</option>
                <option value="Ermi">Ermi</option>
                <option value="Feeza">Feeza</option>
                <!-- <option value="Hjjul">Hjjul</option> -->
                <option value="Khairul">Khairul</option>
                <option value="Jon">Jon</option>
                <option value="Qui">Qui</option>
                <option value="Tommy">Tommy</option>
                <!-- <option value="Zuran">Zuran</option> -->
              </optgroup>
              <!-- <optgroup label="Belts"> -->
                <!-- <option value="Adiwardi">Adiwardi</option> -->
                <!-- <option value="Aiedil">Aiedil</option> -->
                <!-- <option value="Hardy">Hardy</option> -->
                <!-- <option value="Hazif">Hazif</option> -->
                <!-- <option value="Rizal">Rizal</option> -->
                <!-- <option value="Zainul">Zainul</option> -->
                <!-- <option value="Zakwan">Zakwan</option> -->
              <!-- </optgroup> -->
              <optgroup label="Others">
                <option value="Agung">Agung</option>
                <!-- <option value="Syahmi">Syahmi</option> -->
              </optgroup>
            </select>
          </div>
          <div class="col-md-3">
            <label for="assignedJob" class="form-label">Assigned Task</label>
            <textarea id="assignedJob" class="form-control" rows="3"
              placeholder="Enter one or more jobs, each in a new line"></textarea>
          </div>
        </div>

        <div class="mb-3">
          <button type="button" class="btn btn-primary" id="generateBtn">Generate</button>
          <button type="button" class="btn btn-success hidden" id="saveBtn">Save</button>
          <button type="button" class="btn btn-secondary hidden" id="printBtn">Print</button>
          <button type="button" class="btn btn-danger hidden" id="resetBtn">Reset</button>
        </div>
      </form>

      <div id="reportLogoHeader" class="text-center mb-3"></div>
      <table id="dispatcherJobsTable" class="table table-bordered">
        <thead id="dispatcherJobsHeader"></thead>
        <tbody></tbody>
      </table>
      <table id="morningMileageTable" class="table table-bordered">
        <thead id="morningMileageHeader"></thead>
        <tbody></tbody>
      </table>
      <div id="assignedByContainer"></div>
    </div>

    <div id="endOfDayReportSection" class="hidden">
      <div id="reportContainer">
        <form id="endOfDayForm">
          <div class="row mb-3">
            <div class="col-md-3">
              <label for="endReportDate" class="form-label">Date</label>
              <input type="date" id="endReportDate" name="endReportDate" class="form-control" required>
            </div>
          </div>
          <div class="mb-3">
            <button type="button" class="btn btn-primary" id="endGenerateBtn">Generate</button>
            <button type="button" class="btn btn-success hidden" id="endSaveBtn" disabled>Save</button>
            <button type="button" class="btn btn-secondary hidden" id="endPrintBtn">Print</button>
            <button type="button" class="btn btn-danger hidden" id="endResetBtn">Reset</button>
          </div>
        </form>

        <div id="endReportLogoHeader" class="text-center mb-3"></div>
        <table id="endStaffJobsTable" class="table table-bordered">
          <thead id="endStaffJobsHeader"></thead>
          <tbody></tbody>
        </table>

        <table id="endDeliveryResultTable" border="1">
          <thead id="endDeliveryResultHeader"></thead>
          <tbody></tbody>
        </table>

        <div id="codBtCollectedContainer" style="margin-top:30px;"></div>
        <div id="warehouseReportContainer"></div>
        <div id="checkedByContainer"></div>
      </div>
    </div>

    <div id="freelancerEndOfDayReportSection" class="hidden">
      <div id="freelancerReportContainer">
        <form id="freelancerEndOfDayForm">
          <div class="row mb-3">
            <div class="col-md-3">
              <label for="freelancerReportDate" class="form-label">Date</label>
              <input type="date" id="freelancerReportDate" name="freelancerReportDate" class="form-control" required>
            </div>
          </div>
          <div class="mb-3">
            <button type="button" class="btn btn-primary" id="freelancerGenerateBtn">Generate</button>
            <button type="button" class="btn btn-success hidden" id="freelancerSaveBtn" disabled>Save</button>
            <button type="button" class="btn btn-secondary hidden" id="freelancerPrintBtn">Print</button>
            <button type="button" class="btn btn-danger hidden" id="freelancerResetBtn">Reset</button>
          </div>
        </form>

        <div id="freelancerReportLogoHeader" class="text-center mb-3"></div>
        <table id="freelancerJobsTable" class="table table-bordered">
          <thead id="freelancerJobsHeader"></thead>
          <tbody></tbody>
        </table>
        <div id="freelancerCheckedByContainer"></div>
      </div>
    </div>

    <div id="loadingSpinner"
      style="display:none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(255,255,255,0.7); z-index:9999; justify-content: center; align-items: center;">
      <div class="spinner-border text-primary" role="status" style="width: 4rem; height: 4rem;">
        <span class="visually-hidden"></span>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://unpkg.com/bootstrap@5.0.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      // ======================= PRODUCT DISPLAY NAMES MAPPING =======================
      const productDisplayNames = {
        'ewe': 'EWE',
        'pdu': 'PDU',
        'mglobal': 'MGLOBAL',
        'gdex': 'GDEX',
        'gdext': 'GDEX',
        'pure51': 'PURE51',
        'localdelivery': 'LD',
        'cbsl': 'CBSL',
        'pharmacymoh': 'MOH',
        'pharmacyjpmc': 'JPMC',
        'pharmacyphc': 'PHC',
        'kptdp': 'KPT',
        'icarus': 'ICARUS'
      };

      function getProductDisplayName(productKey) {
        return productDisplayNames[productKey] || productKey.toUpperCase();
      }

      // Function to apply product mapping to any table that contains product names
      function applyProductMappingToTable(tableElement) {
        if (!tableElement) return;

        // Find all table headers (th) that might contain product names
        const headers = tableElement.querySelectorAll('th');
        headers.forEach(header => {
          const originalText = header.innerText.trim().toLowerCase();
          // Check if the header text matches any product key
          for (const [key, displayName] of Object.entries(productDisplayNames)) {
            if (originalText === key || originalText === key.toUpperCase()) {
              header.innerText = displayName;
              break;
            }
          }
        });

        // Also check for product names in first column of tbody (sometimes products are listed as rows)
        const rows = tableElement.querySelectorAll('tbody tr');
        rows.forEach(row => {
          const firstCell = row.querySelector('td:first-child');
          if (firstCell) {
            const cellText = firstCell.innerText.trim().toLowerCase();
            for (const [key, displayName] of Object.entries(productDisplayNames)) {
              if (cellText === key || cellText === key.toUpperCase() || cellText.includes(key)) {
                firstCell.innerText = displayName;
                break;
              }
            }
          }
        });
      }
      // ======================= END PRODUCT MAPPING =======================

      // ======================= DATE PICKER RESTRICTION LOGIC =======================
      function configureDatePicker(dateInputElement) {
        if (!dateInputElement) return;

        const today = new Date();
        const yyyy = today.getFullYear();
        const mm = String(today.getMonth() + 1).padStart(2, '0');
        const dd = String(today.getDate()).padStart(2, '0');
        const todayFormatted = `${yyyy}-${mm}-${dd}`;

        dateInputElement.setAttribute('max', todayFormatted);

        if (!dateInputElement.value) {
          dateInputElement.value = todayFormatted;
        }

        dateInputElement.addEventListener('change', function () {
          if (this.value > todayFormatted) {
            alert('Cannot select a future date. Date has been set to today.');
            this.value = todayFormatted;
          }
        });
      }

      const morningReportDate = document.getElementById('reportDate');
      const endOfDayReportDate = document.getElementById('endReportDate');
      const freelancerReportDate = document.getElementById('freelancerReportDate');

      configureDatePicker(morningReportDate);
      configureDatePicker(endOfDayReportDate);
      configureDatePicker(freelancerReportDate);
      // ======================= END DATE PICKER RESTRICTION =======================

      const reportTypeEl = document.getElementById('reportType');
      const reportDateEl = document.getElementById('reportDate');
      const generateBtn = document.getElementById('generateBtn');
      const saveBtn = document.getElementById('saveBtn');
      const printBtn = document.getElementById('printBtn');
      const resetBtn = document.getElementById('resetBtn');
      const dispatcherJobsTable = document.getElementById('dispatcherJobsTable');
      const dispatcherJobsHeader = document.getElementById('dispatcherJobsHeader');
      const dispatcherJobsBody = dispatcherJobsTable.querySelector('tbody');
      const morningMileageTable = document.getElementById('morningMileageTable');
      const morningMileageHeader = document.getElementById('morningMileageHeader');
      const morningMileageBody = morningMileageTable.querySelector('tbody');
      const reportLogoHeader = document.getElementById('reportLogoHeader');
      const assignedByContainer = document.getElementById('assignedByContainer');
      const userId = "<%= user.name %>";
      const loadingSpinner = document.getElementById('loadingSpinner');

      let isReportSaved = false;

      function showLoading() { loadingSpinner.style.display = 'flex'; }
      function hideLoading() { loadingSpinner.style.display = 'none'; }

      function clearReport() {
        reportLogoHeader.innerHTML = '';
        dispatcherJobsHeader.innerHTML = '';
        dispatcherJobsBody.innerHTML = '';
        morningMileageHeader.innerHTML = '';
        morningMileageBody.innerHTML = '';
        assignedByContainer.innerHTML = '';
        reportDateEl.removeAttribute('disabled');
      }

      const freelancerEndOfDaySection = document.getElementById('freelancerEndOfDayReportSection');
      const freelancerGenerateBtn = document.getElementById('freelancerGenerateBtn');
      const freelancerSaveBtn = document.getElementById('freelancerSaveBtn');
      const freelancerPrintBtn = document.getElementById('freelancerPrintBtn');
      const freelancerResetBtn = document.getElementById('freelancerResetBtn');
      const freelancerReportLogoHeader = document.getElementById('freelancerReportLogoHeader');
      const freelancerJobsTable = document.getElementById('freelancerJobsTable');
      const freelancerJobsHeader = document.getElementById('freelancerJobsHeader');
      const freelancerCheckedByContainer = document.getElementById('freelancerCheckedByContainer');

      reportTypeEl.addEventListener('change', () => {
        isReportSaved = false;
        clearReport();
        generateBtn.classList.remove('hidden');
        saveBtn.classList.add('hidden');
        printBtn.classList.add('hidden');
        resetBtn.classList.add('hidden');

        if (reportTypeEl.value === 'Operation Morning Report') {
          morningReportSection.classList.remove('hidden');
          endOfDayReportSection.classList.add('hidden');
          freelancerEndOfDaySection.classList.add('hidden');
        } else if (reportTypeEl.value === 'Operation End of Day Report') {
          morningReportSection.classList.add('hidden');
          endOfDayReportSection.classList.remove('hidden');
          freelancerEndOfDaySection.classList.add('hidden');
        } else if (reportTypeEl.value === 'Freelancer End of Day Report') {
          morningReportSection.classList.add('hidden');
          endOfDayReportSection.classList.add('hidden');
          freelancerEndOfDaySection.classList.remove('hidden');
          freelancerReportLogoHeader.innerHTML = '';
          freelancerJobsHeader.innerHTML = '';
          freelancerJobsTable.querySelector('tbody').innerHTML = '';
          freelancerCheckedByContainer.innerHTML = '';
        } else {
          morningReportSection.classList.add('hidden');
          endOfDayReportSection.classList.add('hidden');
          freelancerEndOfDaySection.classList.add('hidden');
        }
      });

      // Freelancer Generate Button
      freelancerGenerateBtn.addEventListener('click', async () => {
        const reportDate = document.getElementById('freelancerReportDate').value;
        if (!reportDate) {
          alert('Please pick a date');
          return;
        }

        showLoading();
        freelancerGenerateBtn.style.display = "none";

        try {
          const res = await fetch(`/api/freelancer-delivery-result-report?date=${reportDate}`);
          const data = await res.json();

          if (!data.results || data.results.length === 0) {
            alert('No completed jobs found for freelancers on this date');
            freelancerGenerateBtn.style.display = "block";
            hideLoading();
            return;
          }

          const mappedProducts = data.products.map(p => getProductDisplayName(p));

          const formattedDate = new Date(reportDate).toLocaleDateString('en-GB').replace(/\//g, '.');
          const reportTitle = `Freelancer End of Day Report ${formattedDate}`;
          window.currentFreelancerReportName = reportTitle;

          freelancerReportLogoHeader.innerHTML = `
          <img src="https://portal.gorushbn.com/images/logo.png" alt="Logo" style="width:300px; height:auto;">
          <h2>${reportTitle}</h2>
        `;

          const totalColumns = 2 + mappedProducts.length + 1;
          freelancerJobsHeader.innerHTML = `
          <tr style="background:lightblue;font-weight:bold;">
            <th colspan="${totalColumns}" style="text-align:left;">Job Result</th>
          </tr>
          <tr>
            <th>Freelancer</th>
            <th>Area</th>
            ${mappedProducts.map(p => `<th>${p}</th>`).join('')}
            <th>Total</th>
          </tr>
        `;

          const tbody = freelancerJobsTable.querySelector('tbody');
          tbody.innerHTML = '';

          data.results.forEach(result => {
            const row = document.createElement('tr');

            const staffCell = document.createElement('td');
            staffCell.innerText = result.staff;
            row.appendChild(staffCell);

            const areaCell = document.createElement('td');
            areaCell.innerText = result.area || '-';
            areaCell.contentEditable = true;
            row.appendChild(areaCell);

            data.products.forEach(originalProduct => {
              const td = document.createElement('td');
              const value = result.productCounts[originalProduct] || 0;
              td.innerText = value;
              td.contentEditable = true;
              row.appendChild(td);
            });

            const totalCell = document.createElement('td');
            totalCell.innerText = result.totalCompleted || 0;
            totalCell.contentEditable = true;
            row.appendChild(totalCell);

            tbody.appendChild(row);
          });

          freelancerCheckedByContainer.innerText = `Checked and prepared by: ${userId}`;
          freelancerCheckedByContainer.style.fontWeight = 'bold';
          freelancerCheckedByContainer.style.marginTop = '10px';

          freelancerSaveBtn.classList.remove("hidden");
          freelancerResetBtn.classList.remove("hidden");
          freelancerPrintBtn.classList.add("hidden");
          freelancerSaveBtn.removeAttribute("disabled");

          alert(`Freelancer report generated with ${data.results.length} freelancers`);

        } catch (err) {
          console.error('Error generating freelancer report:', err);
          alert('Error fetching report data: ' + err.message);
        } finally {
          hideLoading();
          freelancerGenerateBtn.style.display = "block";
        }
      });

      freelancerSaveBtn.addEventListener('click', async () => {
        const reportDate = document.getElementById('freelancerReportDate').value;
        if (!reportDate) {
          alert('Please select a date first.');
          return;
        }

        showLoading();

        const formattedDate = new Date(reportDate).toLocaleDateString('en-GB').replace(/\//g, '.');
        const reportName = `Freelancer End of Day Report ${formattedDate}`;
        const reportContent = freelancerEndOfDaySection.innerHTML;
        const reportType = "Freelancer End of Day Report";

        async function saveReport(forceReplace = false) {
          try {
            const res = await fetch('/api/saveReport', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                reportType,
                reportName,
                reportContent,
                createdBy: userId,
                forceReplace
              })
            });

            const result = await res.json();

            if (result.success) {
              alert(forceReplace ? 'Report replaced successfully!' : 'Report saved successfully!');
              freelancerSaveBtn.classList.add('hidden');
              freelancerPrintBtn.classList.remove('hidden');
            } else if (result.duplicate) {
              const confirmReplace = confirm('A report with this name already exists. Do you want to replace it?');
              if (confirmReplace) {
                await saveReport(true);
              }
            } else {
              alert('Failed to save report: ' + result.message);
            }
          } catch (err) {
            console.error(err);
            alert('Error saving report');
          } finally {
            hideLoading();
          }
        }

        await saveReport();
      });

      freelancerPrintBtn.addEventListener('click', () => {
        showLoading();

        const printWindow = window.open('', '_blank', 'width=900,height=700');
        const today = new Date();
        const dd = String(today.getDate()).padStart(2, "0");
        const mm = String(today.getMonth() + 1).padStart(2, "0");
        const yyyy = today.getFullYear();
        const fileName = `Freelancer End of Day Report ${dd}.${mm}.${yyyy}`;

        const style = `
        <style>
          body { font-family: Arial, sans-serif; padding: 25px; }
          h2 { text-align: center; margin: 10px 0 20px; }
          table { width: 100%; border-collapse: collapse; margin-bottom: 25px; }
          th, td {
            border: 1px solid #000;
            padding: 6px 8px;
            font-size: 14px;
            text-align: center;
            vertical-align: middle;
          }
          th { background-color: #e6f2ff; font-weight: bold; }
          tr:first-child th[colspan] {
            background-color: lightblue !important;
            text-align: left;
            font-size: 15px;
          }
          img { display: block; margin: 0 auto; max-height: 80px; }
          .checked-by { font-weight: bold; margin-top: 10px; }
          @media print {
            body { zoom: 90%; }
          }
        </style>
      `;

        const tableClone = freelancerJobsTable.cloneNode(true);

        const printHTML = `
        <html>
          <head>
            <title>${fileName}</title>
            ${style}
          </head>
          <body>
            ${freelancerReportLogoHeader.outerHTML}
            ${tableClone.outerHTML}
            <div class="checked-by">${freelancerCheckedByContainer.innerText}</div>
          </body>
        </html>
      `;

        printWindow.document.open();
        printWindow.document.write(printHTML);
        printWindow.document.close();

        printWindow.onload = function () {
          printWindow.document.title = fileName;
          printWindow.focus();
          printWindow.print();
          hideLoading();
        };
      });

      freelancerResetBtn.addEventListener('click', () => {
        if (confirm("Are you sure you want to reset the report?")) {
          location.reload();
        }
      });

      // Morning Report Generate Button
      generateBtn.addEventListener('click', async () => {
        isReportSaved = false;
        const date = reportDateEl.value;
        const vehicle = document.getElementById('vehicle').value || 'N/A';
        const dispatcher = document.getElementById('dispatcher').value;
        const assignedJob = document.getElementById('assignedJob').value;
        if (!date || !dispatcher) { alert('Please pick a date and dispatcher'); return; }
        reportDateEl.setAttribute('disabled', 'true');
        showLoading();

        try {
          const res = await fetch('/api/getDispatcherJobSummary', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ dispatcher, date })
          });

          const data = await res.json();

          const day = new Date(date).toLocaleDateString('en-GB', { weekday: 'long' });
          const formattedDate = new Date(date).toLocaleDateString('en-GB').replace(/\//g, '.');
          const reportName = `Operation Morning Report ${day} ${formattedDate}`;
          window.currentReportName = reportName;

          reportLogoHeader.innerHTML = `<img src="https://portal.gorushbn.com/images/logo.png" alt="Logo"><h2>${reportName}</h2>`;

          dispatcherJobsHeader.innerHTML = `
          <tr style="background:yellow;font-weight:bold;text-align:center;"><th colspan="6">Dispatcher Assigned Tasks</th></tr>
          <tr>
            <th>Vehicle No.</th>
            <th>Dispatcher</th>
            <th>Assigned Task</th>
            <th>Area</th>
            <th>Total Delivery</th>
            <th>Action</th>
          </tr>
        `;

          const existingFooter = dispatcherJobsBody.querySelector('tr.grandTotal');
          if (existingFooter) existingFooter.remove();

          let assignedJobContent = '';
          if (data.totalOrders > 0) {
            assignedJobContent = Object.entries(data.productCounts)
              .map(([p, c]) => `- Deliver ${getProductDisplayName(p)} (${c})`)
              .join('\n');
          }
          if (assignedJob) {
            const jobLines = assignedJob.split('\n').map(l => l.trim()).filter(l => l.length > 0).map(l => `- ${l}`).join('\n');
            assignedJobContent += `${assignedJobContent ? '\n' : ''}${jobLines}`;
          }

          const areaContent = data.totalOrders > 0 ? (data.areas.join(',') || '') : '';
          const totalJobsCount = data.totalOrders || 0;

          if (assignedJobContent || totalJobsCount > 0) {
            const row = document.createElement('tr');
            row.innerHTML = `
            <td contenteditable="true">${vehicle}</td>
            <td contenteditable="true">${dispatcher}</td>
            <td contenteditable="true" style="white-space: pre-line;">${assignedJobContent || ''}</td>
            <td contenteditable="true">${areaContent}</td>
