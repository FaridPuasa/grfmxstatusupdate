              <td contenteditable="true"></td>
              <td contenteditable="true"></td>
              <td contenteditable="true"></td>
              <td contenteditable="true"></td>
              <td><button class="btn btn-sm btn-danger removeRowBtn">🗑️</button></td>
            `;
              tbody.appendChild(newRow);
              attachRowEvents(newRow);
            });
          }

        } catch (err) {
          console.error('Error loading Vehicle Report:', err);
        }
