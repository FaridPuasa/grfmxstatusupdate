      async function loadDeliveryResult(date) {
        if (!reportContainer) return console.error('reportContainer not found');
        try {
          const res = await fetch(`/api/delivery-result-report?date=${date}`);
          const { products, results } = await res.json();
          const mappedProducts = products.map(p => getProductDisplayName(p));
          const fragment = document.createDocumentFragment();
          const spacer = document.createElement("div");
          spacer.style.marginTop = "30px";
          fragment.appendChild(spacer);
          const table = document.createElement("table");
          table.className = "table table-bordered";
          const thead = document.createElement("thead");
          const headerRow = document.createElement("tr");
          headerRow.style.cssText = "background-color: lightblue; font-weight: bold;";
          const headerCell = document.createElement("th");
          headerCell.colSpan = 2 + mappedProducts.length + 4;
          headerCell.style.textAlign = "left";
          headerCell.innerText = "2. Job Result";
          headerRow.appendChild(headerCell);
          thead.appendChild(headerRow);
          const colRow = document.createElement("tr");
          const headers = ["Staff", "Area", "Vehicle", "Jobs", ...mappedProducts, "Total", "Success Rate"];
          colRow.innerHTML = headers.map(h => `<th>${h}</th>`).join('');
          thead.appendChild(colRow);
          table.appendChild(thead);
          const tbody = document.createElement("tbody");
          const filteredResults = results.filter(r => r.staff !== "N/A" && r.staff !== "Unassigned").sort((a, b) => (a.staff === "Selfcollect" ? 1 : b.staff === "Selfcollect" ? -1 : 0));
          const displayNames = { current: "Assigned", completed: "Completed", failed: "Failed" };
          const rowTypes = ["current", "completed", "failed"];
          filteredResults.forEach(r => {
            const rowCells = {};
            const tdSR = document.createElement("td");
            tdSR.rowSpan = 3;
            tdSR.contentEditable = false;
            rowTypes.forEach((type, idx) => {
              const row = document.createElement("tr");
              if (idx === 0) {
                const staffCell = document.createElement("td");
                staffCell.rowSpan = 3;
                staffCell.innerText = r.staff;
                row.appendChild(staffCell);
                const areaCell = document.createElement("td");
                areaCell.rowSpan = 3;
                areaCell.innerText = r.staff === "Selfcollect" ? "-" : r.area || "-";
                areaCell.contentEditable = true;
                row.appendChild(areaCell);
                const vehicleCell = document.createElement("td");
                vehicleCell.rowSpan = 3;
                vehicleCell.innerText = r.vehicle || "-";
                vehicleCell.contentEditable = true;
                row.appendChild(vehicleCell);
              }
              const tdJobs = document.createElement("td");
              tdJobs.innerText = displayNames[type];
              tdJobs.style.fontWeight = "bold";
              row.appendChild(tdJobs);
              const productTds = products.map((originalProduct) => {
                const td = document.createElement("td");
                td.contentEditable = true;
                td.innerText = r.productCounts[originalProduct][type];
                if (!rowCells[originalProduct]) rowCells[originalProduct] = {};
                rowCells[originalProduct][type] = td;
                if (type === "completed" && parseInt(td.innerText) > 0) td.style.backgroundColor = "#d4f4d4";
                else if (type === "failed" && parseInt(td.innerText) > 0) td.style.backgroundColor = "#f4d4d4";
                let inputTimeout;
                td.addEventListener("input", () => {
                  clearTimeout(inputTimeout);
                  inputTimeout = setTimeout(() => {
                    const val = parseInt(td.innerText) || 0;
                    if (type === "completed") td.style.backgroundColor = val > 0 ? "#d4f4d4" : "";
                    else if (type === "failed") td.style.backgroundColor = val > 0 ? "#f4d4d4" : "";
                    if (type === "current") {
                      const completedVal = parseInt(rowCells[originalProduct].completed?.innerText || 0);
                      const failedVal = parseInt(rowCells[originalProduct].failed?.innerText || 0);
                      if (val < completedVal + failedVal) td.innerText = completedVal + failedVal;
                    }
                    let completedTotal = 0, assignedTotal = 0;
                    products.forEach(p => {
                      completedTotal += parseInt(rowCells[p]?.completed?.innerText || 0);
                      assignedTotal += parseInt(rowCells[p]?.current?.innerText || 0);
                    });
                    const successRate = assignedTotal === 0 ? 100 : Math.round((completedTotal / assignedTotal) * 100);
                    tdSR.innerText = successRate + "%";
                    tdSR.style.backgroundColor = successRate < 100 ? "lightyellow" : "";
                  }, 50);
                });
                return td;
              });
              productTds.forEach(td => row.appendChild(td));
              const tdTotal = document.createElement("td");
              const calculateTotal = () => {
                const total = productTds.reduce((sum, td) => sum + (parseInt(td.innerText) || 0), 0);
                tdTotal.innerText = total;
                if (type === "completed" && total > 0) tdTotal.style.backgroundColor = "#d4f4d4";
                else if (type === "failed" && total > 0) tdTotal.style.backgroundColor = "#f4d4d4";
                else tdTotal.style.backgroundColor = "";
                let completedTotal = 0, assignedTotal = 0;
                products.forEach(p => {
                  completedTotal += parseInt(rowCells[p]?.completed?.innerText || 0);
                  assignedTotal += parseInt(rowCells[p]?.current?.innerText || 0);
                });
                const successRate = assignedTotal === 0 ? 100 : Math.round((completedTotal / assignedTotal) * 100);
                tdSR.innerText = successRate + "%";
                tdSR.style.backgroundColor = successRate < 100 ? "lightyellow" : "";
              };
              calculateTotal();
              row.appendChild(tdTotal);
              if (idx === 0) row.appendChild(tdSR);
              tbody.appendChild(row);
            });
          });
          table.appendChild(tbody);
          fragment.appendChild(table);
          reportContainer.appendChild(fragment);
        } catch (err) {
          console.error('Error loading delivery results:', err);
        }
      }

      async function loadVehicleReport(date) {
        if (!reportContainer) return console.error('reportContainer not found');
        try {
          const res = await fetch('/api/vehicle-report', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ date }) });
          const html = await res.text();
          const spacer = document.createElement("div");
          spacer.style.marginTop = "30px";
          reportContainer.appendChild(spacer);
          const vehicleContainer = document.createElement("div");
          vehicleContainer.innerHTML = html;
          reportContainer.appendChild(vehicleContainer);
          const table = vehicleContainer.querySelector('#vehicleReportTable');
          const tbody = table.querySelector('tbody');
          const addRowBtn = vehicleContainer.querySelector('#addVehicleRowBtn');
          function attachRowEvents(row) {
            const delBtn = row.querySelector('.removeRowBtn');
            if (delBtn) delBtn.addEventListener('click', () => row.remove());
            const morningInput = row.querySelector('.morningMileage');
            const eodInput = row.querySelector('.eodMileage');
            const usedInput = row.querySelector('.mileageUsed');
            function recalc() {
              const morningVal = parseFloat(morningInput.value) || 0;
              const eodVal = parseFloat(eodInput.value) || 0;
              usedInput.value = isNaN(eodVal - morningVal) ? '' : (eodVal - morningVal);
            }
            if (morningInput && eodInput) {
              morningInput.addEventListener('input', recalc);
              eodInput.addEventListener('input', recalc);
            }
            const paidCell = row.querySelector('td:nth-child(8)');
            if (paidCell) {
              paidCell.addEventListener('input', () => {
                let val = paidCell.innerText.replace(/[^\d.]/g, '');
                if (val === '') { paidCell.innerText = ''; return; }
                val = parseFloat(val);
                if (isNaN(val)) { paidCell.innerText = ''; return; }
                paidCell.innerText = `$${val.toFixed(2)}`;
              });
            }
          }
          tbody.querySelectorAll('tr').forEach(row => attachRowEvents(row));
          if (addRowBtn) {
            addRowBtn.addEventListener('click', () => {
              const newRow = document.createElement('tr');
              newRow.innerHTML = `<td contenteditable="true"><\/td><td contenteditable="true"><\/td><td><input type="number" class="morningMileage" value="0" readonly><\/td><td><input type="number" class="eodMileage"><\/td><td><input type="number" class="mileageUsed" value="0" readonly><\/td><td contenteditable="true">No<\/td><td contenteditable="true"><\/td><td contenteditable="true"><\/td><td contenteditable="true"><\/td><td contenteditable="true"><\/td><td contenteditable="true"><\/td><td><button class="btn btn-sm btn-danger removeRowBtn">🗑️<\/button><\/td>`;
              tbody.appendChild(newRow);
              attachRowEvents(newRow);
            });
          }
        } catch (err) {
          console.error('Error loading Vehicle Report:', err);
        }
      }

      async function loadWarehouseTable(date, forceRefresh = false, retryCount = 0) {
        const maxRetries = 3;
        const retryDelay = 3000; // 3 seconds

        if (!reportContainer) return console.error('reportContainer not found');

        // Check if we have cached data in memory
        if (!forceRefresh && warehouseDataCache && lastWarehouseDate === date) {
          console.log('Using cached warehouse data');
          const existingWH = document.querySelector('#warehouseReportContainer');
          if (existingWH) existingWH.remove();
          const spacer = document.createElement("div");
          spacer.style.marginTop = "30px";
          reportContainer.appendChild(spacer);
          const whContainer = document.createElement("div");
          whContainer.id = 'warehouseReportContainer';
          whContainer.innerHTML = warehouseDataCache;
          reportContainer.appendChild(whContainer);
          const warehouseTables = whContainer.querySelectorAll('table');
          warehouseTables.forEach(table => applyProductMappingToTable(table));
          return;
        }

        if (isWarehouseLoading) {
          console.log('Warehouse report already loading, skipping...');
          return;
        }

        isWarehouseLoading = true;
        const loadingDiv = document.createElement('div');
        loadingDiv.id = 'warehouseLoading';

        const refreshMsg = forceRefresh ? 'Refreshing warehouse report (getting latest data)...' : 'Loading warehouse report...';
        loadingDiv.innerHTML = `<div class="text-center"><div class="spinner-border text-primary" role="status"></div><p>${refreshMsg}</p><small class="text-muted">This may take 15-30 seconds for first load</small></div>`;
        reportContainer.appendChild(loadingDiv);

        try {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 60000); // 60 second timeout

          let url = '/api/warehouseTableGenerate';
          let fetchOptions = {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ date }),
            signal: controller.signal
          };

          // If force refresh, clear cache first
          if (forceRefresh) {
            await fetch('/api/clear-warehouse-cache', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ date })
            });
            // Reset cache in memory
            warehouseDataCache = null;
            lastWarehouseDate = null;
          }

          const res = await fetch(url, fetchOptions);
          clearTimeout(timeoutId);

          // Handle 503 with retry
          if (res.status === 503 && retryCount < maxRetries) {
            console.log(`Service unavailable, retrying (${retryCount + 1}/${maxRetries})...`);
            const loadingElem = document.getElementById('warehouseLoading');
            if (loadingElem) {
              loadingElem.innerHTML = `
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p>Server is busy, retrying (${retryCount + 1}/${maxRetries})...</p>
                        <small class="text-muted">Waiting ${retryDelay / 1000} seconds before retry</small>
                    </div>
                `;
            }
            await new Promise(resolve => setTimeout(resolve, retryDelay));
            isWarehouseLoading = false; // Reset flag for retry
            return loadWarehouseTable(date, forceRefresh, retryCount + 1);
          }

          if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);

          // Read cache headers
          const cacheStatus = res.headers.get('X-Cache');
          const cacheAge = res.headers.get('X-Cache-Age');

          const html = await res.text();

          warehouseDataCache = html;
          lastWarehouseDate = date;

          const loadingElem = document.getElementById('warehouseLoading');
          if (loadingElem) loadingElem.remove();

          const existingWH = document.querySelector('#warehouseReportContainer');
          if (existingWH) existingWH.remove();

          const spacer = document.createElement("div");
          spacer.style.marginTop = "30px";
          reportContainer.appendChild(spacer);

          const whContainer = document.createElement("div");
          whContainer.id = 'warehouseReportContainer';
          whContainer.innerHTML = html;
          reportContainer.appendChild(whContainer);

          const warehouseTables = whContainer.querySelectorAll('table');
          warehouseTables.forEach(table => applyProductMappingToTable(table));

          // Show cache warning if data is stale
          if (cacheAge) {
            showCacheAgeWarning(parseInt(cacheAge));
          }

          // Show cache status in console
          console.log(`Warehouse data loaded - Cache: ${cacheStatus || 'unknown'}, Age: ${cacheAge || 'unknown'}`);

        } catch (err) {
          // Retry on timeout or network errors
          if (retryCount < maxRetries && (err.name === 'AbortError' || err.message.includes('503') || err.message.includes('timeout'))) {
            console.log(`Request failed, retrying (${retryCount + 1}/${maxRetries})...`);
            const loadingElem = document.getElementById('warehouseLoading');
            if (loadingElem) {
              loadingElem.innerHTML = `
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p>Request timed out, retrying (${retryCount + 1}/${maxRetries})...</p>
                        <small class="text-muted">Waiting ${retryDelay / 1000} seconds before retry</small>
                    </div>
                `;
            }
            await new Promise(resolve => setTimeout(resolve, retryDelay));
            isWarehouseLoading = false;
            return loadWarehouseTable(date, forceRefresh, retryCount + 1);
          }

          console.error('Error loading Warehouse table:', err);
          const loadingElem = document.getElementById('warehouseLoading');
          if (loadingElem) {
            if (err.name === 'AbortError' || err.message.includes('503') || err.message.includes('timeout')) {
              loadingElem.innerHTML = `
                    <div class="alert alert-warning">
                        <strong>⏳ The server is currently busy processing your request.</strong><br>
                        This usually happens when the warehouse data is being generated for the first time.<br><br>
                        Please try:
                        <ul>
                            <li>Waiting a few minutes and refreshing the page</li>
                            <li>Selecting a more recent date</li>
                            <li>Try again later</li>
                        </ul>
                        <button class="btn btn-primary btn-sm mt-2" onclick="location.reload()">🔄 Refresh Page</button>
                        <button class="btn btn-secondary btn-sm mt-2 ms-2" onclick="document.getElementById('warehouseLoading').remove()">✖ Close</button>
                    </div>
                `;
            } else {
              loadingElem.innerHTML = `
                    <div class="alert alert-danger">
                        <strong>❌ Failed to load warehouse data:</strong><br>
                        ${err.message}<br><br>
                        <button class="btn btn-primary btn-sm mt-2" onclick="location.reload()">🔄 Refresh Page</button>
                        <button class="btn btn-secondary btn-sm mt-2 ms-2" onclick="document.getElementById('warehouseLoading').remove()">✖ Close</button>
                    </div>
                `;
            }
            // Don't auto-remove on error, let user decide
          }
        } finally {
          isWarehouseLoading = false;
        }
      }

      // Helper function to show cache age warning
      function showCacheAgeWarning(cacheAgeSeconds) {
        const existingWarning = document.querySelector('.cache-warning');
        if (existingWarning) existingWarning.remove();

        if (cacheAgeSeconds > 300) { // More than 5 minutes
          const warningDiv = document.createElement('div');
          warningDiv.className = 'alert alert-warning cache-warning';
          warningDiv.style.marginTop = '10px';
          warningDiv.innerHTML = `
            <small>
                ⚠️ Warehouse data is ${Math.floor(cacheAgeSeconds / 60)} minutes old. 
                <a href="#" onclick="location.reload(); return false;">Refresh page to get latest data</a>
            </small>
        `;
          const warehouseContainer = document.querySelector('#warehouseReportContainer');
          if (warehouseContainer && warehouseContainer.parentNode) {
            warehouseContainer.parentNode.insertBefore(warningDiv, warehouseContainer.nextSibling);
          }
        }
      }

      endGenerateBtn.addEventListener('click', async () => {
        endGenerateBtn.style.display = "none";
        showLoading();
        const endReportDate = document.getElementById('endReportDate').value;
        if (!endReportDate) { alert('Please pick a date'); return; }
        try {
