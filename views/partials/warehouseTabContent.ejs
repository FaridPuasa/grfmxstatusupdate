<%_
// Locals expected: currentMap, plannedSelfCollectMap, urgentMap, overdueMap,
// maxAttemptMap, archivedMap, productMapping, mawbProducts.
// Extracted from dashboard.ejs so the warehouse tabs can be re-rendered on
// demand (see /api/dashboard/warehouse-refresh) without a full page reload.
_%>    <div class="tab-content">
        <% const tabData = [
            { id: 'current', map: currentMap },
            { id: 'plannedselfcollect', map: plannedSelfCollectMap },
            { id: 'urgent', map: urgentMap },
            { id: 'overdue', map: overdueMap },
            { id: 'maxattempt', map: maxAttemptMap },
            { id: 'archived', map: archivedMap }
        ]; %>

        <% tabData.forEach(({ id, map }, tabIndex) => { %>
            <div class="tab-pane fade <%= tabIndex === 0 ? 'show active' : '' %>" id="<%= id %>" role="tabpanel">

                <% if (Object.keys(map).length === 0) { %>
                    <p class="text-center text-muted">No <%= id %> orders found.</p>
                <% } else { %>

                    <% if (id === 'current') { %>
                        <% Object.keys(map).forEach((location, locIndex) => {
                            let locCount = 0;
                            Object.keys(map[location]).forEach(product => {
                                Object.keys(map[location][product]).forEach(area => {
                                    locCount += map[location][product][area].length;
                                });
                            });
                        %>
                            <div class="card my-3">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <div class="toggle-header" style="cursor: pointer;" data-bs-toggle="collapse"
                                        data-bs-target="#collapse-<%= id %>-loc-<%= locIndex %>">
                                        <strong><%= location.toUpperCase() %></strong>
                                    </div>
                                    <div class="section-toolbar">
                                        <span class="badge bg-primary"><%= locCount %> orders</span>
                                        <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                            data-target="#collapse-<%= id %>-loc-<%= locIndex %>"
                                            data-section-name="<%= location.toUpperCase() %>">📋 Copy</button>
                                        <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                            data-target="#collapse-<%= id %>-loc-<%= locIndex %>"
                                            data-section-name="<%= location.toUpperCase() %>">📊 Excel</button>
                                        <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse"
                                            data-bs-target="#collapse-<%= id %>-loc-<%= locIndex %>"></i>
                                    </div>
                                </div>
                                <div class="collapse" id="collapse-<%= id %>-loc-<%= locIndex %>">
                                    <div class="card-body p-0">

                                        <% Object.keys(map[location]).forEach((product, prodIndex) => {
                                            let prodCount = 0;
                                            Object.keys(map[location][product]).forEach(area => {
                                                prodCount += map[location][product][area].length;
                                            });
                                            const isMawbProduct = mawbProducts.includes(product);
                                        %>
                                            <div class="card my-2 mx-3">
                                                <div class="card-header d-flex justify-content-between align-items-center">
                                                    <div class="toggle-header" style="cursor: pointer;"
                                                        data-bs-toggle="collapse"
                                                        data-bs-target="#collapse-<%= id %>-loc-<%= locIndex %>-prod-<%= prodIndex %>">
                                                        <strong><%= (productMapping[product] || product.toUpperCase()) %></strong>
                                                    </div>
                                                    <div class="section-toolbar">
                                                        <span class="badge bg-success"><%= prodCount %> orders</span>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                                            data-target="#collapse-<%= id %>-loc-<%= locIndex %>-prod-<%= prodIndex %>"
                                                            data-section-name="<%= location.toUpperCase() %> - <%= (productMapping[product] || product.toUpperCase()) %>">📋 Copy</button>
                                                        <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                                            data-target="#collapse-<%= id %>-loc-<%= locIndex %>-prod-<%= prodIndex %>"
                                                            data-section-name="<%= location.toUpperCase() %> - <%= (productMapping[product] || product.toUpperCase()) %>">📊 Excel</button>
                                                        <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse"
                                                            data-bs-target="#collapse-<%= id %>-loc-<%= locIndex %>-prod-<%= prodIndex %>"></i>
                                                    </div>
                                                </div>
                                                <div class="collapse" id="collapse-<%= id %>-loc-<%= locIndex %>-prod-<%= prodIndex %>">
                                                    <div class="card-body p-0">

                                                        <% if (isMawbProduct) {
                                                            const mawbGroups = {};
                                                            Object.keys(map[location][product]).forEach(area => {
                                                                map[location][product][area].forEach(order => {
                                                                    const m = order.mawbNo || 'Unassigned';
                                                                    if (!mawbGroups[m]) mawbGroups[m] = [];
                                                                    mawbGroups[m].push(order);
                                                                });
                                                            });
                                                            const mawbKeysSorted = Object.keys(mawbGroups).sort((a, b) => {
                                                                const maxAgeA = Math.max(...mawbGroups[a].map(o => o.age));
                                                                const maxAgeB = Math.max(...mawbGroups[b].map(o => o.age));
                                                                return maxAgeB - maxAgeA;
                                                            });
                                                        %>
                                                            <% mawbKeysSorted.forEach((mawb, mawbIndex) => {
                                                                const mawbOrders = mawbGroups[mawb];
                                                                const mawbAges = mawbOrders.map(o => o.age);
                                                                const mawbMaxAge = Math.max(...mawbAges);
                                                                const mawbMinAge = Math.min(...mawbAges);
                                                                const mawbAgeLabel = mawbMaxAge === mawbMinAge ? `${mawbMaxAge}` : `${mawbMaxAge}-${mawbMinAge}`;
                                                                const areaSubMap = {};
                                                                mawbOrders.forEach(order => {
                                                                    const a = order.area || 'Unknown';
                                                                    if (!areaSubMap[a]) areaSubMap[a] = [];
                                                                    areaSubMap[a].push(order);
                                                                });
                                                                const mawbIdPrefix = `${id}-loc-${locIndex}-prod-${prodIndex}-mawb-${mawbIndex}`;
                                                            %>
                                                                <div class="card my-2 mx-3">
                                                                    <div class="card-header d-flex justify-content-between align-items-center">
                                                                        <div class="toggle-header" style="cursor: pointer;"
                                                                            data-bs-toggle="collapse"
                                                                            data-bs-target="#collapse-<%= mawbIdPrefix %>">
                                                                            <strong>MAWB: <%= mawb %></strong>
                                                                            <span class="badge
                                                                                <%= mawbMaxAge >= 3 ? 'bg-dark' :
                                                                                    mawbMaxAge >= 2 ? 'bg-danger' :
                                                                                    mawbMaxAge >= 1 ? 'bg-warning text-dark' : 'bg-success' %> ms-2">
                                                                                <%= mawbAgeLabel %> days
                                                                            </span>
                                                                        </div>
                                                                        <div class="section-toolbar">
                                                                            <span class="badge bg-info"><%= mawbOrders.length %> orders</span>
                                                                            <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                                                                data-target="#collapse-<%= mawbIdPrefix %>"
                                                                                data-section-name="MAWB <%= mawb %>">📋 Copy</button>
                                                                            <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                                                                data-target="#collapse-<%= mawbIdPrefix %>"
                                                                                data-section-name="MAWB <%= mawb %>">📊 Excel</button>
                                                                            <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse"
                                                                                data-bs-target="#collapse-<%= mawbIdPrefix %>"></i>
                                                                        </div>
                                                                    </div>
                                                                    <div class="collapse" id="collapse-<%= mawbIdPrefix %>">
                                                                        <div class="card-body p-0">
                                                                            <%- include('warehouseAreaCards', { idPrefix: mawbIdPrefix, areaData: areaSubMap }) %>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            <% }) %>
                                                        <% } else { %>
                                                            <%- include('warehouseAreaCards', { idPrefix: `${id}-loc-${locIndex}-prod-${prodIndex}`, areaData: map[location][product] }) %>
                                                        <% } %>

                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>

                                    </div>
                                </div>
                            </div>
                        <% }) %>

                    <% } else { %>

                        <% Object.keys(map).forEach((product, index) => {
                            const isMawbProduct = mawbProducts.includes(product);
                        %>
                            <div class="card my-3">
                                <div class="card-header d-flex justify-content-between align-items-center flex-wrap">
                                    <div class="toggle-header" style="cursor: pointer;"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#collapse-<%= id %>-<%= index %>">
                                        <strong><%= (productMapping[product] || product.toUpperCase()) %></strong>
                                    </div>
                                    <div class="section-toolbar">
                                        <div class="badge bg-danger">
                                            <%= Object.values(map[product]).flat().length %> orders
                                        </div>
                                        <% Object.keys(map[product]).forEach(method => {
                                            const methodCount = map[product][method].length;
                                            if (methodCount > 0) { %>
                                                <span class="badge
                                                    <%= method === 'Standard' ? 'bg-primary' :
                                                        method === 'Express' ? 'bg-warning text-dark' :
                                                        method === 'Drop Off' ? 'bg-info text-dark' :
                                                        method === 'Immediate' ? 'bg-danger' :
                                                        method === 'Self Collect' ? 'bg-success' : 'bg-secondary' %>">
                                                    <%= method %>: <%= methodCount %>
                                                </span>
                                        <% } }) %>
                                        <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                            data-target="#collapse-<%= id %>-<%= index %>"
                                            data-section-name="<%= (productMapping[product] || product.toUpperCase()) %>">📋 Copy</button>
                                        <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                            data-target="#collapse-<%= id %>-<%= index %>"
                                            data-section-name="<%= (productMapping[product] || product.toUpperCase()) %>">📊 Excel</button>
                                        <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse"
                                            data-bs-target="#collapse-<%= id %>-<%= index %>"></i>
                                    </div>
                                </div>
                                <div class="collapse" id="collapse-<%= id %>-<%= index %>">
                                    <div class="card-body p-0">
                                        <% if (isMawbProduct) {
                                            const mawbGroups = {};
                                            Object.keys(map[product]).forEach(method => {
                                                map[product][method].forEach(order => {
                                                    const m = order.mawbNo || 'Unassigned';
                                                    if (!mawbGroups[m]) mawbGroups[m] = [];
                                                    mawbGroups[m].push(order);
                                                });
                                            });
                                            const mawbKeysSorted = Object.keys(mawbGroups).sort((a, b) => {
                                                const maxAgeA = Math.max(...mawbGroups[a].map(o => o.age));
                                                const maxAgeB = Math.max(...mawbGroups[b].map(o => o.age));
                                                return maxAgeB - maxAgeA;
                                            });
                                        %>
                                            <% mawbKeysSorted.forEach((mawb, mawbIndex) => {
                                                const mawbOrders = mawbGroups[mawb];
                                                const mawbAges = mawbOrders.map(o => o.age);
                                                const mawbMaxAge = Math.max(...mawbAges);
                                                const mawbMinAge = Math.min(...mawbAges);
                                                const mawbAgeLabel = mawbMaxAge === mawbMinAge ? `${mawbMaxAge}` : `${mawbMaxAge}-${mawbMinAge}`;
                                                const methodSubMap = {};
                                                mawbOrders.forEach(order => {
                                                    const meth = order.jobMethod || 'Unknown';
                                                    if (!methodSubMap[meth]) methodSubMap[meth] = [];
                                                    methodSubMap[meth].push(order);
                                                });
                                                const mawbIdPrefix = `${id}-${index}-mawb-${mawbIndex}`;
                                            %>
                                                <div class="card my-2 mx-3">
                                                    <div class="card-header d-flex justify-content-between align-items-center">
                                                        <div class="toggle-header" style="cursor: pointer;"
                                                            data-bs-toggle="collapse"
                                                            data-bs-target="#collapse-<%= mawbIdPrefix %>">
                                                            <strong>MAWB: <%= mawb %></strong>
                                                            <span class="badge
                                                                <%= mawbMaxAge >= 3 ? 'bg-dark' :
                                                                    mawbMaxAge >= 2 ? 'bg-danger' :
                                                                    mawbMaxAge >= 1 ? 'bg-warning text-dark' : 'bg-success' %> ms-2">
                                                                <%= mawbAgeLabel %> days
                                                            </span>
                                                        </div>
                                                        <div class="section-toolbar">
                                                            <span class="badge bg-info"><%= mawbOrders.length %> orders</span>
                                                            <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                                                data-target="#collapse-<%= mawbIdPrefix %>"
                                                                data-section-name="MAWB <%= mawb %>">📋 Copy</button>
                                                            <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                                                data-target="#collapse-<%= mawbIdPrefix %>"
                                                                data-section-name="MAWB <%= mawb %>">📊 Excel</button>
                                                            <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse"
                                                                data-bs-target="#collapse-<%= mawbIdPrefix %>"></i>
                                                        </div>
                                                    </div>
                                                    <div class="collapse" id="collapse-<%= mawbIdPrefix %>">
                                                        <div class="card-body p-0">
                                                            <%- include('warehouseMethodTables', { methodData: methodSubMap, tabId: id }) %>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% }) %>
                                        <% } else { %>
                                            <%- include('warehouseMethodTables', { methodData: map[product], tabId: id }) %>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>

                    <% } %>

                <% } %>

            </div>
        <% }) %>
    </div>