<% /* Locals expected: disp ({name, data, count}), idPrefix (string, unique per assignee), date (string), productMapping (object) */ %>
<div class="card my-2 mx-3">
    <div class="card-header" style="padding: 0.75rem 1rem;">
        <div class="d-flex align-items-center justify-content-between">
            <div class="toggle-header" style="cursor: pointer; flex-grow: 1;" data-bs-toggle="collapse" data-bs-target="#collapse-<%= idPrefix %>">
                <strong><%= disp.name %> <span style="font-weight:normal;">(<%= disp.data.__areas ? disp.data.__areas.filter(a => a && a.trim().toUpperCase() !== 'N/A').join(', ') : '' %>)</span></strong>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-success"><%= disp.count %> jobs</span>
                <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                        data-target="#collapse-<%= idPrefix %>"
                        data-section-name="<%= disp.name %> (<%= date %>)">📋 Copy</button>
                <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                        data-target="#collapse-<%= idPrefix %>"
                        data-section-name="<%= disp.name %> (<%= date %>)">📊 Excel</button>
                <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#collapse-<%= idPrefix %>"></i>
            </div>
        </div>
    </div>
    <div class="collapse" id="collapse-<%= idPrefix %>">
        <div class="card-body p-0">
            <% Object.keys(disp.data.__products).forEach((product, prodIndex) => {
                const productCount = disp.data.__products[product].length;
            %>
                <div class="card my-2 mx-3">
                    <div class="card-header" style="padding: 0.75rem 1rem;">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="toggle-header" style="cursor: pointer; flex-grow: 1;" data-bs-toggle="collapse" data-bs-target="#collapse-<%= idPrefix %>-<%= prodIndex %>">
                                <strong><%= (productMapping[product] || product.toUpperCase()) %></strong>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-warning text-dark"><%= productCount %> jobs</span>
                                <button type="button" class="btn btn-sm btn-outline-secondary toolbar-btn copy-tracking-btn"
                                        data-target="#collapse-<%= idPrefix %>-<%= prodIndex %>"
                                        data-section-name="<%= disp.name %> - <%= (productMapping[product] || product.toUpperCase()) %>">📋 Copy</button>
                                <button type="button" class="btn btn-sm btn-outline-success toolbar-btn export-excel-btn"
                                        data-target="#collapse-<%= idPrefix %>-<%= prodIndex %>"
                                        data-section-name="<%= disp.name %> - <%= (productMapping[product] || product.toUpperCase()) %>">📊 Excel</button>
                                <i class="bi bi-caret-down-fill toggle-header" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#collapse-<%= idPrefix %>-<%= prodIndex %>"></i>
                            </div>
                        </div>
                    </div>
                    <div class="collapse" id="collapse-<%= idPrefix %>-<%= prodIndex %>">
                        <div class="card-body p-0">
                            <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0">
                                <thead>
                                    <tr>
                                        <th>Tracking Number</th>
                                        <th>Area</th>
                                        <th>Name</th>
                                        <th>Main Phone</th>
                                        <th>Go Rush Remark</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% disp.data.__products[product].forEach(order => { %>
                                        <tr>
                                            <td class="track-no"><%= order.doTrackingNumber %></td>
                                            <td><%= order.area || '-' %></td>
                                            <td><%= order.receiverName %></td>
                                            <td><%= order.receiverPhoneNumber %></td>
                                            <td><%= order.grRemark %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>
