<!-- Navbar-specific CSS -->
<style>
  .navbar-nav.flex-row {
    flex-direction: row !important;
  }
  .navbar {
    background-color: transparent;
  }
  .container-bg {
    background-color: #333;
  }
  .navbar-nav.flex-row .nav-item {
    margin-right: 10px;
  }
  .logo {
    height: 40px;
    width: auto;
    max-height: 40px;
  }
  @media (max-width: 768px) {
    .logo {
      height: 30px;
      max-height: 30px;
    }
  }
  @media (max-width: 480px) {
    .logo {
      height: 25px;
      max-height: 25px;
    }
  }
  .navbar-inner {
    position: relative;
  }
  .navbar-logo-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  /* Highlight the nav link / dropdown item matching the current page */
  .navbar-nav .nav-link.active-page {
    background-color: rgba(255, 255, 255, 0.18);
    color: #fff !important;
    font-weight: 700;
    border-radius: 6px;
  }
  .navbar-nav .dropdown-item.active-page {
    background-color: #0d6efd;
    color: #fff !important;
    font-weight: 600;
  }

  /* On mobile the navbar collapses into a stacked menu — center the links,
     dropdown toggles and dropdown items/headers so they read like a phone
     menu instead of a left-aligned desktop list. */
  @media (max-width: 991.98px) {
    .navbar-nav .nav-link,
    .navbar-nav .dropdown-toggle,
    .navbar-nav .dropdown-item,
    .navbar-nav .dropdown-header {
      text-align: center;
    }
    .navbar-nav .dropdown-menu {
      text-align: center;
    }
  }
</style>

