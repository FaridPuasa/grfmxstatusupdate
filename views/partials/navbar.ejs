<script>
  // Highlight whichever nav link / dropdown item points at the current page, and
  // highlight its parent dropdown toggle too so the active section is obvious.
  document.addEventListener('DOMContentLoaded', function () {
    var currentPath = window.location.pathname.replace(/\/+$/, '') || '/';
    document.querySelectorAll('.navbar-nav .nav-link, .navbar-nav .dropdown-item').forEach(function (link) {
      var href = link.getAttribute('href');
      if (!href || href === '#' || /^https?:\/\//i.test(href)) return;
      var linkPath = href.replace(/\/+$/, '') || '/';
      if (linkPath !== currentPath) return;

      link.classList.add('active-page');
      var parentDropdown = link.closest('.dropdown');
      if (parentDropdown) {
        var toggle = parentDropdown.querySelector(':scope > .dropdown-toggle');
        if (toggle) toggle.classList.add('active-page');
      }
    });
  });
</script>